---
export const prerender = true;
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";
import { products } from "../data/products.ts";

// 16 featured items across the four most-recent drops: NSO, PSG,
// Yuzuha/Alice and misc. Excludes Toki, Blanc Bunny and Evelyn.
const featured = [
  // NSO drop
  "nso-deskmat",
  "nso-ame-tapestry",
  "nso-kangel-tapestry",
  "nso-print",
  "nso-ame-sticker",
  // PSG drop
  "psg-deskmat",
  "psg-panty-tapestry",
  "psg-stocking-tapestry",
  "psg-panty-acrylic",
  "psg-stocking-acrylic",
  "psg-panty-sticker",
  // Yuzuha & Alice
  "deskmat-yuzuha-alice",
  "print-yuzuha",
  "print-alice",
  "sticker-yuzuha",
  "sticker-alice",
].map(slug => products.find(p => p.slug === slug)).filter(Boolean);

const roster = [
  { key: "ame",      img: "/showcase/roster/ame.webp",      name: "Ame",       faction: "Off &amp; online",           universe: "Needy Streamer Overload", tag: "NSO" },
  { key: "kangel",   img: "/showcase/roster/kangel.webp",   name: "K.Angel",   faction: "Public-face streamer",       universe: "Needy Streamer Overload", tag: "NSO" },
  { key: "panty",    img: "/showcase/roster/panty.webp",    name: "Panty",     faction: "Anarchy sisters",            universe: "Panty &amp; Stocking",    tag: "PSG" },
  { key: "stocking", img: "/showcase/roster/stocking.webp", name: "Stocking",  faction: "Anarchy sisters",            universe: "Panty &amp; Stocking",    tag: "PSG" },
  { key: "yuzuha",   img: "/showcase/roster/yuzuha.webp",   name: "Yuzuha",    faction: "Tokyo Zero original",        universe: "Chromadipity Core",       tag: "OC" },
  { key: "chii",     img: "/showcase/roster/chii.webp",     name: "Chii",      faction: "Vtuber commission",          universe: "Independent commission",  tag: "VT" },
];
---
<Base title="portfolio" pageClass="page-index" showHeader={false} showFooter={true}>

  <!-- ================================================================
       SECTION TRACKER — fixed right rail, misc-styled
       ================================================================ -->
  <nav class="tracker" aria-label="Section navigation">
    <a class="tracker__item is-active" data-section="hero" href="#hero">
      <span class="tracker__bar"></span><span class="tracker__num">01</span><span class="tracker__lbl">hero</span>
    </a>
    <a class="tracker__item" data-section="graphic" href="#graphic">
      <span class="tracker__bar"></span><span class="tracker__num">02</span><span class="tracker__lbl">graphic</span>
    </a>
    <a class="tracker__item" data-section="roster" href="#roster">
      <span class="tracker__bar"></span><span class="tracker__num">03</span><span class="tracker__lbl">roster</span>
    </a>
    <a class="tracker__item" data-section="photo" href="#photo">
      <span class="tracker__bar"></span><span class="tracker__num">04</span><span class="tracker__lbl">photo</span>
    </a>
    <a class="tracker__item" data-section="catalog" href="#catalog">
      <span class="tracker__bar"></span><span class="tracker__num">05</span><span class="tracker__lbl">catalog</span>
    </a>
  </nav>

  <!-- ================================================================
       01 · HERO — auto-crossfade carousel between NSO + Yuzuha/Alice
       ================================================================ -->
  <section id="hero" class="hero" aria-label="hero">
    <img class="hero__art is-active" src="/hero/nso-hero.webp"          alt="NSO — Ame &amp; KAngel key art" data-slide="0" />
    <img class="hero__art"           src="/hero/yuzuha-alice-hero.webp" alt="Yuzuha &amp; Alice key art"     data-slide="1" />

    <div class="hero__dots" role="tablist" aria-label="Hero carousel">
      <button class="hero__dot is-active" data-goto="0" aria-label="Slide 1"></button>
      <button class="hero__dot"           data-goto="1" aria-label="Slide 2"></button>
    </div>
  </section>

  <!-- ================================================================
       POST-HERO STRIP — soft info bar
       ================================================================ -->
  <div class="hero-strip" aria-hidden="true" data-reveal>
    <span><em>design</em> apex mk3 &middot; beam visionary &middot; branding pro</span>
    <span><em>cloud</em> s3 &middot; cloudfront &middot; lambda &middot; athena &middot; terraform</span>
    <span><em>spend</em> ~$2/mo &mdash; <a href="/status/">/status</a> &middot; <a href="/cost/">/cost</a></span>
  </div>

  <!-- ================================================================
       BOUNDARY DIVIDER — last full-bleed element
       ================================================================ -->
  <div class="section-divider section-divider--boundary" data-reveal>
    <span class="section-divider__num">01</span>
    <span class="section-divider__label">graphic interfaces &middot; drop 01</span>
    <span class="section-divider__mark"></span>
  </div>

  <!-- ================================================================
       02 · GRAPHIC DESIGN
       ================================================================ -->
  <section id="graphic" class="sec">
    <div class="sec__head" data-reveal>
      <p class="sec__num">02 / 05</p>
      <p class="sec__eyebrow">graphic design</p>
      <h2 class="sec__title">the illustration.</h2>
      <p class="sec__lede">
        Character studies, key art, print-ready compositions. A featured piece
        rotates in this frame &mdash; each one is the source for something
        in the catalog.
      </p>
    </div>

    <div class="sec-tabs">
      <a class="sec-tab is-active">chromadipity</a>
      <a class="sec-tab">psg</a>
      <a class="sec-tab">nso</a>
      <a class="sec-tab">genshin &middot; hsr</a>
      <a class="sec-tab">vtuber</a>
    </div>

    <!-- ============================================================
         Cinema editorial board — dark mode, motion + still spread,
         every cell at native aspect ratio, blueprint numerals + hover
         metadata reveal, video cells auto-play muted looped.
         ============================================================ -->
    <div class="gd-board">
      <div class="gd-mark gd-mark--head">
        <span class="gd-mark__dot" aria-hidden="true"></span>
        <span>no. 01</span>
        <span class="gd-mark__sep">/</span>
        <span>drop 01</span>
        <span class="gd-mark__sep">/</span>
        <span>chromadipity core</span>
        <span class="gd-mark__sep">/</span>
        <span>the constellation</span>
      </div>

      <!-- ================================================================
           THE CONSTELLATION — full-viewport dark theatre of design work
           14 nodes: 12 stills + 2 reels. Positioned by cluster:
             upper-left  · character portraits (cover, citlali, fmig)
             center      · motion + hero widescreens
             upper-right · wide banner headers
             right edge  · tall vertical banners
             bottom      · square set & prints, wide floaters
           SVG edges connect within clusters (bright/yellow) and across
           clusters (faint) to visualize the relationship graph.
           ================================================================ -->
      <div class="cn-space" aria-label="Constellation of graphic design pieces">
        <svg class="cn-edges" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
          <!-- Motion/hero cluster (yellow — the two reels + widescreen) -->
          <line class="cn-edge cn-edge--yellow" x1="48" y1="32" x2="68" y2="55" />
          <line class="cn-edge cn-edge--yellow" x1="48" y1="32" x2="28" y2="55" />
          <line class="cn-edge cn-edge--yellow" x1="28" y1="55" x2="68" y2="55" />

          <!-- Character portrait cluster (upper-left) -->
          <line class="cn-edge" x1="14" y1="22" x2="30" y2="12" />
          <line class="cn-edge" x1="14" y1="22" x2="10" y2="40" />
          <line class="cn-edge" x1="30" y1="12" x2="10" y2="40" />

          <!-- Wide banner + tall banner cluster (right) -->
          <line class="cn-edge" x1="82" y1="20" x2="92" y2="46" />
          <line class="cn-edge" x1="92" y1="46" x2="94" y2="68" />
          <line class="cn-edge" x1="82" y1="20" x2="94" y2="68" />

          <!-- Square / print cluster (bottom center) -->
          <line class="cn-edge" x1="42" y1="82" x2="58" y2="88" />
          <line class="cn-edge" x1="58" y1="88" x2="74" y2="74" />
          <line class="cn-edge" x1="42" y1="82" x2="74" y2="74" />

          <!-- Wide floaters (bottom corners) -->
          <line class="cn-edge" x1="16" y1="82" x2="42" y2="82" />
          <line class="cn-edge" x1="74" y1="74" x2="86" y2="84" />

          <!-- Cross-cluster narrative edges (faint) -->
          <line class="cn-edge cn-edge--faint" x1="30" y1="12" x2="82" y2="20" />
          <line class="cn-edge cn-edge--faint" x1="14" y1="22" x2="48" y2="32" />
          <line class="cn-edge cn-edge--faint" x1="68" y1="55" x2="82" y2="20" />
          <line class="cn-edge cn-edge--faint" x1="28" y1="55" x2="42" y2="82" />
          <line class="cn-edge cn-edge--faint" x1="68" y1="55" x2="74" y2="74" />
          <line class="cn-edge cn-edge--faint" x1="10" y1="40" x2="16" y2="82" />
        </svg>

        <!-- Character portraits — upper-left arc -->
        <figure class="cn-node cn-node--m" style="--ar: 0.80; --x: 14%; --y: 22%; --d: 0" data-tag="cover 04">
          <img src="/showcase/graphics/cover.webp" alt="Cover 04" loading="lazy" />
          <span class="cn-node__tag">cover 04</span>
        </figure>
        <figure class="cn-node cn-node--m" style="--ar: 0.79; --x: 30%; --y: 12%; --d: 3" data-tag="citlali">
          <img src="/showcase/graphics/citlali.webp" alt="Citlali key art" loading="lazy" />
          <span class="cn-node__tag">citlali</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 0.80; --x: 10%; --y: 40%; --d: 6" data-tag="fmig · post">
          <img src="/showcase/graphics/fmig-post.webp" alt="FMIG post" loading="lazy" />
          <span class="cn-node__tag">fmig · post</span>
        </figure>

        <!-- Motion / hero cluster — center of gravity -->
        <figure class="cn-node cn-node--xl cn-node--video" style="--ar: 2.37; --x: 48%; --y: 32%; --d: 1" data-tag="header mograph">
          <video muted loop playsinline autoplay preload="metadata" poster="/showcase/motion/header-mograph-poster.jpg">
            <source src="/showcase/motion/header-mograph.webm" type="video/webm" />
            <source src="/showcase/motion/header-mograph.mp4" type="video/mp4" />
          </video>
          <span class="cn-node__tag">header mograph &middot; motion</span>
        </figure>
        <figure class="cn-node cn-node--l" style="--ar: 2.22; --x: 68%; --y: 55%; --d: 4" data-tag="chii · widescreen">
          <img src="/showcase/graphics/chii3.webp" alt="Chii widescreen illustration" loading="lazy" />
          <span class="cn-node__tag">chii &middot; widescreen</span>
        </figure>
        <figure class="cn-node cn-node--m cn-node--video" style="--ar: 0.5625; --x: 28%; --y: 55%; --d: 7" data-tag="comp 1_1 · reel">
          <video muted loop playsinline autoplay preload="metadata" poster="/showcase/motion/comp-1-1-poster.jpg">
            <source src="/showcase/motion/comp-1-1.webm" type="video/webm" />
            <source src="/showcase/motion/comp-1-1.mp4" type="video/mp4" />
          </video>
          <span class="cn-node__tag">comp 1_1 &middot; reel</span>
        </figure>

        <!-- Wide + tall banner cluster (right edge) -->
        <figure class="cn-node cn-node--l" style="--ar: 2.37; --x: 82%; --y: 20%; --d: 2" data-tag="citlali · header">
          <img src="/showcase/graphics/citlali-header.webp" alt="Citlali header" loading="lazy" />
          <span class="cn-node__tag">citlali &middot; header</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 0.55; --x: 92%; --y: 46%; --d: 5" data-tag="cipher · vertical">
          <img src="/showcase/graphics/cipher-vertical.webp" alt="Cipher vertical banner" loading="lazy" />
          <span class="cn-node__tag">cipher &middot; vertical</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 0.61; --x: 94%; --y: 68%; --d: 8" data-tag="fuwawa · tall">
          <img src="/showcase/graphics/fuwawa-banner.webp" alt="Fuwawa banner" loading="lazy" />
          <span class="cn-node__tag">fuwawa &middot; tall</span>
        </figure>

        <!-- Square / print cluster (bottom center) -->
        <figure class="cn-node cn-node--s" style="--ar: 1; --x: 42%; --y: 82%; --d: 3" data-tag="concept">
          <img src="/showcase/graphics/concept-square.webp" alt="Concept square" loading="lazy" />
          <span class="cn-node__tag">concept</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 1; --x: 58%; --y: 88%; --d: 6" data-tag="product">
          <img src="/showcase/graphics/product-square.webp" alt="Product square" loading="lazy" />
          <span class="cn-node__tag">product</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 1.25; --x: 74%; --y: 74%; --d: 9" data-tag="topbox">
          <img src="/showcase/graphics/topbox.webp" alt="Topbox" loading="lazy" />
          <span class="cn-node__tag">topbox</span>
        </figure>

        <!-- Wide floaters (bottom corners) -->
        <figure class="cn-node cn-node--m" style="--ar: 2.37; --x: 16%; --y: 82%; --d: 4" data-tag="ayaka · header">
          <img src="/showcase/graphics/dodgers-ayaka-header.webp" alt="Dodgers Ayaka header" loading="lazy" />
          <span class="cn-node__tag">ayaka &middot; header</span>
        </figure>
        <figure class="cn-node cn-node--m" style="--ar: 1.78; --x: 86%; --y: 84%; --d: 10" data-tag="fuwamoco · header">
          <img src="/showcase/graphics/fuwamoco-header.webp" alt="Fuwamoco header" loading="lazy" />
          <span class="cn-node__tag">fuwamoco &middot; header</span>
        </figure>
      </div>

      <div class="gd-mark gd-mark--foot">
        <span class="gd-mark__dot" aria-hidden="true"></span>
        <span>end of drop 01 &middot; fourteen pieces &middot; two reels</span>
      </div>
    </div>

    <div class="sec-foot">
      <div class="pager">
        <button aria-label="previous">&larr;</button>
        <span class="pager__nums">01 / 12</span>
        <button aria-label="next">&rarr;</button>
      </div>
      <p class="sec-foot__meta">graphic 02 &middot; system interfaces</p>
    </div>
  </section>

  <!-- ================================================================
       03 · CHARACTER ROSTER
       ================================================================ -->
  <section id="roster" class="sec">
    <div class="sec__head" data-reveal>
      <p class="sec__num">03 / 05</p>
      <p class="sec__eyebrow">the roster</p>
      <h2 class="sec__title">character work.</h2>
      <p class="sec__lede">
        Portrait, key art, chibi variant, full-body pose &mdash; each character
        in the roster serves at least one product category.
      </p>
    </div>

    <div class="roster-body">
      <aside class="roster-rail">
        {roster.map((r, i) => (
          <button class:list={["portrait", i === 0 && "is-active"]} data-key={r.key} aria-label={r.name}>
            <img src={r.img} alt={r.name} />
          </button>
        ))}
        <a class="roster-all" href="/catalog/">all &rarr;</a>
      </aside>

      <div class="roster-stage">
        <div class="roster-block" aria-hidden="true"></div>
        <div class="roster-letters" data-target="letters" aria-hidden="true">AME</div>

        <div class="roster-hero">
          <img class="roster-img" src="/showcase/roster/ame.webp" alt="Ame" data-target="img" />
        </div>

        <div class="roster-card" data-reveal>
          <p class="roster-card__num" data-target="num">01 / 06</p>
          <h3 class="roster-card__name" data-target="name">Ame</h3>
          <div class="roster-card__rule"></div>
          <dl class="roster-card__dl">
            <dt>faction</dt><dd data-target="faction">Off &amp; online</dd>
            <dt>universe</dt><dd data-target="universe">Needy Streamer Overload</dd>
            <dt>tag</dt><dd data-target="tag">NSO</dd>
          </dl>
          <p class="roster-card__desc">
            Hand-illustrated character work &mdash; portraits, key art, chibi
            variants, and full-body poses. Each character in the roster serves
            a specific product category: deskmats, tapestries, prints, or
            acrylic stands.
          </p>
        </div>
      </div>
    </div>

    <!-- Compact theme selector — small aside inside the roster -->
    <div class="theme-mini" data-reveal>
      <div class="theme-mini__head">
        <p class="theme-mini__eyebrow">experimental &middot; themed rooms</p>
        <p class="theme-mini__lede">two alternate storefronts &mdash; each takes over the full page.</p>
      </div>
      <div class="theme-mini__grid">
        <a class="theme-sq theme-sq--psg" href="/work/psg/" aria-label="Enter PSG storefront">
          <img class="theme-sq__char theme-sq__char--l" src="/assets/psg-panty-sticker.webp"    alt="" aria-hidden="true" />
          <img class="theme-sq__char theme-sq__char--r" src="/assets/psg-stocking-sticker.webp" alt="" aria-hidden="true" />
          <span class="theme-sq__label">psg</span>
        </a>
        <a class="theme-sq theme-sq--nso" href="/work/nso/" aria-label="Enter NSO storefront">
          <img class="theme-sq__char theme-sq__char--l" src="/assets/nso-ame-sticker.webp"    alt="" aria-hidden="true" />
          <img class="theme-sq__char theme-sq__char--r" src="/assets/nso-kangel-sticker.webp" alt="" aria-hidden="true" />
          <span class="theme-sq__label">nso</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ================================================================
       INTERLUDE — 16:9 vtuber header between roster + photo
       ================================================================ -->
  <figure class="interlude interlude--wide">
    <img src="/showcase/graphics/fuwamoco-header.webp" alt="FUWAMOCO header" loading="lazy" />
    <figcaption>
      <span class="interlude__lbl">fuwamoco header &middot; vtuber drop</span>
      <span class="interlude__ratio">16 : 9</span>
    </figcaption>
  </figure>

  <!-- ================================================================
       04 · PRODUCT PHOTOGRAPHY — 3D coverflow carousel + editorial sidebar
       ================================================================ -->
  <section id="photo" class="sec">
    <!-- viewport-fit wrapper: header + carousel take one screen height -->
    <div class="photo-viewport">
      <div class="sec__head" data-reveal>
        <p class="sec__num">04 / 05</p>
        <p class="sec__eyebrow">product photography</p>
        <h2 class="sec__title">finished pieces.</h2>
        <p class="sec__lede">
          Illustration &rarr; production &rarr; photography. Ten frames from the
          drop &mdash; deskmats, prints, stickers, packaging, flat-lays.
        </p>
      </div>

      <div class="photo-editorial">
        <!-- 3D coverflow carousel — auto-rotates through 10 photo frames -->
        <div class="lead-3d" aria-label="Product photography carousel">
          <div class="lead-3d__stage">
            <button class="lead-3d__card" data-i="0" aria-label="Frame 01">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-01.webp" alt="Product photography frame 01" loading="lazy" />
                <span class="lead-3d__card-tag">01</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="1" aria-label="Frame 02">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-02.webp" alt="Product photography frame 02" loading="lazy" />
                <span class="lead-3d__card-tag">02</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="2" aria-label="Frame 03">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-03.webp" alt="Product photography frame 03" loading="lazy" />
                <span class="lead-3d__card-tag">03</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="3" aria-label="Frame 04">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-04.webp" alt="Product photography frame 04" loading="lazy" />
                <span class="lead-3d__card-tag">04</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="4" aria-label="Frame 05">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-05.webp" alt="Product photography frame 05" loading="lazy" />
                <span class="lead-3d__card-tag">05</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="5" aria-label="Frame 06">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-06.webp" alt="Product photography frame 06" loading="lazy" />
                <span class="lead-3d__card-tag">06</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="6" aria-label="Frame 07">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-07.webp" alt="Product photography frame 07" loading="lazy" />
                <span class="lead-3d__card-tag">07</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="7" aria-label="Frame 08">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-08.webp" alt="Product photography frame 08" loading="lazy" />
                <span class="lead-3d__card-tag">08</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="8" aria-label="Frame 09">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-09.webp" alt="Product photography frame 09" loading="lazy" />
                <span class="lead-3d__card-tag">09</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="9" aria-label="Frame 10">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-10.webp" alt="Product photography frame 10" loading="lazy" />
                <span class="lead-3d__card-tag">10</span>
              </div>
            </button>
          </div>

          <div class="lead-3d__ctrl">
            <button class="lead-3d__arrow" data-nav="prev" aria-label="Previous">&larr;</button>
            <div class="lead-3d__dots">
              <button class="is-active" data-goto="0" aria-label="Frame 01"></button>
              <button                   data-goto="1" aria-label="Frame 02"></button>
              <button                   data-goto="2" aria-label="Frame 03"></button>
              <button                   data-goto="3" aria-label="Frame 04"></button>
              <button                   data-goto="4" aria-label="Frame 05"></button>
              <button                   data-goto="5" aria-label="Frame 06"></button>
              <button                   data-goto="6" aria-label="Frame 07"></button>
              <button                   data-goto="7" aria-label="Frame 08"></button>
              <button                   data-goto="8" aria-label="Frame 09"></button>
              <button                   data-goto="9" aria-label="Frame 10"></button>
            </div>
            <button class="lead-3d__arrow" data-nav="next" aria-label="Next">&rarr;</button>
          </div>
        </div>

        <!-- Editorial sidebar — dynamic caption for the active card -->
        <aside class="photo-side" data-reveal>
          <p class="photo-side__label">// featured</p>
          <h3 class="photo-side__title">the drop.</h3>

          <div class="photo-side__cap" data-target="side-cap">
