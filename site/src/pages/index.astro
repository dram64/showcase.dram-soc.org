    }
    .hero-strip a { color: var(--misc-accent, #5061b9); text-decoration: none; border-bottom: 1px solid currentColor; }

    /* ============================================================
       SECTION DIVIDERS — thin hairline with small caps text
       ============================================================ */
    .section-divider {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 16px clamp(80px, 8vw, 120px);
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      border-bottom: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      background: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
    }
    .section-divider__num {
      color: var(--misc-accent, #5061b9);
      font-weight: 500;
    }
    .section-divider__label { flex: 1; }
    .section-divider__mark {
      display: inline-block;
      width: 32px;
      height: 2px;
      background: var(--misc-accent, #5061b9);
    }

    /* ============================================================
       SHARED — section shell (used by sec02 through sec06).
       Sections fill the full space between rails (main padding = --rails-w)
       with a small internal breathing gutter so content doesn't touch
       the rail edges.
       ============================================================ */
    .sec {
      padding: clamp(60px, 8vw, 100px) clamp(24px, 4vw, 64px);
      max-width: none;
      width: 100%;
      margin: 0 auto;
      box-sizing: border-box;
    }
    .sec__head { margin-bottom: 5vh; max-width: 820px; }
    .sec__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0 0 12px;
    }
    .sec__eyebrow {
      font-family: 'Beam Visionary', cursive;
      font-size: clamp(1.1rem, 1.6vw, 1.4rem);
      color: var(--misc-accent, #5061b9);
      margin: 0 0 8px;
      line-height: 1;
    }
    .sec__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(2rem, 4vw, 2.8rem);
      line-height: 1;
      color: var(--misc-ink, #1a1a1a);
      text-transform: lowercase;
      margin: 0 0 20px;
      letter-spacing: -0.01em;
    }
    .sec__lede {
      font-family: 'Branding Pro', sans-serif;
      font-size: 1rem;
      line-height: 1.55;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
      max-width: 620px;
    }
    .sec-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.10));
      gap: 20px;
      flex-wrap: wrap;
    }
    .sec-foot__meta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
    }
    .pager { display: inline-flex; align-items: center; gap: 14px; }
    .pager button {
      width: 38px; height: 38px;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      background: transparent;
      color: var(--misc-ink, #14131a);
      cursor: pointer;
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
      transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .pager button:hover { background: var(--misc-accent, #5061b9); color: #fff; border-color: var(--misc-accent, #5061b9); }
    .pager__nums {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.82rem;
      letter-spacing: 0.14em;
      color: var(--misc-ink, #14131a);
    }

    /* ============================================================
       GRAPHIC DESIGN
       ============================================================ */
    .sec-tabs {
      display: flex;
      gap: 20px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      margin-bottom: 32px;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      overflow-x: auto;
    }
    .sec-tab {
      color: var(--misc-ink-soft, #6b6b6b);
      text-decoration: none;
      padding-bottom: 4px;
      border-bottom: 1px solid transparent;
      transition: color 140ms ease, border-color 140ms ease;
      cursor: pointer;
      white-space: nowrap;
    }
    .sec-tab:hover { color: var(--misc-ink, #14131a); }
    .sec-tab.is-active {
      color: var(--misc-ink, #14131a);
      border-bottom-color: var(--misc-accent, #5061b9);
    }
    .graphic-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 60px;
      gap: 32px;
    }
    .graphic-vrail {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 40px;
    }
    .graphic-vrail span {
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-family: 'Apex Mk3', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
      white-space: nowrap;
    }
    .graphic-stage { position: relative; }
    .graphic-caption {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.88rem;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 16px 0 0;
      font-style: italic;
    }
    /* Legacy single-slot (unused now; kept for safety) */
    .graphic-slot {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding: 60px;
      min-height: 460px;
      background: #fff;
      border: 1px dashed rgba(80, 97, 185, 0.4);
    }

    /* ============================================================
       Cinema editorial board (dark) — .gd-board container
       ============================================================ */
    #graphic {
      padding-top: clamp(40px, 5vw, 72px);
      padding-bottom: clamp(40px, 5vw, 72px);
    }
    .gd-board {
      display: flex;
      flex-direction: column;
      gap: clamp(12px, 1.6vw, 22px);
      padding: clamp(6px, 1vw, 12px) 0;
    }
    /* Masonry — packs cells shortest-column-first so no white space is
       left between images within a column. Column-order visually, but
       every cell keeps its native aspect ratio (--ar). */
    .gd-mason {
      columns: 3;
      column-gap: clamp(10px, 1.2vw, 16px);
      break-inside: avoid;
    }
    .gd-mason .gd-cell {
      break-inside: avoid;
      -webkit-column-break-inside: avoid;
      page-break-inside: avoid;
      margin: 0 0 clamp(10px, 1.2vw, 16px) 0;
      width: 100%;
      display: block;
    }
    @media (max-width: 900px) { .gd-mason { columns: 2; } }
    @media (max-width: 560px) { .gd-mason { columns: 1; } }

    /* ============================================================
       THE CONSTELLATION — full-viewport dark theatre of design work
       14 nodes (12 stills + 2 reels) scatter across the section by
       inline --x / --y positions in %. Nodes drift on cnFloat with
       staggered --d delay. SVG edges dash-flow via cnFlow.
       Palette matches the rest of the site: slate-violet + yellow
       #ffee00 on the graphite gradient already applied to #graphic.
       ============================================================ */
    /* Constellation renders as a CSS-columns masonry so nodes pack
       shortest-column-first — no dead vertical space, no forced
       overlaps. Each node fills its column width and keeps its native
       aspect ratio, so the horizontal footprint is uniform per column
       and every piece reads at a real size on first scroll. */
    .cn-space {
      position: relative;
      isolation: isolate;
      width: 100%;
      columns: 5;
      column-gap: clamp(10px, 1vw, 16px);
      padding: clamp(20px, 2.5vh, 40px) 0;
      overflow: visible;
      /* CSS counter for the folio numeral drawn on every cell */
      counter-reset: folio;
    }
    @media (max-width: 1200px) { .cn-space { columns: 4; } }
    @media (max-width: 900px)  { .cn-space { columns: 3; } }
    @media (max-width: 560px)  { .cn-space { columns: 2; } }
    @media (max-width: 380px)  { .cn-space { columns: 1; } }
    .cn-edges {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
      display: none;
    }
    .cn-edge {
      stroke: rgba(80, 97, 185, 0.42);
      stroke-width: 0.16;
      fill: none;
      vector-effect: non-scaling-stroke;
      stroke-dasharray: 2 2.5;
    }
    .cn-edge--yellow {
      stroke: rgba(255, 238, 0, 0.42);
      stroke-width: 0.22;
      stroke-dasharray: 3 3;
    }
    .cn-edge--faint {
      stroke: rgba(255, 255, 255, 0.12);
      stroke-width: 0.10;
      stroke-dasharray: 1 3;
    }
    .cn-node {
      position: static;
      display: block;
      break-inside: avoid;
      -webkit-column-break-inside: avoid;
      page-break-inside: avoid;
      margin: 0 0 clamp(10px, 1vw, 16px) 0;
      width: 100%;
      aspect-ratio: var(--ar, 1);
      overflow: hidden;
      border: 1px solid rgba(80, 97, 185, 0.35);
      background: #0a0913;
      opacity: 0;
      transform: translateY(24px) scale(0.96);
      transition: opacity 720ms cubic-bezier(0.16, 1, 0.3, 1),
                  transform 380ms cubic-bezier(0.16, 1, 0.3, 1),
                  border-color 260ms ease,
                  box-shadow 320ms ease,
                  filter 260ms ease;
      transition-delay: calc(var(--d, 0) * 60ms);
      counter-increment: folio;
    }
    .cn-space.is-entered .cn-node {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    .cn-node img,
    .cn-node video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 420ms cubic-bezier(0.16, 1, 0.3, 1),
                  filter 260ms ease;
    }
    /* Blueprint folio numeral — magazine plate number top-left of every
       cell. Auto-increments via CSS counter, decimal-leading-zero pads
       to two digits (01, 02, ...). Fades out on hover so the tag caption
       can breathe. */
    .cn-node::before {
      content: counter(folio, decimal-leading-zero);
      position: absolute;
      top: 6px;
      left: 10px;
      z-index: 2;
      font-family: 'Apex Mk3', 'JetBrains Mono', monospace;
      font-weight: 300;
      font-size: clamp(1.3rem, 1.8vw, 2.2rem);
      line-height: 0.9;
      letter-spacing: -0.03em;
      color: rgba(255, 255, 255, 0.42);
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.6);
      pointer-events: none;
      transition: opacity 220ms ease;
    }
    .cn-node:hover::before { opacity: 0.15; }

    /* Metadata tag — hover reveals from the bottom with a slight rise */
    .cn-node__tag {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 14px 12px 10px;
      background: linear-gradient(180deg, transparent 0%, rgba(20, 19, 26, 0.92) 55%);
      color: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
      pointer-events: none;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 260ms ease, transform 260ms ease;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .cn-node:hover .cn-node__tag { opacity: 1; transform: translateY(0); }

    /* Hover polish — subtle scale + inner yellow rim + image tilt-in */
    .cn-node:hover {
      border-color: rgba(255, 238, 0, 0.85);
      box-shadow:
        inset 0 0 0 1px rgba(255, 238, 0, 0.28),
        0 12px 30px -12px rgba(0, 0, 0, 0.7);
      transform: translateY(-2px) scale(1.015);
      filter: brightness(1.06);
    }
    .cn-node:hover img,
    .cn-node:hover video {
      transform: scale(1.02);
      filter: saturate(1.05);
    }

    /* Size tiers are no-ops in the masonry layout — every cell fills
       the column width. Classes remain for compatibility. */
    .cn-node--xl, .cn-node--l, .cn-node--m,
    .cn-node--s, .cn-node--xs { width: 100%; }
    /* Character-close-ups strip is 0.13 aspect — at column width that
       would be ~8x column height. Clamp it to a reasonable height so
       the top portion shows without dominating a whole column. */
    .cn-node--totem {
      width: 100%;
      aspect-ratio: unset;
      max-height: clamp(320px, 42vh, 480px);
    }

    .cn-node--totem img {
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }
    /* Hide the ambient stars (were positioned relative to abs nodes) */
    .cn-star { display: none; }

    /* Ambient constellation stars — small pulsing points that fill the gaps
       between nodes and reinforce the "night sky" feel. Slate-violet, with
       occasional bigger yellow anchors. */
    .cn-star {
      position: absolute;
      top: var(--y, 50%);
      left: var(--x, 50%);
      width: 4px;
      height: 4px;
      background: rgba(80, 97, 185, 0.7);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      z-index: 0;
      animation: cnStar 4.4s ease-in-out infinite;
      animation-delay: calc(var(--sd, 0) * 0.55s);
    }
    .cn-star--big {
      width: 6px;
      height: 6px;
      background: rgba(255, 238, 0, 0.85);
      animation-name: cnStarYellow;
    }
    @keyframes cnStar {
      0%, 100% { opacity: 0.35; box-shadow: 0 0 0 0 rgba(80, 97, 185, 0); }
      50%      { opacity: 0.95; box-shadow: 0 0 10px 0 rgba(80, 97, 185, 0.55); }
    }
    @keyframes cnStarYellow {
      0%, 100% { opacity: 0.5; box-shadow: 0 0 0 0 rgba(255, 238, 0, 0); }
      50%      { opacity: 1;   box-shadow: 0 0 14px 2px rgba(255, 238, 0, 0.55); }
    }
    /* Subtle vertical drift — staggered via --d so nodes float out of sync */
    @keyframes cnFloat {
      0%, 100% { transform: translate(-50%, -50%) translateY(0px); }
      50%      { transform: translate(-50%, -50%) translateY(-10px); }
    }

    /* Mobile — collapse to a scroll-through vertical layout */
    @media (max-width: 900px) {
      .cn-space {
        min-height: 0;
        padding: 24px 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
        justify-items: center;
      }
      .cn-edges, .cn-star { display: none; }
      .cn-node {
        position: static;
        opacity: 1;
        transform: none;
        animation: none;
        transition: border-color 260ms ease, box-shadow 260ms ease;
        display: block;
      }
      .cn-space.is-entered .cn-node {
        transform: none;
        animation: none;
      }
      .cn-node--xl, .cn-node--l, .cn-node--m, .cn-node--s {
        width: min(92%, 460px);
      }
      .cn-node__tag { opacity: 1; transform: none; }
    }

    /* Editorial marks — mono pills that thread through the spread */
    .gd-mark {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 5px 14px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      align-self: flex-start;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: lowercase;
      color: rgba(255, 255, 255, 0.72);
      white-space: nowrap;
      overflow-x: auto;
      max-width: 100%;
    }
    .gd-mark--head,
    .gd-mark--foot {
      background: rgba(255, 238, 0, 0.06);
      border-color: rgba(255, 238, 0, 0.28);
      color: #ffee00;
    }
    .gd-mark__dot {
      width: 8px; height: 8px;
      background: #ffee00;
      border-radius: 50%;
      box-shadow: 0 0 12px rgba(255, 238, 0, 0.55);
      animation: gdMarkPulse 2.2s ease-in-out infinite;
    }
    .gd-mark__sep { color: rgba(255, 255, 255, 0.24); }
    .gd-mark__script {
      font-family: 'Beam Visionary', 'Apex Mk3', serif;
      font-style: italic;
      font-size: 1.05rem;
      letter-spacing: 0.04em;
      text-transform: none;
      color: #ffee00;
      opacity: 0.95;
      transform: translateY(-1px);
    }
    @keyframes gdMarkPulse {
      0%, 100% { opacity: 0.65; }
      50%      { opacity: 1;    box-shadow: 0 0 18px rgba(255, 238, 0, 0.8); }
    }

    /* Rows */
    .gd-row {
      display: grid;
      gap: clamp(12px, 1.4vw, 22px);
      align-items: start;
    }
    .gd-row--hero { grid-template-columns: 1fr; }
    .gd-row--3    { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr); }
    .gd-row--4    { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .gd-row--2    { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
    /* Rows where mixed aspect ratios should align at their bottom edge */
    .gd-row--baseline { align-items: end; }
    /* Narrow-middle 3-col — for accents that shouldn't dominate their neighbors */
    .gd-row--sm-mid.gd-row--3 {
      grid-template-columns: minmax(0, 1.5fr) minmax(0, 0.55fr) minmax(0, 1.5fr);
    }
    /* Slim row — constrained max-width, centered. Use for tall banner
       pairs so they don't render at full section width. */
    .gd-row--slim {
      max-width: 72%;
      margin-left: auto;
      margin-right: auto;
    }
    @media (max-width: 900px) {
      .gd-row--slim { max-width: 100%; }
    }

    /* Cells — every one uses native aspect-ratio (--ar) */
    .gd-cell {
      position: relative;
      margin: 0;
      aspect-ratio: var(--ar, 1);
      overflow: hidden;
      background: #0a0913;
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: transform 340ms cubic-bezier(0.34, 1.20, 0.64, 1),
                  border-color 220ms ease,
                  box-shadow 340ms ease;
    }
    .gd-cell:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 238, 0, 0.7);
      box-shadow: 0 26px 48px -22px rgba(0, 0, 0, 0.6);
    }
    .gd-cell img,
    .gd-cell video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }
    /* Blueprint numeral top-left — big, light-weight, translucent */
    .gd-cell::before {
      content: attr(data-idx);
      position: absolute;
      top: 10px;
      left: 14px;
      z-index: 3;
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(1.6rem, 2.4vw, 2.6rem);
      line-height: 0.85;
      color: rgba(255, 255, 255, 0.78);
      text-shadow: 0 2px 14px rgba(0, 0, 0, 0.65);
      letter-spacing: -0.04em;
      pointer-events: none;
    }
    /* Metadata caption — reveals on hover from the bottom */
    .gd-cell::after {
      content: attr(data-name) " · " attr(data-ratio) " · " attr(data-dim);
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 3;
      padding: 10px 14px 10px 14px;
      background: linear-gradient(180deg, transparent 0%, rgba(20, 19, 26, 0.82) 100%);
      color: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
      text-align: right;
      opacity: 0;
      transform: translateY(6px);
      transition: opacity 260ms ease, transform 260ms ease;
      pointer-events: none;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .gd-cell:hover::after { opacity: 1; transform: translateY(0); }

    /* Video cell — small yellow "playing" pulse */
    .gd-cell--video .gd-cell__pulse {
      position: absolute;
      top: 14px;
      right: 16px;
      width: 8px;
      height: 8px;
      background: #ffee00;
      border-radius: 50%;
      z-index: 3;
      animation: gdPulse 1.6s ease-in-out infinite;
      pointer-events: none;
    }
    @keyframes gdPulse {
      0%, 100% { opacity: 0.55; transform: scale(0.9); box-shadow: 0 0 0 0 rgba(255, 238, 0, 0.55); }
      50%      { opacity: 1;    transform: scale(1.1); box-shadow: 0 0 0 8px rgba(255, 238, 0, 0); }
    }

    /* Responsive collapse */
    @media (max-width: 900px) {
      .graphic-grid { grid-template-columns: 1fr; }
      .graphic-vrail { display: none; }
      .gd-row--3, .gd-row--4 { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 560px) {
      .gd-row--3, .gd-row--4, .gd-row--2 { grid-template-columns: 1fr; }
    }

    /* ============================================================
       Interlude — full-bleed editorial cut (video or still)
       ============================================================ */
    .interlude {
      position: relative;
      margin: clamp(28px, 4vw, 56px) 0;
      width: 100vw;
      margin-left: calc((100% - 100vw) / 2);
      max-width: 100vw;
      box-sizing: border-box;
      background: #14131a;
      overflow: hidden;
      display: block;
    }
    .interlude img,
    .interlude video {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
    }
    .interlude figcaption {
      position: absolute;
      right: clamp(20px, 3vw, 44px);
      bottom: clamp(16px, 2vw, 28px);
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 6px 12px;
      background: rgba(20, 19, 26, 0.55);
      color: #fff;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
    }
    .interlude__lbl { opacity: 0.9; }
    .interlude__ratio {
      color: #ffee00;
      letter-spacing: 0.22em;
      border-left: 1px solid rgba(255,255,255,0.28);
      padding-left: 12px;
    }
    /* Motion badge on video interludes */
    .interlude--video::before {
      content: "";
      position: absolute;
      top: clamp(16px, 2vw, 28px);
      left: clamp(20px, 3vw, 44px);
      width: 10px;
      height: 10px;
      background: #ffee00;
      border-radius: 50%;
      z-index: 2;
      animation: gdPulse 1.6s ease-in-out infinite;
    }
    @media (max-width: 600px) {
      .interlude figcaption { font-size: 0.58rem; padding: 4px 8px; }
      .interlude__ratio { padding-left: 8px; }
    }

    /* ============================================================
       ROSTER (character showcase)
       ============================================================ */
    .roster-body {
      display: grid;
      grid-template-columns: 100px minmax(0, 1fr);
      gap: 40px;
      position: relative;
    }
    .roster-rail {
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: center;
    }
    .portrait {
      display: block;
      width: 72px;
      height: 72px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid var(--misc-line, rgba(0,0,0,0.15));
      background: #fff;
      cursor: pointer;
      padding: 0;
      transition: border-color 180ms ease, transform 180ms ease;
    }
    .portrait img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
    .portrait:hover { transform: scale(1.05); }
    .portrait.is-active {
      border-color: var(--misc-accent, #5061b9);
      box-shadow: 0 0 0 4px rgba(80, 97, 185, 0.15);
    }
    .roster-all {
      margin-top: 16px;
      padding: 8px 12px;
      color: var(--misc-ink, #14131a);
      text-decoration: none;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
      border: 1px solid var(--misc-ink, #14131a);
      transition: background 140ms ease, color 140ms ease;
    }
    .roster-all:hover { background: var(--misc-ink, #14131a); color: #fff; }

    .roster-stage {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
      gap: 40px;
      align-items: start;
    }
    .roster-block {
      position: absolute;
      top: 4%;
      right: 30%;
      width: 55%;
      height: 92%;
      max-width: 620px;
      background: rgba(80, 97, 185, 0.06);
      z-index: 0;
    }
    .roster-letters {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(6rem, 18vw, 16rem);
      letter-spacing: -0.03em;
      color: rgba(80, 97, 185, 0.06);
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
      white-space: nowrap;
      text-transform: uppercase;
    }
    .roster-hero { position: relative; z-index: 2; }
    .roster-img {
      display: block;
      width: 100%;
      max-width: 520px;
      height: auto;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
    }
    .roster-card {
      position: relative;
      z-index: 2;
      padding: 28px 24px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
    }
    .roster-card__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 8px;
    }
    .roster-card__name {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(1.6rem, 2.5vw, 2rem);
      line-height: 1;
      color: var(--misc-ink, #14131a);
      margin: 0 0 16px;
      text-transform: lowercase;
    }
    .roster-card__rule {
      height: 1px;
      background: var(--misc-line, rgba(0,0,0,0.14));
      margin-bottom: 16px;
      position: relative;
    }
    .roster-card__rule::after {
      content: "";
      position: absolute;
      left: 0; top: 0;
      width: 48px;
      height: 2px;
      background: var(--misc-accent, #5061b9);
    }
    .roster-card__dl {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 8px 20px;
      margin: 0 0 16px;
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.9rem;
    }
    .roster-card__dl dt {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
      align-self: center;
    }
    .roster-card__dl dd { margin: 0; color: var(--misc-ink, #14131a); }
    .roster-card__desc {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.88rem;
      line-height: 1.55;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
    }
    @media (max-width: 900px) {
      .roster-body { grid-template-columns: 1fr; }
      .roster-rail { flex-direction: row; flex-wrap: wrap; }
      .roster-stage { grid-template-columns: 1fr; }
      .roster-block { display: none; }
      .roster-letters { font-size: 10rem; }
    }

    /* ============================================================
       CATALOG
       ============================================================ */
    .catalog-grid { grid-template-columns: repeat(4, 1fr) !important; gap: 5vh 3vw !important; }
    @media (max-width: 900px) { .catalog-grid { grid-template-columns: repeat(2, 1fr) !important; } }

    /* ============================================================
       THEMED ROOMS
       ============================================================ */
    .rooms {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .room {
      position: relative;
      display: block;
      min-height: 480px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      transition: transform 220ms ease, border-color 220ms ease;
    }
    .room:hover { transform: translateY(-4px); border-color: var(--misc-accent, #5061b9); }
    .room--psg { background: linear-gradient(150deg, #ffe0eb 0%, #fff4fa 60%, #d6f8ff 100%); }
    .room--nso { background: linear-gradient(150deg, #e0e6ff 0%, #f6f2ff 60%, #ffe0f4 100%); }
    .room__meta-top {
      position: absolute;
      top: 16px;
      left: 16px;
      right: 16px;
      z-index: 3;
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }
    .room__tag, .room__live {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 3px 8px;
      background: rgba(255, 255, 255, 0.85);
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      color: var(--misc-ink, #14131a);
    }
    .room__live { color: var(--misc-accent, #5061b9); }
    .room__chars { position: absolute; bottom: 0; left: 0; right: 0; height: 65%; pointer-events: none; z-index: 1; }
    .room__char {
      position: absolute;
      bottom: -8%;
      height: 110%;
      width: auto;
      max-width: 60%;
      object-fit: contain;
      object-position: bottom center;
      filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.12));
      transition: transform 320ms ease;
    }
    .room__char--l { left: -6%; }
    .room__char--r { right: -6%; }
    .room:hover .room__char--l { transform: translate(-3px, -6px) rotate(-1deg); }
    .room:hover .room__char--r { transform: translate(3px, -6px) rotate(1deg); }
    .room__title-wrap {
      position: relative;
      z-index: 2;
      padding: 56px 28px 0;
      text-align: center;
    }
    .room__eyebrow {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: lowercase;
      color: var(--misc-ink-soft, #6b6b6b);
      margin-bottom: 6px;
    }
    .room__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(3.4rem, 8vw, 6rem);
      line-height: 0.95;
      color: var(--misc-ink, #14131a);
      margin: 0 0 8px;
      text-transform: lowercase;
    }
    .room__sub {
      font-family: 'Beam Visionary', cursive;
      font-size: clamp(1rem, 1.6vw, 1.4rem);
      color: var(--misc-accent, #5061b9);
      margin: 0;
    }
    .room__foot {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      z-index: 3;
      padding: 16px 20px;
      background: linear-gradient(to top, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.4) 80%, transparent 100%);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .room__enter {
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      color: var(--misc-accent, #5061b9);
    }
    .room__specs {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--misc-ink-soft, #6b6b6b);
    }
    @media (max-width: 900px) { .rooms { grid-template-columns: 1fr; } }

    /* ============================================================
       PRODUCT PHOTOGRAPHY + PATHS
       ============================================================ */
    .prod-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 60px;
    }
    .prod {
      margin: 0;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      overflow: hidden;
      transition: transform 200ms ease, border-color 200ms ease;
      display: flex;
      flex-direction: column;
    }
    .prod:hover { transform: translateY(-3px); border-color: var(--misc-accent, #5061b9); }
    .prod__img {
      background: #f7f6f2;
      aspect-ratio: 4/5;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .prod__img img { max-width: 100%; max-height: 100%; object-fit: contain; }
    .prod figcaption {
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.10));
    }
    .prod__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
    }
    .prod__name {
      font-family: 'Apex Mk3', sans-serif;
      font-size: 1.05rem;
      color: var(--misc-ink, #14131a);
    }
    .prod__spec {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.78rem;
      color: var(--misc-ink-soft, #6b6b6b);
      line-height: 1.4;
    }
    .paths {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .path {
      display: block;
      padding: 24px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      text-decoration: none;
      color: inherit;
      transition: border-color 180ms ease, transform 180ms ease;
    }
    .path:hover { border-color: var(--misc-accent, #5061b9); transform: translateY(-2px); }
    .path__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 12px;
    }
    .path__title {
      font-family: 'Apex Mk3', sans-serif;
      font-size: 1.2rem;
      color: var(--misc-ink, #14131a);
      margin: 0 0 8px;
      font-weight: 400;
      text-transform: lowercase;
    }
    .path__desc {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.9rem;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
      line-height: 1.5;
    }
    @media (max-width: 900px) {
      .prod-grid { grid-template-columns: repeat(2, 1fr); }
      .paths { grid-template-columns: 1fr; }
    }

    /* =========================================================================
       ENHANCEMENTS — Illustration + Roster + Editorial Photography + Themes mini
       ========================================================================= */

    #roster {
      background:
        radial-gradient(circle at 8% 12%, rgba(80, 97, 185, 0.05) 0%, transparent 45%),
        radial-gradient(circle at 92% 88%, rgba(255, 129, 176, 0.045) 0%, transparent 50%),
        var(--misc-bg, #fdfcf9);
      position: relative;
      overflow: hidden;
    }
    /* Cinema editorial dark mode — graphic section only */
    #graphic {
      background:
        radial-gradient(circle at 8% 12%, rgba(80, 97, 185, 0.18) 0%, transparent 45%),
        radial-gradient(circle at 92% 88%, rgba(255, 129, 176, 0.08) 0%, transparent 50%),
        linear-gradient(180deg, #0d0c13 0%, #14131a 100%);
      color: #f5f4f0;
      position: relative;
      overflow: hidden;
    }
    /* Section corner vignette — soft radial darkening at the corners so
       the constellation reads as a lit stage. Sits above the base bg
       gradient but below the content stack. */
    #graphic::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background:
        radial-gradient(ellipse at 0% 0%,   rgba(0, 0, 0, 0.35) 0%, transparent 40%),
        radial-gradient(ellipse at 100% 0%, rgba(0, 0, 0, 0.35) 0%, transparent 40%),
        radial-gradient(ellipse at 0% 100%, rgba(0, 0, 0, 0.35) 0%, transparent 40%),
        radial-gradient(ellipse at 100% 100%, rgba(0, 0, 0, 0.35) 0%, transparent 40%);
    }
    #graphic > * { position: relative; z-index: 1; }
    #graphic .sec__num       { color: rgba(255, 255, 255, 0.55); }
    #graphic .sec__eyebrow   { color: #ffee00; }
    #graphic .sec__title     { color: #fff; }
    #graphic .sec__lede      { color: rgba(255, 255, 255, 0.72); }
    #graphic .sec-tabs       { border-bottom-color: rgba(255, 255, 255, 0.12); }
    #graphic .sec-tab        { color: rgba(255, 255, 255, 0.55); }
    #graphic .sec-tab:hover  { color: #fff; }
    #graphic .sec-tab.is-active { color: #fff; border-bottom-color: #ffee00; }
    #graphic .sec-foot       { border-top-color: rgba(255, 255, 255, 0.10); }
    #graphic .sec-foot__meta { color: rgba(255, 255, 255, 0.55); }
    #graphic .pager button   { border-color: rgba(255, 255, 255, 0.18); color: #fff; background: transparent; }
    #graphic .pager button:hover { background: #ffee00; border-color: #ffee00; color: #14131a; }
    #graphic .pager__nums    { color: #fff; }

    /* ---- Illustration ---- */
    #graphic .graphic-slot {
      min-height: 520px;
      background:
        radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.9) 0%, transparent 50%),
        repeating-linear-gradient(
          -45deg,
          rgba(80, 97, 185, 0.04) 0px,
          rgba(80, 97, 185, 0.04) 8px,
          transparent 8px,
          transparent 22px
        ),
        #fff;
      border: 1px dashed rgba(80, 97, 185, 0.35);
      position: relative;
    }
    #graphic .graphic-slot::before {
      content: "";
      position: absolute;
      inset: 12px;
      border: 1px solid rgba(80, 97, 185, 0.1);
      pointer-events: none;
    }
    #graphic .graphic-slot__icon { font-size: 3rem; opacity: 0.55; }
    #graphic .graphic-slot__label {
      font-size: 0.78rem;
      color: var(--misc-accent);
      font-weight: 600;
      letter-spacing: 0.24em;
    }
    #graphic .graphic-stage { position: relative; }
    /* (Left graphic-rail removed) */

    /* ---- Roster — viewport-presence character showcase ---- */
    #roster {
      padding-top: clamp(60px, 8vh, 120px);
      padding-bottom: clamp(60px, 8vh, 120px);
    }
    #roster .roster-body {
      min-height: calc(100vh - clamp(140px, 16vh, 220px));
      min-height: calc(100svh - clamp(140px, 16vh, 220px));
      align-items: stretch;
    }
    /* Single-column stage — character owns the full width, info card
       floats in as an editorial overlay in the top-right corner. */
    #roster .roster-stage {
      grid-template-columns: 1fr;
      gap: 0;
      align-items: stretch;
      position: relative;
    }
    #roster .roster-hero,
    #roster .roster-block,
    #roster .roster-letters {
      grid-column: 1 / -1;
    }
    #roster .roster-card {
      position: absolute;
      top: 24px;
      right: 24px;
      width: min(400px, 34vw);
      z-index: 4;
    }
    #roster .roster-block {
      top: 0%;
      right: 10%;
      width: 80%;
      height: 100%;
      max-width: none;
      background:
        radial-gradient(circle at 30% 30%, rgba(255, 129, 176, 0.05) 0%, transparent 60%),
        rgba(80, 97, 185, 0.06);
    }
    #roster .roster-letters {
      font-size: clamp(9rem, 26vw, 24rem);
      color: rgba(80, 97, 185, 0.07);
    }
    #roster .roster-img {
      max-width: 100%;
      max-height: 88vh;
      max-height: 88svh;
      width: auto;
      height: auto;
      padding: 0;
      background: transparent;
      border: none;
      box-shadow: none;
      filter: drop-shadow(0 34px 50px rgba(20, 19, 26, 0.24))
              drop-shadow(0 10px 20px rgba(20, 19, 26, 0.14));
      object-fit: contain;
      display: block;
      margin: 0 auto;
      transition: filter 220ms ease, transform 320ms cubic-bezier(0.34, 1.20, 0.64, 1);
    }
    #roster .roster-img:hover {
      transform: translateY(-4px);
      filter: drop-shadow(0 44px 60px rgba(20, 19, 26, 0.30))
              drop-shadow(0 14px 24px rgba(20, 19, 26, 0.16));
    }
    #roster .roster-hero {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: flex-end;
      min-height: 88vh;
      min-height: 88svh;
      height: 100%;
    }
    @media (max-width: 900px) {
      #roster .roster-body { min-height: 0; }
      #roster .roster-hero { min-height: 620px; }
      #roster .roster-img { max-width: 100%; max-height: 70vh; max-height: 70svh; }
      /* Collapse info-card overlay back to normal flow below the character */
      #roster .roster-card {
        position: static;
        width: auto;
        margin-top: 24px;
      }
    }
    #roster .roster-card {
      padding: 32px 28px;
      background: linear-gradient(180deg, #fff 0%, #faf9f5 100%);
      border: 1px solid var(--misc-line);
      box-shadow: 0 20px 40px -20px rgba(20, 19, 26, 0.10);
      position: relative;
    }
    #roster .roster-card::before {
      content: "profile";
      position: absolute;
      top: -12px;
      right: 20px;
      background: var(--misc-accent);
      color: #fff;
      padding: 3px 10px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    #roster .roster-card__dl {
      grid-template-columns: auto 1fr;
      gap: 10px 16px;
      align-items: center;
    }
    #roster .roster-card__dl dt {
      background: rgba(80, 97, 185, 0.10);
      color: var(--misc-accent);
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 0.6rem;
      justify-self: start;
      font-weight: 600;
    }

    /* ============================================================
       Theme picks in #graphic sec__head — minimalist squares that
       shove the eyebrow/title/lede to the left and dock the two
       themed-storefront entry points on the right.
       ============================================================ */
    #graphic .sec__head--with-themes {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
      gap: clamp(24px, 4vw, 72px);
      max-width: none;
    }
    #graphic .sec__head-text { max-width: 820px; }
    .theme-picks {
      display: flex;
      align-items: flex-end;
      gap: clamp(10px, 1vw, 16px);
      padding-bottom: 4px;
    }
    .theme-picks__label {
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.28em;
      text-transform: lowercase;
      color: rgba(255, 255, 255, 0.55);
      align-self: stretch;
      padding: 4px 0;
    }
    /* Storefront tiles use the exact .misc__theme-square markup + CSS
       from the Shopify theme (theme.css is already imported globally
       via Base.astro). Only local job here is to size the switch nav
       so the tiles fit into the sec__head right column. */
    .theme-picks .misc__theme-switch {
      display: flex;
      align-items: flex-end;
      gap: clamp(10px, 1vw, 16px);
    }
    .theme-picks .misc__theme-square {
      /* Overrides theme.css min-height 180 / max-height 320 so the two
         tiles fit alongside the section title without hijacking the row */
      height: clamp(96px, 9vw, 132px);
      min-height: 0;
      max-height: none;
      width: auto;   /* aspect-ratio 1.8/1 from theme.css computes width */
      flex: 0 0 auto;
    }
    @media (max-width: 700px) {
      #graphic .sec__head--with-themes { grid-template-columns: 1fr; }
      .theme-picks { justify-content: flex-start; }
      .theme-picks__label { writing-mode: horizontal-tb; transform: none; }
    }

    /* ---- Compact theme selector at bottom of roster (retired — kept for compat) ---- */
    .theme-mini {
      margin-top: clamp(56px, 7vw, 96px);
      padding-top: clamp(40px, 4.5vw, 56px);
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      display: grid;
      grid-template-columns: minmax(260px, 340px) 1fr;
      gap: clamp(24px, 4vw, 64px);
      align-items: center;
    }
    .theme-mini__eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent);
      margin: 0 0 10px;
    }
    .theme-mini__lede {
      font-family: 'Branding Pro', sans-serif;
      font-size: 1rem;
      line-height: 1.5;
      color: var(--misc-ink-soft);
      margin: 0;
    }
    .theme-mini__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      max-width: 760px;
      justify-self: end;
    }
    .theme-sq {
      position: relative;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      aspect-ratio: 1.4 / 1;
      background: #fff;
      border: 1px solid var(--misc-line);
      overflow: hidden;
      text-decoration: none;
      transition: transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
      box-shadow: 0 8px 22px -12px rgba(20, 19, 26, 0.10);
