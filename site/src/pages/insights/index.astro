---
export const prerender = true;
import Gryphline from "../../layouts/Gryphline.astro";
---
<Gryphline title="insights">
  <section class="gl-shell">
    <p class="gl-kicker">traffic · last 7 days · athena over cloudfront logs</p>
    <h1 class="gl-h1">insights<em>.</em></h1>
    <p class="gl-lede">
      Live from <strong>Amazon Athena</strong> over CloudFront access logs (parsed via a Glue
      Data Catalog table). Published nightly by the digest Lambda. Query cost: fractions
      of a cent, capped at <code>1 GB scanned</code> via workgroup config.
    </p>

    <h2 class="gl-h2">top pages</h2>
    <table class="gl-tbl">
      <thead>
        <tr><th>URI</th><th class="gl-tbl__num">hits</th></tr>
      </thead>
      <tbody id="i-body"><tr><td colspan="2">loading&hellip;</td></tr></tbody>
    </table>

    <p class="gl-kicker" id="i-generated" style="margin-top: 32px;">loading&hellip;</p>
  </section>

  <script is:inline>
    fetch("/insights.json", { cache: "no-cache" }).then(r => r.json()).then(d => {
      document.getElementById("i-generated").textContent = "// digest generated " + new Date(d.generatedAt).toLocaleString();
      const body = document.getElementById("i-body");
      body.innerHTML = "";
      if (d.warning) {
        body.innerHTML = "<tr><td colspan='2'>" + d.warning + "</td></tr>";
        return;
      }
      const rows = d.topPages || [];
      if (!rows.length) {
        body.innerHTML = "<tr><td colspan='2'>no data yet — CloudFront logs roll in every hour</td></tr>";
        return;
      }
      rows.forEach(r => {
        const tr = document.createElement("tr");
        tr.innerHTML = `<td><code>${r.uri}</code></td><td class='gl-tbl__num'>${r.hits}</td>`;
        body.appendChild(tr);
      });
    }).catch(() => {
      document.getElementById("i-generated").textContent = "// digest not available yet";
    });
  </script>
</Gryphline>
