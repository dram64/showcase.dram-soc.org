---
const year = 2026;
---
<footer class="tz-footer" role="contentinfo">
  <div class="tz-footer__inner">
    <div class="tz-footer__col tz-footer__col--brand">
      <p class="tz-footer__eyebrow">
        <a class="tz-footer__eyebrow-line" href="/">TOKYO ZERO</a>
        <span class="tz-footer__eyebrow-line">Chromadipity Core</span>
      </p>
    </div>

    <nav class="tz-footer__col tz-footer__col--nav" aria-label="Footer">
      <p class="tz-footer__col-label">explore</p>
      <ul class="tz-footer__list">
        <li><a href="/">catalog</a></li>
        <li><a href="/process/">process</a></li>
        <li><a href="/architecture/">architecture</a></li>
        <li><a href="/status/">status</a></li>
        <li><a href="/insights/">insights</a></li>
        <li><a href="/contact/">contact</a></li>
      </ul>
    </nav>

    <div class="tz-footer__col tz-footer__col--social">
      <p class="tz-footer__col-label">follow</p>
      <a class="tz-footer__ig" href="https://www.instagram.com/tokyozeroofficial/" target="_blank" rel="noopener" aria-label="Tokyo Zero on Instagram">
        <svg class="tz-footer__ig-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="2.5" y="2.5" width="19" height="19" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="12" cy="12" r="4.2" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="17.6" cy="6.4" r="1.15" fill="currentColor"/>
        </svg>
        <span class="tz-footer__ig-handle">@tokyozeroofficial</span>
      </a>
      <a class="tz-footer__email" href="mailto:desiramirez62200@gmail.com">desiramirez62200@gmail.com</a>
    </div>
  </div>

  <div class="tz-footer__bar">
    <span class="tz-footer__copy">© {year} Tokyo Zero — all rights reserved.</span>
    <span class="tz-footer__signoff">chromadipity core.</span>
  </div>
</footer>
