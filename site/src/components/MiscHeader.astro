---
interface Props {
  title?: string;
  brand?: string;
  subBrand?: string;
  showAnnouncement?: boolean;
}
const {
  title = "misc",
  brand = "TOKYO ZERO",
  subBrand = "Chromadipity Core",
  showAnnouncement = true,
} = Astro.props;
---
<header class="misc__header-wrap" role="banner">
  <div class="misc__header">
    <div class="misc__header-left">
      <p class="misc__eyebrow">
        <a class="misc__eyebrow-line" href="/">{brand}</a>
        <span class="misc__eyebrow-line">{subBrand}</span>
      </p>
      <h1 class="misc__title">{title}.</h1>
    </div>
    <div class="misc__theme-block">
      <p class="misc__theme-heading">
        <span class="misc__theme-heading-eyebrow">experimental</span>
        <span class="misc__theme-heading-title">theme selector</span>
      </p>
      <nav class="misc__theme-switch" aria-label="Theme">
        <a class="misc__theme-square misc__theme-square--psg" href="/work/psg/" aria-label="PSG theme">
          <img class="misc__theme-square-char misc__theme-square-char--panty"    src="/assets/psg-panty-sticker.webp"    alt="" aria-hidden="true" />
          <img class="misc__theme-square-char misc__theme-square-char--stocking" src="/assets/psg-stocking-sticker.webp" alt="" aria-hidden="true" />
          <span class="misc__theme-square-label">psg</span>
        </a>
        <a class="misc__theme-square misc__theme-square--nso" href="/work/nso/" aria-label="NSO theme">
          <img class="misc__theme-square-char misc__theme-square-char--ame"    src="/assets/nso-ame-sticker.webp"    alt="" aria-hidden="true" />
          <img class="misc__theme-square-char misc__theme-square-char--kangel" src="/assets/nso-kangel-sticker.webp" alt="" aria-hidden="true" />
          <span class="misc__theme-square-label">nso</span>
        </a>
      </nav>
    </div>
  </div>

  {showAnnouncement && (
    <div class="misc__announcement" role="note" aria-label="Portfolio note">
      <span class="misc__announcement-item">
        <strong>portfolio showcase</strong> — running on aws serverless. see the
        <a href="/architecture/">stack</a> ·
        <a href="/status/">status</a> · <a href="/insights/">insights</a>
      </span>
      <span class="misc__announcement-item">
        design case study at <a href="/process/">/process</a>
      </span>
    </div>
  )}
</header>

<style is:global>
  .misc__announcement a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .misc__announcement a:hover { opacity: 0.75; }
</style>
