---
export const prerender = true;
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";
import { products } from "../data/products.ts";

const featured = [
  "deskmat-yuzuha-alice",
  "tapestry-astra-yao",
  "print-yuzuha",
  "sticker-blanc-bunny",
  "deskmat-toki-bunny",
  "tapestry-citlali",
  "print-castorice",
  "sticker-alice",
].map(slug => products.find(p => p.slug === slug)).filter(Boolean);

const roster = [
  { key: "kafka",     img: "/portfolio/kafka.webp",     name: "Kafka",             faction: "Stellaron Hunters",           universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "topaz",     img: "/portfolio/topaz.webp",     name: "Topaz",             faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "psg",       img: "/portfolio/psg.webp",       name: "Panty & Stocking",  faction: "Daten City Church",           universe: "Panty & Stocking",  tag: "PSG" },
  { key: "ayaka",     img: "/portfolio/ayaka.webp",     name: "Kamisato Ayaka",    faction: "Kamisato Clan",               universe: "Genshin Impact",     tag: "GI" },
  { key: "jane",      img: "/portfolio/jane.webp",      name: "Jane Doe",          faction: "Tokyo Zero Original",         universe: "Chromadipity Core",  tag: "OC" },
  { key: "ironmouse", img: "/portfolio/ironmouse.webp", name: "Ironmouse",         faction: "VShojo",                      universe: "Vtuber",             tag: "VT" },
];
---
<Base title="portfolio" pageClass="page-index" showHeader={false} showFooter={true}>

  <!-- ================================================================
       SECTION TRACKER — fixed right rail, misc-styled
       ================================================================ -->
  <nav class="tracker" aria-label="Section navigation">
    <a class="tracker__item is-active" data-section="hero" href="#hero">
      <span class="tracker__bar"></span><span class="tracker__num">01</span><span class="tracker__lbl">hero</span>
    </a>
    <a class="tracker__item" data-section="graphic" href="#graphic">
      <span class="tracker__bar"></span><span class="tracker__num">02</span><span class="tracker__lbl">graphic</span>
    </a>
    <a class="tracker__item" data-section="roster" href="#roster">
      <span class="tracker__bar"></span><span class="tracker__num">03</span><span class="tracker__lbl">roster</span>
    </a>
    <a class="tracker__item" data-section="catalog" href="#catalog">
      <span class="tracker__bar"></span><span class="tracker__num">04</span><span class="tracker__lbl">catalog</span>
    </a>
    <a class="tracker__item" data-section="photo" href="#photo">
      <span class="tracker__bar"></span><span class="tracker__num">05</span><span class="tracker__lbl">photo</span>
    </a>
  </nav>

  <!-- ================================================================
       01 · HERO — auto-crossfade carousel between NSO + Yuzuha/Alice
       ================================================================ -->
  <section id="hero" class="hero" aria-label="hero">
    <img class="hero__art is-active" src="/hero/nso-hero.webp"          alt="NSO — Ame &amp; KAngel key art" data-slide="0" />
    <img class="hero__art"           src="/hero/yuzuha-alice-hero.webp" alt="Yuzuha &amp; Alice key art"     data-slide="1" />

    <div class="hero__dots" role="tablist" aria-label="Hero carousel">
      <button class="hero__dot is-active" data-goto="0" aria-label="Slide 1"></button>
      <button class="hero__dot"           data-goto="1" aria-label="Slide 2"></button>
    </div>
  </section>

  <!-- ================================================================
       POST-HERO STRIP — soft info bar
       ================================================================ -->
  <div class="hero-strip" aria-hidden="true">
    <span><em>design</em> apex mk3 &middot; beam visionary &middot; branding pro</span>
    <span><em>cloud</em> s3 &middot; cloudfront &middot; lambda &middot; athena &middot; terraform</span>
    <span><em>spend</em> ~$2/mo &mdash; <a href="/status/">/status</a> &middot; <a href="/cost/">/cost</a></span>
  </div>

  <!-- ================================================================
       BOUNDARY DIVIDER — last full-bleed element
       ================================================================ -->
  <div class="section-divider section-divider--boundary">
    <span class="section-divider__num">01</span>
    <span class="section-divider__label">graphic interfaces &middot; drop 01</span>
    <span class="section-divider__mark"></span>
  </div>

  <!-- ================================================================
       02 · GRAPHIC DESIGN
       ================================================================ -->
  <section id="graphic" class="sec">
    <div class="sec__head">
      <p class="sec__num">02 / 05</p>
      <p class="sec__eyebrow">graphic design</p>
      <h2 class="sec__title">the illustration.</h2>
      <p class="sec__lede">
        Character studies, key art, print-ready compositions. A featured piece
        rotates in this frame &mdash; each one is the source for something
        in the catalog.
      </p>
    </div>

    <div class="sec-tabs">
      <a class="sec-tab is-active">chromadipity</a>
      <a class="sec-tab">psg</a>
      <a class="sec-tab">nso</a>
      <a class="sec-tab">genshin &middot; hsr</a>
      <a class="sec-tab">vtuber</a>
    </div>

    <div class="graphic-grid">
      <aside class="graphic-rail">
        <span class="graphic-chip"></span>
        <div class="graphic-meta">
          <p><em>theme</em>&mdash; chromadipity core</p>
          <p><em>creator</em>&mdash; dram</p>
          <p><em>format</em>&mdash; digital painting</p>
          <p><em>size</em>&mdash; 2400 &times; 1600</p>
          <p><em>roster</em>&mdash; 40+ pcs</p>
          <p><em>index</em>&mdash; 01 of 12</p>
        </div>
        <p class="graphic-signature">from the desk.</p>
      </aside>

      <div class="graphic-stage">
        <div class="graphic-slot">
          <span class="graphic-slot__label">slot 01 &middot; featured illustration</span>
          <span class="graphic-slot__icon">◇</span>
          <span class="graphic-slot__dim">2400 &times; 1600 &middot; drop the graphic here</span>
        </div>
        <p class="graphic-caption">&mdash; swap freely; portrait &amp; landscape both fit.</p>
      </div>

      <aside class="graphic-vrail">
        <span>chromadipity core &middot; drop 01</span>
      </aside>
    </div>

    <div class="sec-foot">
      <div class="pager">
        <button aria-label="previous">&larr;</button>
        <span class="pager__nums">01 / 12</span>
        <button aria-label="next">&rarr;</button>
      </div>
      <p class="sec-foot__meta">graphic 02 &middot; system interfaces</p>
    </div>
  </section>

  <!-- ================================================================
       03 · CHARACTER ROSTER
       ================================================================ -->
  <section id="roster" class="sec">
    <div class="sec__head">
      <p class="sec__num">03 / 05</p>
      <p class="sec__eyebrow">the roster</p>
      <h2 class="sec__title">character work.</h2>
      <p class="sec__lede">
        Portrait, key art, chibi variant, full-body pose &mdash; each character
        in the roster serves at least one product category.
      </p>
    </div>

    <div class="roster-body">
      <aside class="roster-rail">
        {roster.map((r, i) => (
          <button class:list={["portrait", i === 0 && "is-active"]} data-key={r.key} aria-label={r.name}>
            <img src={r.img} alt={r.name} />
          </button>
        ))}
        <a class="roster-all" href="/catalog/">all &rarr;</a>
      </aside>

      <div class="roster-stage">
        <div class="roster-block" aria-hidden="true"></div>
        <div class="roster-letters" data-target="letters" aria-hidden="true">KAFKA</div>

        <div class="roster-hero">
          <img class="roster-img" src="/portfolio/kafka.webp" alt="Kafka" data-target="img" />
        </div>

        <div class="roster-card">
          <p class="roster-card__num" data-target="num">01 / 06</p>
          <h3 class="roster-card__name" data-target="name">Kafka</h3>
          <div class="roster-card__rule"></div>
          <dl class="roster-card__dl">
            <dt>faction</dt><dd data-target="faction">Stellaron Hunters</dd>
            <dt>universe</dt><dd data-target="universe">Honkai: Star Rail</dd>
            <dt>tag</dt><dd data-target="tag">HSR</dd>
          </dl>
          <p class="roster-card__desc">
            Hand-illustrated character work &mdash; portraits, key art, chibi
            variants, and full-body poses. Each character in the roster serves
            a specific product category: deskmats, tapestries, prints, or
            acrylic stands.
          </p>
        </div>
      </div>
    </div>

    <!-- Compact theme selector — small aside inside the roster -->
    <div class="theme-mini">
      <div class="theme-mini__head">
        <p class="theme-mini__eyebrow">experimental &middot; themed rooms</p>
        <p class="theme-mini__lede">two alternate storefronts &mdash; each takes over the full page.</p>
      </div>
      <div class="theme-mini__grid">
        <a class="theme-sq theme-sq--psg" href="/work/psg/" aria-label="Enter PSG storefront">
          <img class="theme-sq__char theme-sq__char--l" src="/assets/psg-panty-sticker.webp"    alt="" aria-hidden="true" />
          <img class="theme-sq__char theme-sq__char--r" src="/assets/psg-stocking-sticker.webp" alt="" aria-hidden="true" />
          <span class="theme-sq__label">psg</span>
        </a>
        <a class="theme-sq theme-sq--nso" href="/work/nso/" aria-label="Enter NSO storefront">
          <img class="theme-sq__char theme-sq__char--l" src="/assets/nso-ame-sticker.webp"    alt="" aria-hidden="true" />
          <img class="theme-sq__char theme-sq__char--r" src="/assets/nso-kangel-sticker.webp" alt="" aria-hidden="true" />
          <span class="theme-sq__label">nso</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ================================================================
       04 · CATALOG — misc__card grid, shopify-native
       ================================================================ -->
  <section id="catalog" class="sec">
    <div class="sec__head">
      <p class="sec__num">04 / 05</p>
      <p class="sec__eyebrow">from the catalog</p>
      <h2 class="sec__title">the drops.</h2>
      <p class="sec__lede">
        A curated eight from the 30-piece drop &mdash; deskmats, tapestries,
        prints, stickers. Each carries a character. Full catalog on shopify.
      </p>
    </div>

    <div class="misc__grid catalog-grid">
      {featured.map((p, i) => (
        <ProductCard product={p} index={String(i + 1).padStart(2, "0")} category={p.category} />
      ))}
    </div>

    <div class="sec-foot">
      <a class="btn btn--primary" href="https://ac41ps-i0.myshopify.com" target="_blank" rel="noopener">shop the full catalog &rarr;</a>
    </div>
  </section>

  <!-- ================================================================
       05 · PRODUCT PHOTOGRAPHY — 3D coverflow carousel + editorial sidebar
       ================================================================ -->
  <section id="photo" class="sec">
    <!-- viewport-fit wrapper: header + carousel take one screen height -->
    <div class="photo-viewport">
      <div class="sec__head">
        <p class="sec__num">05 / 05</p>
        <p class="sec__eyebrow">product photography</p>
        <h2 class="sec__title">finished pieces.</h2>
        <p class="sec__lede">
          Illustration &rarr; production &rarr; photography. Four physical
          drops from the roster.
        </p>
      </div>

      <div class="photo-editorial">
        <!-- 3D coverflow carousel — auto-rotates through 4 products -->
        <div class="lead-3d" aria-label="Product photography carousel">
          <div class="lead-3d__stage">
            <button class="lead-3d__card" data-i="0" aria-label="Kafka Acrylic Stand">
              <div class="lead-3d__card-inner">
                <img src="/portfolio/prod-kafka-acrylic.webp" alt="Kafka Acrylic Stand" loading="lazy" />
                <span class="lead-3d__card-tag">01</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="1" aria-label="Topaz Acrylic Stand">
              <div class="lead-3d__card-inner">
                <img src="/portfolio/prod-topaz-acrylic.webp" alt="Topaz Acrylic Stand" loading="lazy" />
                <span class="lead-3d__card-tag">02</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="2" aria-label="Faruzan Deskmat">
              <div class="lead-3d__card-inner">
                <img src="/portfolio/prod-faruzan.webp" alt="Faruzan Deskmat" loading="lazy" />
                <span class="lead-3d__card-tag">03</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="3" aria-label="Cinna Miku Print">
              <div class="lead-3d__card-inner">
                <img src="/portfolio/prod-miku.webp" alt="Cinna Miku Print" loading="lazy" />
                <span class="lead-3d__card-tag">04</span>
              </div>
            </button>
          </div>

          <div class="lead-3d__ctrl">
            <button class="lead-3d__arrow" data-nav="prev" aria-label="Previous">&larr;</button>
            <div class="lead-3d__dots">
              <button class="is-active" data-goto="0" aria-label="Kafka"></button>
              <button                   data-goto="1" aria-label="Topaz"></button>
              <button                   data-goto="2" aria-label="Faruzan"></button>
              <button                   data-goto="3" aria-label="Miku"></button>
            </div>
            <button class="lead-3d__arrow" data-nav="next" aria-label="Next">&rarr;</button>
          </div>
        </div>

        <!-- Editorial sidebar — dynamic caption for the active card -->
        <aside class="photo-side">
          <p class="photo-side__label">// featured</p>
          <h3 class="photo-side__title">the drop.</h3>

          <div class="photo-side__cap" data-target="side-cap">
            <p class="photo-side__idx" data-target="side-idx">01</p>
            <p class="photo-side__cap-label" data-target="side-label">acrylic stand</p>
            <h4 class="photo-side__cap-name">
              <span data-target="side-name">Kafka</span><span class="photo-side__dot">.</span>
            </h4>
            <div class="photo-side__specs" data-target="side-specs">
              <span><em>size</em>5.6 &times; 7.4 in</span>
              <span><em>material</em>clear acrylic</span>
              <span><em>print</em>screen &middot; 4-color</span>
            </div>
          </div>

          <div class="photo-side__quote">
            <p>&ldquo;the character comes first &mdash; the product is the vessel.&rdquo;</p>
            <span class="photo-side__by">&mdash; from the desk.</span>
          </div>
        </aside>
      </div>
    </div>

    <!-- Three-up strip below (outside the viewport-fit) -->
    <div class="photo-strip">
      <figure class="photo-thumb">
        <span class="photo-thumb__num">02</span>
        <div class="photo-thumb__img">
          <img src="/portfolio/prod-topaz-acrylic.webp" alt="Topaz Acrylic Stand" loading="lazy" />
        </div>
        <figcaption>
          <span class="photo-thumb__label">acrylic stand</span>
          <span class="photo-thumb__name">Topaz</span>
          <span class="photo-thumb__spec">5.6 &times; 7.4 in &middot; clear acrylic</span>
        </figcaption>
      </figure>
      <figure class="photo-thumb">
        <span class="photo-thumb__num">03</span>
        <div class="photo-thumb__img">
          <img src="/portfolio/prod-faruzan.webp" alt="Faruzan Deskmat" loading="lazy" />
        </div>
        <figcaption>
          <span class="photo-thumb__label">deskmat</span>
          <span class="photo-thumb__name">Faruzan</span>
          <span class="photo-thumb__spec">900 &times; 400 mm &middot; sublimated</span>
        </figcaption>
      </figure>
      <figure class="photo-thumb">
        <span class="photo-thumb__num">04</span>
        <div class="photo-thumb__img">
          <img src="/portfolio/prod-miku.webp" alt="Cinna Miku Print" loading="lazy" />
        </div>
        <figcaption>
          <span class="photo-thumb__label">print</span>
          <span class="photo-thumb__name">Cinna Miku</span>
          <span class="photo-thumb__spec">12 &times; 18 in &middot; satin card stock</span>
        </figcaption>
      </figure>
    </div>

    <div class="paths">
      <a class="path" href="/work/">
        <p class="path__num">&mdash; 01</p>
        <h3 class="path__title">the three themes</h3>
        <p class="path__desc">psg &middot; nso &middot; misc &mdash; each with a distinct system.</p>
      </a>
      <a class="path" href="/process/">
        <p class="path__num">&mdash; 02</p>
        <h3 class="path__title">design case study</h3>
        <p class="path__desc">voice, typography, color, three-theme system.</p>
      </a>
      <a class="path" href="/architecture/">
        <p class="path__num">&mdash; 03</p>
        <h3 class="path__title">the aws stack</h3>
        <p class="path__desc">serverless breakdown &mdash; 12 services, ~$2/mo.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const roster = {
      kafka:     { name: "Kafka",             letters: "KAFKA", faction: "Stellaron Hunters",           universe: "Honkai: Star Rail", tag: "HSR", img: "/portfolio/kafka.webp",     num: "01" },
      topaz:     { name: "Topaz",             letters: "TOPAZ", faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR", img: "/portfolio/topaz.webp",     num: "02" },
      psg:       { name: "Panty & Stocking",  letters: "PSG",   faction: "Daten City Church",           universe: "Panty & Stocking",  tag: "PSG", img: "/portfolio/psg.webp",       num: "03" },
      ayaka:     { name: "Kamisato Ayaka",    letters: "AYAKA", faction: "Kamisato Clan",               universe: "Genshin Impact",     tag: "GI",  img: "/portfolio/ayaka.webp",     num: "04" },
      jane:      { name: "Jane Doe",          letters: "JANE",  faction: "Tokyo Zero Original",         universe: "Chromadipity Core",  tag: "OC",  img: "/portfolio/jane.webp",      num: "05" },
      ironmouse: { name: "Ironmouse",         letters: "MOUSE", faction: "VShojo",                      universe: "Vtuber",             tag: "VT",  img: "/portfolio/ironmouse.webp", num: "06" },
    };
    document.querySelectorAll(".portrait[data-key]").forEach(btn => {
      btn.addEventListener("click", () => {
        const r = roster[btn.dataset.key];
        if (!r) return;
        document.querySelectorAll(".portrait").forEach(b => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        const set = (t, v) => { const el = document.querySelector(`[data-target="${t}"]`); if (el) el.textContent = v; };
        set("name", r.name); set("letters", r.letters); set("faction", r.faction); set("universe", r.universe); set("tag", r.tag);
        set("num", r.num + " / 06");  // roster carousel counter (kept — 6 characters)
        const img = document.querySelector('[data-target="img"]'); if (img) img.src = r.img;
      });
    });

    // Tracker — IntersectionObserver highlights the active section + smooth-scroll on click
    const trackerItems = document.querySelectorAll(".tracker__item[data-section]");
    const sectionIds = ["hero", "graphic", "roster", "catalog", "photo"];
    const setActive = (id) => trackerItems.forEach(el => el.classList.toggle("is-active", el.dataset.section === id));
    const io = new IntersectionObserver((entries) => {
      let best = null;
      entries.forEach(e => { if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) best = e; });
      if (best) setActive(best.target.id);
    }, { rootMargin: "-25% 0px -50% 0px", threshold: [0, 0.2, 0.5, 0.8, 1] });
    sectionIds.forEach(id => { const el = document.getElementById(id); if (el) io.observe(el); });
    trackerItems.forEach(item => {
      item.addEventListener("click", (e) => {
        e.preventDefault();
        const target = document.getElementById(item.dataset.section);
        if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    // Rail dark/light transition — dark while hero is in view (matches the
    // hero backdrop), fades to light misc palette once scrolled past.
    (function () {
      const html = document.documentElement;
      const heroEl = document.getElementById("hero");
      if (!heroEl) return;
      html.setAttribute("data-rail", "dark");
      const railObs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          html.setAttribute("data-rail", e.isIntersecting && e.intersectionRatio > 0.2 ? "dark" : "light");
        });
      }, { threshold: [0, 0.2, 0.5, 0.8, 1] });
      railObs.observe(heroEl);
    })();

    // 3D coverflow carousel for the featured product photography section.
    // Auto-advances every 4.5s; click any card, dot, or arrow to control.
    // Center card is bright + forward; side cards angle back at ~35deg with
    // reduced opacity for depth.
    (function () {
      const stage = document.querySelector(".lead-3d__stage");
      if (!stage) return;
      const cards = Array.from(stage.querySelectorAll(".lead-3d__card"));
      const dots  = Array.from(document.querySelectorAll(".lead-3d__dots button[data-goto]"));
      const nav = {
        prev: document.querySelector('.lead-3d__arrow[data-nav="prev"]'),
        next: document.querySelector('.lead-3d__arrow[data-nav="next"]'),
      };
      const products = [
        { name: "Kafka",       label: "acrylic stand", idx: "01",
          specs: [["size","5.6 × 7.4 in"], ["material","clear acrylic"], ["print","screen · 4-color"]] },
        { name: "Topaz",       label: "acrylic stand", idx: "02",
          specs: [["size","5.6 × 7.4 in"], ["material","clear acrylic"], ["print","screen · 4-color"]] },
        { name: "Faruzan",     label: "deskmat",       idx: "03",
          specs: [["size","900 × 400 mm"], ["material","sublimated rubber base"], ["print","300 dpi"]] },
        { name: "Cinna Miku",  label: "print",         idx: "04",
          specs: [["size","12 × 18 in"], ["material","satin card stock"], ["print","4-color"]] },
      ];
      const N = cards.length;
      let current = 0;
      let timer = null;
      const INTERVAL = 4500;

      const paint = () => {
        cards.forEach((card, i) => {
          let diff = i - current;
          if (diff >  N / 2) diff -= N;
          if (diff < -N / 2) diff += N;
          const abs = Math.abs(diff);
          const isCenter = diff === 0;
          const x   = diff * 60;                    // horizontal spread
          const z   = isCenter ? 0 : -180 - abs * 60;
          const rot = -diff * 32;                    // rotate around Y
          const scale = isCenter ? 1 : 0.85 - (abs - 1) * 0.05;
          card.style.transform =
            `translate(-50%, -50%) translateX(${x}%) translateZ(${z}px) rotateY(${rot}deg) scale(${scale})`;
          card.style.zIndex   = String(20 - abs);
          card.style.opacity  = String(abs > 2 ? 0 : abs > 1 ? 0.25 : abs > 0 ? 0.55 : 1);
          card.classList.toggle("is-center", isCenter);
          card.tabIndex = isCenter ? 0 : -1;
        });
        dots.forEach((d, i) => d.classList.toggle("is-active", i === current));
        const p = products[current] || {};
        const setEl = (t, v) => { const el = document.querySelector(`[data-target="${t}"]`); if (el) el.textContent = v; };
        setEl("side-idx",   p.idx);
        setEl("side-label", p.label);
        setEl("side-name",  p.name);
        const specsEl = document.querySelector('[data-target="side-specs"]');
        if (specsEl && p.specs) {
          specsEl.innerHTML = p.specs.map(([k, v]) => `<span><em>${k}</em>${v}</span>`).join("");
        }
      };

      const advance = () => { current = (current + 1) % N; paint(); };
      const back    = () => { current = (current - 1 + N) % N; paint(); };
      const start   = () => { stop(); timer = setInterval(advance, INTERVAL); };
      const stop    = () => { if (timer) { clearInterval(timer); timer = null; } };

      cards.forEach((card, i) => card.addEventListener("click", () => { current = i; paint(); start(); }));
      dots.forEach((dot, i) => dot.addEventListener("click", () => { current = i; paint(); start(); }));
      if (nav.prev) nav.prev.addEventListener("click", () => { back();    start(); });
      if (nav.next) nav.next.addEventListener("click", () => { advance(); start(); });

      document.addEventListener("visibilitychange", () => { if (document.hidden) stop(); else start(); });

      paint();
      start();
    })();

    // Hero carousel — auto-crossfade between NSO and Yuzuha/Alice keyart.
    // Pauses while the tab isn't visible. Click a dot to jump to a slide
    // and reset the auto-timer.
    (function () {
      const slides = Array.from(document.querySelectorAll(".hero__art[data-slide]"));
      const dots   = Array.from(document.querySelectorAll(".hero__dot[data-goto]"));
      if (slides.length < 2) return;
      const INTERVAL_MS = 6500;
      let current = 0;
      let timer   = null;

      const show = (idx) => {
        current = ((idx % slides.length) + slides.length) % slides.length;
        slides.forEach((el, i) => el.classList.toggle("is-active", i === current));
        dots.forEach((el, i)   => el.classList.toggle("is-active", i === current));
      };
      const advance = () => show(current + 1);
      const start = () => { stop(); timer = setInterval(advance, INTERVAL_MS); };
      const stop  = () => { if (timer) { clearInterval(timer); timer = null; } };

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const idx = parseInt(dot.dataset.goto, 10);
          if (!Number.isNaN(idx)) { show(idx); start(); }
        });
      });

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) stop(); else start();
      });

      start();
    })();
  </script>

