      <dl class="photo-caption__dl" data-target="side-specs">
        <dt>type</dt><dd data-target="side-label">flat-lay</dd>
        <dt>set</dt><dd>studio &middot; natural light</dd>
        <dt>capture</dt><dd>a7iii &middot; 35mm</dd>
        <dt>process</dt><dd>color &middot; retouch</dd>
      </dl>
      <p class="photo-caption__desc">
        Illustration &rarr; production &rarr; photography. Each frame lives
        on a Shopify listing; the carousel above auto-advances and the
        caption card refreshes to match.
      </p>
    </div>
  </section>

  <!-- ================================================================
       05 · CATALOG — misc__card grid, shopify-native
       ================================================================ -->
  <section id="catalog" class="sec">
    <div class="sec__head" data-reveal>
      <p class="sec__num">04 / 04</p>
      <p class="sec__eyebrow">product catalog</p>
      <h2 class="sec__title">STRAIGHT OFF THE PRESS</h2>
