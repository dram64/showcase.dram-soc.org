---
export const prerender = true;
import Base from "../layouts/Base.astro";
const contactApi = import.meta.env.PUBLIC_CONTACT_API || "";
---
<Base title="contact" miscTitle="contact" showAnnouncement={false}>
  <section class="ct">
    <p class="ct__kicker">// establish contact</p>
    <h1 class="ct__title">contact.</h1>

    <form class="ct__form" id="contact-form">
      <input type="text" name="website" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true" />
      <div class="row">
        <label class="fld">
          <span>&gt; name</span>
          <input type="text" name="name" required maxlength="120" autocomplete="name" />
        </label>
        <label class="fld">
          <span>&gt; email</span>
          <input type="email" name="email" required maxlength="200" autocomplete="email" />
        </label>
      </div>
      <label class="fld">
        <span>&gt; subject</span>
        <input type="text" name="subject" maxlength="200" placeholder="collab, hire me, question&hellip;" />
      </label>
      <label class="fld">
        <span>&gt; message</span>
        <textarea name="body" required rows="6" maxlength="4000"></textarea>
      </label>
      <button class="ct__cta" type="submit">
        transmit <span class="arrow">&rarr;</span>
      </button>
      <p class="ct__status" role="status" aria-live="polite"></p>
    </form>

    <aside class="ct__aside">
      <p class="ct__aside-label">// direct</p>
      <a class="ct__line" href="mailto:desiramirez62200@gmail.com">
        <span class="ct__line-tag">email</span>
        <span class="ct__line-val">desiramirez62200@gmail.com</span>
      </a>
    </aside>
  </section>

  <script is:inline define:vars={{ contactApi }}>
    (function () {
      const form = document.getElementById("contact-form");
      const status = form.querySelector(".ct__status");
      const cta = form.querySelector(".ct__cta");
      if (!contactApi) { status.textContent = "// contact endpoint not configured"; status.classList.add("is-error"); cta.disabled = true; return; }
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        status.textContent = "";
        status.className = "ct__status";
        cta.disabled = true;
        cta.firstChild.textContent = "transmitting ";
        const data = Object.fromEntries(new FormData(form).entries());
        try {
          const res = await fetch(contactApi, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(data),
          });
          const payload = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(payload.error || "send failed");
          status.textContent = "// signal received. reply within a few days.";
          status.classList.add("is-ok");
          form.reset();
        } catch (err) {
          status.textContent = "// " + (err.message || "transmission failed");
          status.classList.add("is-error");
        } finally {
          cta.disabled = false;
          cta.firstChild.textContent = "transmit ";
        }
      });
    })();
  </script>

  <style>
    .ct {
      max-width: 900px;
      margin: 0 auto;
      padding: clamp(48px, 8vw, 96px) clamp(24px, 6vw, 48px);
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(220px, 0.9fr);
      gap: clamp(32px, 5vw, 72px);
    }
    .ct__kicker { font-family: 'JetBrains Mono', 'Apex Mk3', monospace; font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--misc-accent, #5061b9); margin: 0 0 16px; grid-column: 1 / -1; }
    .ct__title { font-family: 'Apex Mk3', sans-serif; font-weight: 300; font-size: clamp(3rem, 8vw, 5rem); line-height: 1; margin: 0 0 20px; grid-column: 1 / -1; text-transform: lowercase; }
    .ct__lede { font-family: 'Branding Pro', sans-serif; font-size: 1.05rem; line-height: 1.55; color: var(--misc-ink-soft, #6b6b6b); margin: 0 0 40px; grid-column: 1 / -1; max-width: 620px; }
    .ct__form { display: grid; gap: 22px; }
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
    .fld { display: grid; gap: 6px; }
    .fld span { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; letter-spacing: 0.14em; color: var(--misc-accent); }
    .fld input, .fld textarea {
      font-family: 'Branding Pro', sans-serif;
      font-size: 1rem;
      color: var(--misc-ink);
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      padding: 12px 14px;
      transition: border-color 140ms ease;
    }
    .fld textarea { resize: vertical; min-height: 140px; line-height: 1.5; }
    .fld input:focus, .fld textarea:focus { outline: none; border-color: var(--misc-accent); box-shadow: 0 0 0 2px rgba(80,97,185,0.15); }
    .ct__cta {
      justify-self: start;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.14em;
      text-transform: lowercase;
      background: var(--misc-ink);
      color: #fff;
      border: none;
      padding: 14px 28px;
      cursor: pointer;
      clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 100%, 10px 100%);
      transition: background 140ms ease, padding 140ms ease;
    }
    .ct__cta:hover { background: var(--misc-accent); padding-right: 34px; }
    .arrow { font-family: 'JetBrains Mono', monospace; }
    .ct__status { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; margin: 0; color: var(--misc-ink-soft); }
    .ct__status.is-ok { color: #2c8a3f; }
    .ct__status.is-error { color: #b53030; }
    .ct__aside { padding-top: 8px; }
    .ct__aside-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.22em; color: var(--misc-accent); margin: 0 0 12px; }
    .ct__line { display: grid; grid-template-columns: 60px 1fr; gap: 12px; padding: 8px 0; border-bottom: 1px dashed var(--misc-line); text-decoration: none; transition: color 140ms ease; }
    .ct__line:hover { color: var(--misc-accent); }
    .ct__line-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--misc-ink-soft); }
    .ct__line-val { font-family: 'Apex Mk3', monospace; font-size: 0.92rem; color: var(--misc-ink); word-break: break-word; }
    @media (max-width: 800px) { .ct { grid-template-columns: 1fr; } }
    @media (max-width: 600px) { .row { grid-template-columns: 1fr; } }
  </style>
</Base>
