---
export const prerender = true;
import Base from "../../layouts/Base.astro";
---
<Base title="insights" miscTitle="insights" showAnnouncement={false}>
  <section class="ops">
    <p class="ops__kicker">traffic · last 7 days · athena over cloudfront logs</p>
    <h1 class="ops__title">insights.</h1>
    <p class="ops__lede">
      Live from <strong>Amazon Athena</strong> over CloudFront access logs (parsed via a Glue
      Data Catalog table). Published nightly by the digest Lambda. Query cost: fractions
      of a cent, capped at 1 GB scanned via workgroup config.
    </p>

    <h2 class="ops__h2">top pages</h2>
    <table class="ops__tbl">
      <thead><tr><th>URI</th><th class="ops__num">Hits</th></tr></thead>
      <tbody id="i-body"><tr><td colspan="2">loading…</td></tr></tbody>
    </table>

    <p class="ops__note" id="i-generated">loading…</p>
  </section>

  <script is:inline>
    fetch("/insights.json", { cache: "no-cache" }).then(r => r.json()).then(d => {
      document.getElementById("i-generated").textContent = "digest generated " + new Date(d.generatedAt).toLocaleString();
      const body = document.getElementById("i-body");
      body.innerHTML = "";
      if (d.warning) {
        body.innerHTML = "<tr><td colspan='2'>" + d.warning + "</td></tr>";
        return;
      }
      const rows = d.topPages || [];
      if (!rows.length) {
        body.innerHTML = "<tr><td colspan='2'>no data yet — CloudFront logs roll in every hour</td></tr>";
        return;
      }
      rows.forEach(r => {
        const tr = document.createElement("tr");
        tr.innerHTML = `<td>${r.uri}</td><td class='ops__num'>${r.hits}</td>`;
        body.appendChild(tr);
      });
    }).catch(() => {
      document.getElementById("i-generated").textContent = "digest not available yet.";
    });
  </script>

  <style>
    .ops { max-width: 900px; margin: 0 auto; padding: clamp(48px, 8vw, 96px) clamp(24px, 6vw, 48px); }
    .ops__kicker { font-family: 'Apex Mk3', monospace; font-size: 0.78rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--misc-accent); margin: 0 0 16px; }
    .ops__title { font-family: 'Apex Mk3', monospace; font-weight: 300; font-size: clamp(3rem, 8vw, 5rem); line-height: 1; margin: 0 0 20px; text-transform: lowercase; letter-spacing: -0.02em; }
    .ops__lede { font-family: 'Branding Pro', sans-serif; font-size: 1.05rem; line-height: 1.55; color: var(--misc-ink-soft); margin: 0 0 5vh; max-width: 660px; }
    .ops__h2 { font-family: 'Apex Mk3', monospace; font-size: 0.85rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--misc-ink-soft); margin: 0 0 12px; padding-bottom: 8px; border-bottom: 1px solid var(--misc-line); }
    .ops__tbl { width: 100%; border-collapse: collapse; font-family: 'Branding Pro', sans-serif; font-size: 0.95rem; }
    .ops__tbl th, .ops__tbl td { padding: 12px 8px; text-align: left; border-bottom: 1px solid var(--misc-line); }
    .ops__tbl th { font-family: 'Apex Mk3', monospace; font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--misc-ink-soft); font-weight: 500; }
    .ops__num { text-align: right; font-variant-numeric: tabular-nums; }
    .ops__note { font-family: 'Apex Mk3', monospace; font-size: 0.82rem; color: var(--misc-ink-soft); margin-top: 32px; }
  </style>
</Base>
