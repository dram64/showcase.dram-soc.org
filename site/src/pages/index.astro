      background: rgba(255, 255, 255, 0.85);
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      color: var(--misc-ink, #14131a);
    }
    .room__live { color: var(--misc-accent, #5061b9); }
    .room__chars { position: absolute; bottom: 0; left: 0; right: 0; height: 65%; pointer-events: none; z-index: 1; }
    .room__char {
      position: absolute;
      bottom: -8%;
      height: 110%;
      width: auto;
      max-width: 60%;
      object-fit: contain;
      object-position: bottom center;
      filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.12));
      transition: transform 320ms ease;
    }
    .room__char--l { left: -6%; }
    .room__char--r { right: -6%; }
    .room:hover .room__char--l { transform: translate(-3px, -6px) rotate(-1deg); }
    .room:hover .room__char--r { transform: translate(3px, -6px) rotate(1deg); }
    .room__title-wrap {
      position: relative;
      z-index: 2;
      padding: 56px 28px 0;
      text-align: center;
    }
    .room__eyebrow {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: lowercase;
      color: var(--misc-ink-soft, #6b6b6b);
      margin-bottom: 6px;
    }
    .room__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(3.4rem, 8vw, 6rem);
      line-height: 0.95;
      color: var(--misc-ink, #14131a);
      margin: 0 0 8px;
      text-transform: lowercase;
    }
    .room__sub {
      font-family: 'Beam Visionary', cursive;
      font-size: clamp(1rem, 1.6vw, 1.4rem);
      color: var(--misc-accent, #5061b9);
      margin: 0;
    }
    .room__foot {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      z-index: 3;
      padding: 16px 20px;
      background: linear-gradient(to top, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.4) 80%, transparent 100%);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .room__enter {
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      color: var(--misc-accent, #5061b9);
    }
    .room__specs {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--misc-ink-soft, #6b6b6b);
    }
    @media (max-width: 900px) { .rooms { grid-template-columns: 1fr; } }

    /* ============================================================
       PRODUCT PHOTOGRAPHY + PATHS
       ============================================================ */
    .prod-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 60px;
    }
    .prod {
      margin: 0;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      overflow: hidden;
      transition: transform 200ms ease, border-color 200ms ease;
      display: flex;
      flex-direction: column;
    }
    .prod:hover { transform: translateY(-3px); border-color: var(--misc-accent, #5061b9); }
    .prod__img {
      background: #f7f6f2;
      aspect-ratio: 4/5;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .prod__img img { max-width: 100%; max-height: 100%; object-fit: contain; }
    .prod figcaption {
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.10));
    }
    .prod__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
    }
    .prod__name {
      font-family: 'Apex Mk3', sans-serif;
      font-size: 1.05rem;
      color: var(--misc-ink, #14131a);
    }
    .prod__spec {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.78rem;
      color: var(--misc-ink-soft, #6b6b6b);
      line-height: 1.4;
    }
    .paths {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .path {
      display: block;
      padding: 24px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      text-decoration: none;
      color: inherit;
      transition: border-color 180ms ease, transform 180ms ease;
    }
    .path:hover { border-color: var(--misc-accent, #5061b9); transform: translateY(-2px); }
    .path__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 12px;
    }
    .path__title {
      font-family: 'Apex Mk3', sans-serif;
      font-size: 1.2rem;
      color: var(--misc-ink, #14131a);
      margin: 0 0 8px;
      font-weight: 400;
      text-transform: lowercase;
    }
    .path__desc {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.9rem;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
      line-height: 1.5;
    }
    @media (max-width: 900px) {
      .prod-grid { grid-template-columns: repeat(2, 1fr); }
      .paths { grid-template-columns: 1fr; }
    }

    /* =========================================================================
       ENHANCEMENTS — Illustration + Roster + Editorial Photography + Themes mini
       ========================================================================= */

    #graphic,
    #roster {
      background:
        radial-gradient(circle at 8% 12%, rgba(80, 97, 185, 0.05) 0%, transparent 45%),
        radial-gradient(circle at 92% 88%, rgba(255, 129, 176, 0.045) 0%, transparent 50%),
        var(--misc-bg, #fdfcf9);
      position: relative;
      overflow: hidden;
    }

    /* ---- Illustration ---- */
    #graphic .graphic-slot {
      min-height: 520px;
      background:
        radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.9) 0%, transparent 50%),
        repeating-linear-gradient(
          -45deg,
          rgba(80, 97, 185, 0.04) 0px,
          rgba(80, 97, 185, 0.04) 8px,
          transparent 8px,
          transparent 22px
        ),
        #fff;
      border: 1px dashed rgba(80, 97, 185, 0.35);
      position: relative;
    }
    #graphic .graphic-slot::before {
      content: "";
      position: absolute;
      inset: 12px;
      border: 1px solid rgba(80, 97, 185, 0.1);
      pointer-events: none;
    }
    #graphic .graphic-slot__icon { font-size: 3rem; opacity: 0.55; }
    #graphic .graphic-slot__label {
      font-size: 0.78rem;
      color: var(--misc-accent);
      font-weight: 600;
      letter-spacing: 0.24em;
    }
    #graphic .graphic-stage { position: relative; }
    #graphic .graphic-stage::before {
      content: "n° 01 / drop 01";
      position: absolute;
      top: -14px;
      left: 24px;
      background: var(--misc-bg, #fdfcf9);
      padding: 4px 10px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent);
      border: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      z-index: 2;
    }
    #graphic .graphic-chip {
      width: 46px; height: 46px;
      background: var(--misc-accent);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-family: 'Beam Visionary', cursive;
      font-size: 1.6rem;
      line-height: 1;
      padding-bottom: 4px;
    }
    #graphic .graphic-chip::after { content: "d"; }

    /* ---- Roster ---- */
    #roster .roster-stage {
      grid-template-columns: minmax(0, 1.15fr) minmax(280px, 380px);
      gap: clamp(28px, 5vw, 72px);
    }
    #roster .roster-block {
      top: 2%;
      right: 26%;
      width: 62%;
      height: 96%;
      background:
        radial-gradient(circle at 30% 30%, rgba(255, 129, 176, 0.05) 0%, transparent 60%),
        rgba(80, 97, 185, 0.06);
    }
    #roster .roster-letters {
      font-size: clamp(7rem, 22vw, 20rem);
      color: rgba(80, 97, 185, 0.06);
    }
    #roster .roster-img {
      max-width: 560px;
      padding: 8px;
      background: #fff;
      border: 1px solid var(--misc-line);
      box-shadow: 0 20px 40px -20px rgba(20, 19, 26, 0.12);
    }
    #roster .roster-hero { position: relative; }
    #roster .roster-hero::before {
      content: "";
      position: absolute;
      top: -14px; left: -14px;
      width: 32px; height: 32px;
      border-top: 2px solid var(--misc-accent);
      border-left: 2px solid var(--misc-accent);
      pointer-events: none;
      z-index: 3;
    }
    #roster .roster-hero::after {
      content: "";
      position: absolute;
      bottom: -14px; right: -14px;
      width: 32px; height: 32px;
      border-bottom: 2px solid var(--misc-accent);
      border-right: 2px solid var(--misc-accent);
      pointer-events: none;
      z-index: 3;
    }
    #roster .roster-card {
      padding: 32px 28px;
      background: linear-gradient(180deg, #fff 0%, #faf9f5 100%);
      border: 1px solid var(--misc-line);
      box-shadow: 0 20px 40px -20px rgba(20, 19, 26, 0.10);
      position: relative;
    }
    #roster .roster-card::before {
      content: "profile";
      position: absolute;
      top: -12px;
      right: 20px;
      background: var(--misc-accent);
      color: #fff;
      padding: 3px 10px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    #roster .roster-card__dl {
      grid-template-columns: auto 1fr;
      gap: 10px 16px;
      align-items: center;
    }
    #roster .roster-card__dl dt {
      background: rgba(80, 97, 185, 0.10);
      color: var(--misc-accent);
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 0.6rem;
      justify-self: start;
      font-weight: 600;
    }

    /* ---- Compact theme selector at bottom of roster ---- */
    .theme-mini {
      margin-top: clamp(48px, 6vw, 80px);
      padding-top: clamp(32px, 4vw, 48px);
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      display: grid;
      grid-template-columns: minmax(260px, 320px) 1fr;
      gap: clamp(24px, 4vw, 56px);
      align-items: center;
    }
    .theme-mini__eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent);
      margin: 0 0 8px;
    }
    .theme-mini__lede {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--misc-ink-soft);
      margin: 0;
    }
    .theme-mini__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      max-width: 480px;
      justify-self: end;
    }
    .theme-sq {
      position: relative;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      aspect-ratio: 1.6 / 1;
      background: #fff;
      border: 1px solid var(--misc-line);
      overflow: hidden;
      text-decoration: none;
      transition: transform 200ms ease, border-color 200ms ease;
    }
    .theme-sq:hover { transform: translateY(-2px); border-color: var(--misc-accent); }
    .theme-sq--psg { background: linear-gradient(180deg, #ffe0eb 0%, #fff4fa 60%, #d6f8ff 100%); }
    .theme-sq--nso { background: linear-gradient(180deg, #e0e6ff 0%, #f6f2ff 60%, #ffe0f4 100%); }
    .theme-sq__char {
      position: absolute;
      bottom: 0;
      height: 88%;
      width: auto;
      max-width: 46%;
    }
    .theme-sq__char--l { left: 3%; }
    .theme-sq__char--r { right: 3%; }
    .theme-sq__label {
      position: relative;
      z-index: 2;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--misc-ink);
      background: rgba(255, 255, 255, 0.9);
      padding: 3px 12px;
      margin-bottom: 8px;
    }
    @media (max-width: 800px) {
      .theme-mini { grid-template-columns: 1fr; }
      .theme-mini__grid { justify-self: stretch; max-width: none; }
    }

    /* ---- Editorial photography — viewport-fit wrapper ---- */
    #photo {
      padding-top: clamp(48px, 6vh, 88px);
      padding-bottom: clamp(48px, 6vw, 100px);
    }
    #photo .photo-viewport {
      min-height: calc(100vh - clamp(96px, 12vh, 176px));
      min-height: calc(100svh - clamp(96px, 12vh, 176px));
      display: flex;
      flex-direction: column;
      gap: clamp(24px, 3vh, 40px);
      margin-bottom: clamp(56px, 6vw, 96px);
    }
    #photo .photo-viewport .sec__head { margin-bottom: 0; }

    .photo-editorial {
      display: grid;
      grid-template-columns: minmax(0, 1.65fr) minmax(280px, 380px);
      gap: clamp(24px, 4vw, 56px);
      flex: 1;
      min-height: 0;
      align-items: stretch;
    }

    /* ---- 3D coverflow carousel ---- */
    .lead-3d {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 0;
      perspective: 1600px;
      perspective-origin: 50% 55%;
    }
    .lead-3d__stage {
      position: relative;
      flex: 1;
      min-height: 340px;
      transform-style: preserve-3d;
      display: block;
    }
    .lead-3d__card {
      position: absolute;
      top: 50%;
      left: 50%;
      width: clamp(240px, 32vw, 420px);
      aspect-ratio: 4 / 5;
      background: transparent;
      border: none;
      padding: 0;
      cursor: pointer;
      transform: translate(-50%, -50%);
      transform-origin: center center;
      transform-style: preserve-3d;
      transition:
        transform 780ms cubic-bezier(0.34, 1.20, 0.64, 1),
        opacity 620ms ease,
        z-index 0ms 320ms;
      will-change: transform, opacity;
      -webkit-tap-highlight-color: transparent;
    }
    .lead-3d__card-inner {
      position: relative;
      width: 100%;
      height: 100%;
      background: linear-gradient(180deg, #f7f6f2 0%, #eeece4 100%);
      border: 1px solid var(--misc-line, rgba(0, 0, 0, 0.12));
      box-shadow: 0 20px 45px -18px rgba(20, 19, 26, 0.22);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      transition: border-color 300ms ease, box-shadow 300ms ease;
    }
    .lead-3d__card-inner img {
      max-width: 84%;
      max-height: 84%;
      object-fit: contain;
      filter: drop-shadow(0 22px 26px rgba(20, 19, 26, 0.18));
      transition: filter 300ms ease;
    }
    .lead-3d__card-tag {
      position: absolute;
      top: 12px;
      right: 12px;
      background: #fff;
      color: var(--misc-accent, #5061b9);
      padding: 3px 10px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      border: 1px solid var(--misc-line, rgba(0, 0, 0, 0.12));
    }
    .lead-3d__card.is-center .lead-3d__card-inner {
      border-color: var(--misc-accent, #5061b9);
      box-shadow: 0 40px 70px -24px rgba(80, 97, 185, 0.35);
    }
    .lead-3d__card.is-center .lead-3d__card-inner img {
      filter: drop-shadow(0 28px 34px rgba(20, 19, 26, 0.24));
    }

    /* Carousel controls */
    .lead-3d__ctrl {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      padding: 16px 0 0;
    }
    .lead-3d__arrow {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid var(--misc-line, rgba(0, 0, 0, 0.14));
      background: #fff;
      color: var(--misc-ink, #14131a);
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
      cursor: pointer;
      transition: background 160ms ease, color 160ms ease, border-color 160ms ease, transform 160ms ease;
    }
    .lead-3d__arrow:hover {
      background: var(--misc-accent, #5061b9);
      color: #fff;
      border-color: var(--misc-accent, #5061b9);
      transform: translateY(-1px);
    }
    .lead-3d__dots {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .lead-3d__dots button {
      width: 28px;
      height: 4px;
      padding: 0;
      border: none;
      background: rgba(0, 0, 0, 0.16);
      border-radius: 2px;
      cursor: pointer;
      transition: background 220ms ease, width 220ms ease;
    }
    .lead-3d__dots button:hover { background: rgba(0, 0, 0, 0.3); }
    .lead-3d__dots button.is-active {
      background: var(--misc-accent, #5061b9);
      width: 42px;
    }

    /* ---- Editorial sidebar ---- */
    .photo-side {
      display: flex;
      flex-direction: column;
      padding: 8px 4px;
      min-height: 0;
    }
    .photo-side__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 8px;
    }
    .photo-side__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(2rem, 3.4vw, 2.8rem);
      line-height: 0.95;
      color: var(--misc-ink, #14131a);
      margin: 0 0 24px;
      text-transform: lowercase;
      letter-spacing: -0.02em;
    }

    /* Dynamic caption block */
    .photo-side__cap {
      padding: 20px 20px 22px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0, 0, 0, 0.12));
      border-left: 3px solid var(--misc-accent, #5061b9);
      margin-bottom: 20px;
    }
    .photo-side__idx {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: 2.4rem;
      line-height: 0.9;
      color: rgba(80, 97, 185, 0.35);
      margin: 0 0 4px;
      letter-spacing: -0.04em;
    }
    .photo-side__cap-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 4px;
    }
    .photo-side__cap-name {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: 1.7rem;
      line-height: 1;
      color: var(--misc-ink, #14131a);
      margin: 0 0 12px;
      text-transform: lowercase;
      letter-spacing: -0.01em;
    }
    .photo-side__dot { color: var(--misc-accent, #5061b9); }
    .photo-side__specs {
      display: grid;
      gap: 6px;
    }
    .photo-side__specs span {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.88rem;
      color: var(--misc-ink, #14131a);
      display: grid;
      grid-template-columns: 80px 1fr;
      align-items: baseline;
    }
    .photo-side__specs em {
      font-style: normal;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
    }

    .photo-side__quote {
      padding: 16px;
      background: rgba(80, 97, 185, 0.06);
      border-left: 3px solid var(--misc-accent, #5061b9);
      margin-top: auto;
    }
    .photo-side__quote p {
      font-family: 'Beam Visionary', cursive;
      font-size: 1.1rem;
      line-height: 1.4;
      color: var(--misc-ink, #14131a);
      margin: 0 0 6px;
    }
    .photo-side__by {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.14em;
      color: var(--misc-ink-soft, #6b6b6b);
    }

    @media (max-width: 900px) {
      #photo .photo-viewport { min-height: 0; }
      .photo-editorial { grid-template-columns: 1fr; }
      .lead-3d__stage { min-height: 320px; }
    }
    .photo-lead {
      position: relative;
      margin: 0;
      background: #fff;
      border: 1px solid var(--misc-line);
      overflow: hidden;
    }
    .photo-lead__num {
      position: absolute;
      top: 20px;
      left: 24px;
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(4rem, 9vw, 8rem);
      line-height: 0.8;
      color: rgba(80, 97, 185, 0.10);
      letter-spacing: -0.04em;
      z-index: 1;
      pointer-events: none;
    }
    .photo-lead__img {
      background: linear-gradient(180deg, #f7f6f2 0%, #efece4 100%);
      aspect-ratio: 5 / 4;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }
    .photo-lead__img img {
      max-width: 78%;
      max-height: 82%;
      object-fit: contain;
      filter: drop-shadow(0 20px 30px rgba(20, 19, 26, 0.15));
    }
    .photo-lead__cap {
      padding: 28px clamp(24px, 3vw, 40px);
      display: grid;
      gap: 12px;
      border-top: 1px solid var(--misc-line);
    }
    .photo-lead__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent);
      margin: 0;
    }
    .photo-lead__name {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
