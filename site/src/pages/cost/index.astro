---
export const prerender = true;
import Gryphline from "../../layouts/Gryphline.astro";
---
<Gryphline title="cost">
  <section class="gl-shell">
    <p class="gl-kicker">actual spend · last 30 days · unblended</p>
    <h1 class="gl-h1">cost<em>.</em></h1>
    <p class="gl-lede">
      Live from <strong>AWS Cost Explorer</strong>, published nightly by a scheduled Lambda.
      Radical transparency: the actual spend running this whole stack, grouped by service. An
      AWS Budget hard-caps the account at <code>$25/mo</code> with SNS alerts at 20% and 40%,
      plus Cost Anomaly Detection scoped to <code>&gt;= $1</code> daily drift.
    </p>

    <div class="gl-stats">
      <div class="gl-stat">
        <p class="gl-stat__label">30-day total</p>
        <p class="gl-stat__value" id="c-total">&mdash;</p>
      </div>
      <div class="gl-stat">
        <p class="gl-stat__label">period start</p>
        <p class="gl-stat__value" id="c-start">&mdash;</p>
      </div>
      <div class="gl-stat">
        <p class="gl-stat__label">period end</p>
        <p class="gl-stat__value" id="c-end">&mdash;</p>
      </div>
      <div class="gl-stat">
        <p class="gl-stat__label">of budget</p>
        <p class="gl-stat__value" id="c-util">&mdash;</p>
      </div>
    </div>

    <div class="gl-section">
      <h2 class="gl-h2">budget headroom</h2>
      <div class="c-bar">
        <div class="c-bar__fill" id="c-fill" style="width: 0%"></div>
        <div class="c-bar__mark" style="left: 20%"><span>20%</span></div>
        <div class="c-bar__mark" style="left: 40%"><span>40%</span></div>
      </div>
      <p class="gl-kicker" style="margin-top: 12px; color: var(--gl-ink-soft);">
        anomaly detection: <span id="c-anom">&mdash;</span> &middot; active budget alerts: <span id="c-alerts">&mdash;</span>
      </p>
    </div>

    <div class="gl-section">
      <h2 class="gl-h2">by service</h2>
      <table class="gl-tbl">
        <thead>
          <tr><th>Service</th><th class="gl-tbl__num">$ / 30d</th><th class="gl-tbl__num">% total</th></tr>
        </thead>
        <tbody id="c-body"><tr><td colspan="3">loading&hellip;</td></tr></tbody>
      </table>
    </div>

    <p class="gl-kicker" id="c-generated" style="margin-top: 32px;">loading&hellip;</p>
  </section>

  <style>
    .c-bar {
      position: relative;
      height: 22px;
      background: rgba(80, 97, 185, 0.12);
      border: 1px solid rgba(80, 97, 185, 0.28);
      overflow: hidden;
      margin-top: 16px;
    }
    .c-bar__fill {
      height: 100%;
      background: linear-gradient(90deg, var(--gl-cyan, #5061b9) 0%, #ffee00 100%);
      transition: width 480ms ease;
    }
    .c-bar__mark {
      position: absolute;
      top: 0;
      bottom: -18px;
      width: 1px;
      background: rgba(20, 19, 26, 0.35);
    }
    .c-bar__mark span {
      position: absolute;
      top: 100%;
      transform: translateX(-50%);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      color: rgba(20, 19, 26, 0.55);
    }
  </style>

  <script is:inline>
    fetch("/cost.json", { cache: "no-cache" }).then(r => r.json()).then(d => {
      const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
      set("c-total", "$" + (d.total ?? 0).toFixed(2));
      set("c-start", d.periodStart || "-");
      set("c-end",   d.periodEnd   || "-");
      const util = typeof d.budgetUtilizationPct === "number"
        ? d.budgetUtilizationPct
        : (d.budgetCeiling ? (d.total / d.budgetCeiling) * 100 : 0);
      set("c-util", util.toFixed(1) + " %");
      set("c-anom", d.anomalyStatus || "-");
      set("c-alerts", (d.activeBudgetAlerts ?? "-") + "");
      set("c-generated", "// digest generated " + new Date(d.generatedAt).toLocaleString());
      const fill = document.getElementById("c-fill");
      if (fill) fill.style.width = Math.min(util, 100) + "%";
      const body = document.getElementById("c-body");
      body.innerHTML = "";
      const rows = (d.services || []).slice().sort((a, b) => b.cost - a.cost);
      rows.forEach(s => {
        const tr = document.createElement("tr");
        const pct = d.total ? ((s.cost / d.total) * 100).toFixed(1) + "%" : "";
        tr.innerHTML = `<td><code>${s.service}</code></td><td class="gl-tbl__num">$${s.cost.toFixed(2)}</td><td class="gl-tbl__num">${pct}</td>`;
        body.appendChild(tr);
      });
      if (!rows.length) body.innerHTML = "<tr><td colspan='3'>no charges yet</td></tr>";
    }).catch(() => {
      document.getElementById("c-generated").textContent = "// digest not available yet";
    });
  </script>
</Gryphline>
