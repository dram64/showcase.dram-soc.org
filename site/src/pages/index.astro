    /* ---- 3D coverflow carousel — PSP/PS2 magazine-showcase aesthetic
           Products float freely with cast floor shadows, no frames or
           borders, subtle soft floor plane suggests a gallery display. ---- */
    .lead-3d {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 0;
      perspective: 1800px;
      perspective-origin: 50% 60%;
      background:
        radial-gradient(ellipse at 50% 100%, rgba(80, 97, 185, 0.05) 0%, transparent 60%),
        linear-gradient(180deg, transparent 40%, rgba(80, 97, 185, 0.02) 100%);
    }
    /* Soft horizon floor line, receding into distance */
    .lead-3d::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 68px;
      height: 1px;
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(80, 97, 185, 0.15) 20%,
        rgba(80, 97, 185, 0.30) 50%,
        rgba(80, 97, 185, 0.15) 80%,
        transparent 100%
      );
      pointer-events: none;
      z-index: 1;
    }
    .lead-3d__stage {
      position: relative;
      flex: 1;
      min-height: 640px;
      transform-style: preserve-3d;
      display: block;
    }
    .lead-3d__card {
      position: absolute;
      top: 50%;
      left: 50%;
      width: clamp(400px, 50vw, 720px);
      aspect-ratio: 4 / 5;
      background: transparent;
      border: none;
      padding: 0;
      cursor: pointer;
      transform: translate(-50%, -50%);
      transform-origin: center center;
      transform-style: preserve-3d;
      transition:
        transform 780ms cubic-bezier(0.34, 1.20, 0.64, 1),
        opacity 620ms ease,
        z-index 0ms 320ms;
      will-change: transform, opacity;
      -webkit-tap-highlight-color: transparent;
    }
    /* No frame, no background — just a stage for the product to float on */
    .lead-3d__card-inner {
      position: relative;
      width: 100%;
      height: 100%;
      background: transparent;
      border: none;
      box-shadow: none;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: visible;
    }
    /* Product image floats with a soft render-style drop-shadow */
    .lead-3d__card-inner img {
      max-width: 98%;
      max-height: 98%;
      object-fit: contain;
      filter:
        drop-shadow(0 8px 16px rgba(20, 19, 26, 0.18))
        drop-shadow(0 22px 30px rgba(20, 19, 26, 0.22));
      transition: filter 400ms ease, transform 400ms ease;
    }
    /* Cast floor shadow — elliptical blur beneath the product, like a
       game-asset render. Sits behind the image on the "floor" plane. */
    .lead-3d__card-inner::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: 3%;
      width: 74%;
      height: 22px;
      transform: translateX(-50%);
      background: radial-gradient(ellipse,
        rgba(20, 19, 26, 0.42) 0%,
        rgba(20, 19, 26, 0.15) 40%,
        transparent 70%
      );
      filter: blur(6px);
      opacity: 0.75;
      transition: opacity 400ms ease, width 400ms ease, filter 400ms ease;
      z-index: -1;
      pointer-events: none;
    }
    /* Minimal numbered tag — no border, no bg, just a floating label */
    .lead-3d__card-tag {
      position: absolute;
      top: 8px;
      left: 12px;
      color: var(--misc-accent, #5061b9);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.24em;
      opacity: 0.85;
      pointer-events: none;
      z-index: 2;
      background: transparent;
      border: none;
      padding: 0;
    }
    /* Center card — brighter shadow, slightly larger shadow footprint */
    .lead-3d__card.is-center .lead-3d__card-inner img {
      filter:
        drop-shadow(0 10px 20px rgba(20, 19, 26, 0.22))
        drop-shadow(0 32px 44px rgba(20, 19, 26, 0.30));
    }
    .lead-3d__card.is-center .lead-3d__card-inner::after {
      opacity: 1;
      width: 82%;
      filter: blur(8px);
    }
    /* Side cards fade their floor shadow so it doesn't compete with the center */
    .lead-3d__card:not(.is-center) .lead-3d__card-inner::after {
      opacity: 0.4;
    }
    /* On hover, subtle lift feel */
    .lead-3d__card.is-center:hover .lead-3d__card-inner img {
      transform: translateY(-4px);
    }
    .lead-3d__card.is-center:hover .lead-3d__card-inner::after {
      width: 88%;
      opacity: 0.6;
    }

    /* Carousel controls — pinned well below the stage, above the
