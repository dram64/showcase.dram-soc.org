---
export const prerender = true;
import Base from "../../layouts/Base.astro";
---
<Base title="work" miscTitle="work">
  <section class="work-grid">
    <a class="work-tile work-tile--psg" href="/work/psg/">
      <img class="work-tile__char work-tile__char--panty"    src="/assets/psg-panty-sticker.webp"    alt="Panty" />
      <img class="work-tile__char work-tile__char--stocking" src="/assets/psg-stocking-sticker.webp" alt="Stocking" />
      <div class="work-tile__meta">
        <p class="work-tile__num">01</p>
        <h2 class="work-tile__name">PSG</h2>
        <p class="work-tile__desc">Panty &amp; Stocking pastiche — candy halftones, hot pink frills, 7-card showcase.</p>
      </div>
    </a>

    <a class="work-tile work-tile--nso" href="/work/nso/">
      <img class="work-tile__char work-tile__char--ame"    src="/assets/nso-ame-sticker.webp"    alt="Ame" />
      <img class="work-tile__char work-tile__char--kangel" src="/assets/nso-kangel-sticker.webp" alt="KAngel" />
      <div class="work-tile__meta">
        <p class="work-tile__num">02</p>
        <h2 class="work-tile__name">NSO</h2>
        <p class="work-tile__desc">Needy Streamer Overload homage — CRT scanlines, RGB glitching, chrome bg.</p>
      </div>
    </a>

    <a class="work-tile work-tile--misc" href="/">
      <div class="work-tile__meta">
        <p class="work-tile__num">03</p>
        <h2 class="work-tile__name">MISC</h2>
        <p class="work-tile__desc">The catalog hub — magazine-style, numbered cards, slate-violet accent, 47 products.</p>
      </div>
    </a>
  </section>

  <style>
    .work-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      padding: 0 clamp(24px, 6vw, 72px);
      max-width: 1400px;
      margin: 6vh auto 12vh;
    }
    .work-tile {
      position: relative;
      display: block;
      aspect-ratio: 3 / 4;
      padding: 32px 28px;
      background: #fff;
      border: 1px solid rgba(20,19,26,0.14);
      border-radius: 12px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      transition: transform 200ms ease, box-shadow 200ms ease;
    }
    .work-tile:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px -20px rgba(0,0,0,0.15);
    }
    .work-tile--psg {
      background: linear-gradient(150deg, #ffe0eb 0%, #fff4fa 60%, #d6f8ff 100%);
    }
    .work-tile--nso {
      background: linear-gradient(150deg, #e0e6ff 0%, #f6f2ff 60%, #ffe0f4 100%);
    }
    .work-tile--misc {
      background: #f5f4f0;
    }
    .work-tile__char {
      position: absolute;
      bottom: -8%;
      height: 62%;
      z-index: 1;
      pointer-events: none;
      filter: drop-shadow(0 6px 12px rgba(0,0,0,0.12));
    }
    .work-tile__char--panty, .work-tile__char--ame       { left:  -6%; }
    .work-tile__char--stocking, .work-tile__char--kangel { right: -6%; }
    .work-tile__meta {
      position: relative;
      z-index: 2;
    }
    .work-tile__num {
      font-family: 'Apex Mk3', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      color: rgba(20,19,26,0.5);
      margin: 0 0 10px;
    }
    .work-tile__name {
      font-family: 'Apex Mk3', monospace;
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      font-weight: 300;
      margin: 0 0 12px;
      line-height: 1;
      letter-spacing: -0.02em;
    }
    .work-tile__desc {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.92rem;
      line-height: 1.5;
      color: rgba(20,19,26,0.7);
      margin: 0;
      max-width: 90%;
    }
    @media (max-width: 900px) {
      .work-grid { grid-template-columns: 1fr; gap: 20px; }
      .work-tile { aspect-ratio: 5 / 3; }
      .work-tile__char { height: 90%; }
    }
  </style>
</Base>
