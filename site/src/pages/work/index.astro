---
export const prerender = true;
import Base from "../../layouts/Base.astro";
---
<Base title="work" miscTitle="work" showAnnouncement={false}>
  <section class="work">
    <p class="work__kicker">// three themed storefronts</p>
    <h1 class="work__title">tokyo zero.</h1>
    <p class="work__lede">
      Panty &amp; Stocking pastiche, Needy Streamer Overload homage, and a neutral catalog hub &mdash;
      all one brand voice. Click through for the full themed pages.
    </p>

    <div class="work__grid">
      <a class="w-tile w-tile--psg" href="/work/psg/">
        <img class="w-tile__char w-tile__char--l" src="/assets/psg-panty-sticker.webp" alt="Panty" />
        <img class="w-tile__char w-tile__char--r" src="/assets/psg-stocking-sticker.webp" alt="Stocking" />
        <div class="w-tile__meta">
          <p class="w-tile__num">01</p>
          <h2 class="w-tile__name">PSG</h2>
          <p class="w-tile__desc">Panty &amp; Stocking pastiche &mdash; candy halftones, hot pink frills, 7-card showcase.</p>
        </div>
      </a>

      <a class="w-tile w-tile--nso" href="/work/nso/">
        <img class="w-tile__char w-tile__char--l" src="/assets/nso-ame-sticker.webp" alt="Ame" />
        <img class="w-tile__char w-tile__char--r" src="/assets/nso-kangel-sticker.webp" alt="KAngel" />
        <div class="w-tile__meta">
          <p class="w-tile__num">02</p>
          <h2 class="w-tile__name">NSO</h2>
          <p class="w-tile__desc">Needy Streamer Overload homage &mdash; CRT scanlines, RGB glitching, chrome bg.</p>
        </div>
      </a>

      <a class="w-tile w-tile--misc" href="/catalog/">
        <div class="w-tile__meta">
          <p class="w-tile__num">03</p>
          <h2 class="w-tile__name">MISC</h2>
          <p class="w-tile__desc">Neutral hub &mdash; magazine catalog, numbered cards, slate-violet accent, 30+ products.</p>
        </div>
      </a>
    </div>
  </section>

  <style>
    .work { max-width: 1200px; margin: 0 auto; padding: clamp(48px, 8vw, 96px) clamp(24px, 6vw, 48px); }
    .work__kicker {
      font-family: 'Apex Mk3', 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 16px;
    }
    .work__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(3rem, 8vw, 5rem);
      line-height: 1;
      margin: 0 0 20px;
      text-transform: lowercase;
    }
    .work__lede {
      font-family: 'Branding Pro', sans-serif;
      font-size: 1.05rem;
      line-height: 1.55;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0 0 6vh;
      max-width: 620px;
    }
    .work__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .w-tile {
      position: relative;
      display: block;
      aspect-ratio: 3 / 4;
      padding: 28px 24px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      transition: transform 200ms ease, border-color 200ms ease;
      clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 0 100%);
    }
    .w-tile:hover { transform: translateY(-4px); border-color: var(--misc-accent); }
    .w-tile--psg  { background: linear-gradient(150deg, #ffe0eb 0%, #fff4fa 60%, #d6f8ff 100%); }
    .w-tile--nso  { background: linear-gradient(150deg, #e0e6ff 0%, #f6f2ff 60%, #ffe0f4 100%); }
    .w-tile__char {
      position: absolute;
      bottom: -8%;
      height: 62%;
      pointer-events: none;
      filter: drop-shadow(0 6px 12px rgba(0,0,0,0.12));
      z-index: 1;
    }
    .w-tile__char--l { left: -6%; }
    .w-tile__char--r { right: -6%; }
    .w-tile__meta { position: relative; z-index: 2; }
    .w-tile__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 10px;
    }
    .w-tile__name {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 400;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      margin: 0 0 12px;
      line-height: 1;
      color: var(--misc-ink, #1a1a1a);
    }
    .w-tile__desc {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
      max-width: 90%;
    }
    @media (max-width: 900px) {
      .work__grid { grid-template-columns: 1fr; }
      .w-tile { aspect-ratio: 5/3; }
      .w-tile__char { height: 90%; }
    }
  </style>
</Base>
