  <script is:inline>
    // Portrait carousel — swap the character showcase on click.
    const roster = {
      kafka:     { name: "Kafka",             letters: "KAFKA",      faction: "Stellaron Hunters",       universe: "Honkai: Star Rail", tag: "HSR",  img: "/portfolio/kafka.webp",     num: "01" },
      topaz:     { name: "Topaz",             letters: "TOPAZ",      faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR", img: "/portfolio/topaz.webp",     num: "02" },
      psg:       { name: "Panty & Stocking",  letters: "PSG",        faction: "Daten City Church",       universe: "Panty & Stocking",  tag: "PSG",  img: "/portfolio/psg.webp",       num: "03" },
      ayaka:     { name: "Kamisato Ayaka",    letters: "AYAKA",      faction: "Kamisato Clan",           universe: "Genshin Impact",     tag: "GI",   img: "/portfolio/ayaka.webp",     num: "04" },
      jane:      { name: "Jane Doe",          letters: "JANE",       faction: "Tokyo Zero Original",     universe: "Chromadipity Core",  tag: "OC",   img: "/portfolio/jane.webp",      num: "05" },
      ironmouse: { name: "Ironmouse",         letters: "MOUSE",      faction: "VShojo",                  universe: "Vtuber",             tag: "VT",   img: "/portfolio/ironmouse.webp", num: "06" },
    };
    document.querySelectorAll(".ef-portrait[data-key]").forEach(btn => {
      btn.addEventListener("click", () => {
        const k = btn.dataset.key;
        const r = roster[k];
        if (!r) return;
        document.querySelectorAll(".ef-portrait").forEach(b => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        const map = { name: r.name, letters: r.letters, "brk-name": r.name, faction: r.faction, universe: r.universe, tag: r.tag };
        Object.keys(map).forEach(target => {
          const el = document.querySelector(`[data-target="${target}"]`);
          if (el) el.textContent = map[target];
        });
        const img = document.querySelector('[data-target="img"]');
        if (img) img.src = r.img;
        const num = document.getElementById("c-num");
        if (num) num.textContent = r.num;
      });
    });

    // Section tracker — IntersectionObserver highlights active section,
    // click a tracker item to smooth-scroll there.
    const trackerItems = document.querySelectorAll(".tracker__item[data-section]");
    const sectionIds = ["hero", "graphic", "roster", "catalog", "themes", "photo"];
    const setActive = (id) => {
      trackerItems.forEach(el => el.classList.toggle("is-active", el.dataset.section === id));
    };
    const io = new IntersectionObserver((entries) => {
      // Pick the entry that is most intersecting near the top-third of the viewport.
      let best = null;
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        if (!best || e.intersectionRatio > best.intersectionRatio) best = e;
      });
      if (best) setActive(best.target.id);
    }, {
      // Section counts as "active" once its top is within the top 40% of the viewport
      rootMargin: "-25% 0px -50% 0px",
      threshold: [0, 0.2, 0.5, 0.8, 1],
    });
    sectionIds.forEach(id => {
      const el = document.getElementById(id);
      if (el) io.observe(el);
    });
    trackerItems.forEach(item => {
      item.addEventListener("click", (e) => {
        e.preventDefault();
        const target = document.getElementById(item.dataset.section);
        if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    // Hide fixed rails once user scrolls past the hero; slide tracker back to
    // the edge when the rails go away.
    const heroEl = document.getElementById("hero");
    const railL = document.querySelector(".hero__rail--l");
    const railR = document.querySelector(".hero__rail--r");
    const tracker = document.querySelector(".tracker");
    if (heroEl && railL && railR) {
      const heroObs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const inHero = entry.isIntersecting && entry.intersectionRatio > 0.15;
          railL.classList.toggle("is-hidden", !inHero);
          railR.classList.toggle("is-hidden", !inHero);
          if (tracker) tracker.style.right = inHero ? "76px" : "24px";
        });
      }, { threshold: [0, 0.15, 0.3, 0.6, 1] });
      heroObs.observe(heroEl);
    }
  </script>

