---
export const prerender = true;
import Gryphline from "../layouts/Gryphline.astro";
const contactApi = import.meta.env.PUBLIC_CONTACT_API || "";
---
<Gryphline title="contact">
  <section class="gl-shell" style="max-width: 720px;">
    <p class="gl-kicker">signal · establish contact</p>
    <h1 class="gl-h1">contact<em>.</em></h1>
    <p class="gl-lede">
      Portfolio inquiries, collab pitches, "how did you do X" — send a note. This form
      POSTs to a Lambda that validates &amp; stores your message in DynamoDB and forwards
      it via <strong>SES</strong>. Response time: <code>2-4 days</code>.
    </p>

    <form class="gl-panel" id="contact-form" style="display: grid; gap: 22px;">
      <span class="gl-panel__corner gl-panel__corner--tl"></span>
      <span class="gl-panel__corner gl-panel__corner--bl"></span>
      <span class="gl-panel__corner gl-panel__corner--br"></span>

      <input type="text" name="website" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true" />

      <div class="row">
        <label class="fld">
          <span class="fld__label">&gt; name</span>
          <input type="text" name="name" required maxlength="120" autocomplete="name" />
        </label>
        <label class="fld">
          <span class="fld__label">&gt; email</span>
          <input type="email" name="email" required maxlength="200" autocomplete="email" />
        </label>
      </div>

      <label class="fld">
        <span class="fld__label">&gt; subject</span>
        <input type="text" name="subject" maxlength="200" placeholder="collab, hire me, question&hellip;" />
      </label>

      <label class="fld">
        <span class="fld__label">&gt; message</span>
        <textarea name="body" required rows="6" maxlength="4000"></textarea>
      </label>

      <button class="gl-btn gl-btn--primary" type="submit" style="justify-self: start;">
        transmit <span class="gl-btn__arrow">&rarr;</span>
      </button>
      <p class="status" role="status" aria-live="polite"></p>
    </form>
  </section>

  <script is:inline define:vars={{ contactApi }}>
    (function () {
      const form = document.getElementById("contact-form");
      const status = form.querySelector(".status");
      const cta = form.querySelector("button[type=submit]");
      if (!contactApi) {
        status.textContent = "// contact endpoint not configured";
        status.classList.add("is-bad");
        cta.disabled = true;
        return;
      }
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        status.textContent = "";
        status.className = "status";
        cta.disabled = true;
        cta.firstChild.textContent = "transmitting ";
        const data = Object.fromEntries(new FormData(form).entries());
        try {
          const res = await fetch(contactApi, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(data),
          });
          const payload = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(payload.error || "send failed");
          status.textContent = "// signal received. will reply within a few days.";
          status.classList.add("is-ok");
          form.reset();
        } catch (err) {
          status.textContent = "// " + (err.message || "transmission failed");
          status.classList.add("is-bad");
        } finally {
          cta.disabled = false;
          cta.firstChild.textContent = "transmit ";
        }
      });
    })();
  </script>

  <style>
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
    .fld { display: grid; gap: 6px; }
    .fld__label {
      font-family: var(--gl-mono);
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gl-cyan);
    }
    .fld input, .fld textarea {
      font-family: var(--gl-sans);
      font-size: 1rem;
      color: var(--gl-ink);
      background: transparent;
      border: 1px solid var(--gl-line-strong);
      padding: 12px 14px;
      transition: border-color 140ms ease;
    }
    .fld textarea { resize: vertical; min-height: 140px; line-height: 1.5; }
    .fld input:focus, .fld textarea:focus {
      outline: none;
      border-color: var(--gl-cyan);
      box-shadow: 0 0 0 2px var(--gl-cyan-soft);
    }
    .fld input::placeholder, .fld textarea::placeholder {
      color: var(--gl-ink-dim);
      font-style: italic;
    }
    .status {
      font-family: var(--gl-mono);
      font-size: 0.85rem;
      margin: 0;
      color: var(--gl-ink-soft);
    }
    .status.is-ok  { color: var(--gl-green); }
    .status.is-bad { color: var(--gl-red); }

    @media (max-width: 600px) { .row { grid-template-columns: 1fr; } }
  </style>
</Gryphline>
