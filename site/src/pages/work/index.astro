---
export const prerender = true;
import Gryphline from "../../layouts/Gryphline.astro";
---
<Gryphline title="work">
  <section class="gl-shell">
    <p class="gl-kicker">tokyo zero · chromadipity core</p>
    <h1 class="gl-h1">the work<em>.</em></h1>
    <p class="gl-lede">
      Three storefronts, distinct aesthetics, one brand voice. <strong>PSG</strong> for hot-pink
      Panty &amp; Stocking pastiche. <strong>NSO</strong> for CRT / chrome Needy Streamer Overload
      homage. <strong>MISC</strong> for the neutral catalog hub. Design + product photography +
      typography, all mine.
    </p>

    <div class="work-grid">
      <a class="node node--psg" href="/work/psg/">
        <span class="gl-panel__corner gl-panel__corner--tl"></span>
        <span class="gl-panel__corner gl-panel__corner--bl"></span>
        <div class="node__cover">
          <img src="/assets/psg-panty-sticker.webp" alt="Panty" class="node__char node__char--l" />
          <img src="/assets/psg-stocking-sticker.webp" alt="Stocking" class="node__char node__char--r" />
        </div>
        <div class="node__meta">
          <p class="node__id">01 · PSG</p>
          <h3 class="node__name">Panty &amp; Stocking</h3>
          <p class="node__desc">Candy-halftone showcase. 7-item product spread on a tilted cyan slab, pink scallop frill drop, TOKYO ZERO slam-drop intro.</p>
          <span class="gl-tag">enter &rarr;</span>
        </div>
      </a>

      <a class="node node--nso" href="/work/nso/">
        <span class="gl-panel__corner gl-panel__corner--tl"></span>
        <span class="gl-panel__corner gl-panel__corner--bl"></span>
        <div class="node__cover">
          <img src="/assets/nso-ame-sticker.webp" alt="Ame" class="node__char node__char--l" />
          <img src="/assets/nso-kangel-sticker.webp" alt="KAngel" class="node__char node__char--r" />
        </div>
        <div class="node__meta">
          <p class="node__id">02 · NSO</p>
          <h3 class="node__name">Needy Streamer Overload</h3>
          <p class="node__desc">CRT / chrome background, RGB-glitching popup boxes, 3D flip-card product previews. Character sprites for Ame + KAngel.</p>
          <span class="gl-tag gl-tag--amber">enter &rarr;</span>
        </div>
      </a>

      <a class="node node--misc" href="/catalog/">
        <span class="gl-panel__corner gl-panel__corner--tl"></span>
        <span class="gl-panel__corner gl-panel__corner--bl"></span>
        <div class="node__meta">
          <p class="node__id">03 · MISC</p>
          <h3 class="node__name">the catalog</h3>
          <p class="node__desc">Nyalra magazine catalog — 30+ curated products, numbered cards, slate-violet accent. Deskmats · tapestries · prints · stickers · flags.</p>
          <span class="gl-tag gl-tag--green">enter &rarr;</span>
        </div>
      </a>
    </div>
  </section>

  <style>
    .work-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 6vh;
    }
    .node {
      position: relative;
      display: block;
      background: var(--gl-bg-panel);
      border: 1px solid var(--gl-line);
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      transition: transform 180ms ease, border-color 180ms ease;
      clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 0 100%);
    }
    .node:hover { transform: translateY(-4px); border-color: var(--gl-cyan); }
    .node--nso:hover { border-color: var(--gl-amber); }
    .node--misc:hover { border-color: var(--gl-green); }

    .node__cover {
      position: relative;
      aspect-ratio: 5 / 3;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      background: linear-gradient(135deg, rgba(61, 234, 255, 0.05) 0%, rgba(255, 184, 77, 0.03) 100%);
    }
    .node--psg .node__cover { background: linear-gradient(135deg, rgba(255, 77, 166, 0.1) 0%, rgba(61, 234, 255, 0.06) 100%); }
    .node--nso .node__cover { background: linear-gradient(135deg, rgba(255, 184, 77, 0.08) 0%, rgba(253, 122, 192, 0.06) 100%); }

    .node__char {
      position: absolute;
      bottom: -8%;
      height: 92%;
      filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
    }
    .node__char--l { left: -6%; }
    .node__char--r { right: -6%; }

    .node__meta { padding: 20px 22px; }
    .node__id {
      font-family: var(--gl-mono);
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      color: var(--gl-cyan);
      margin: 0 0 8px;
      text-transform: uppercase;
    }
    .node__name {
      font-family: var(--gl-display);
      font-weight: 600;
      font-size: 1.25rem;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      color: var(--gl-ink);
      margin: 0 0 10px;
    }
    .node__desc {
      font-family: var(--gl-sans);
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--gl-ink-soft);
      margin: 0 0 14px;
    }
    @media (max-width: 900px) { .work-grid { grid-template-columns: 1fr; } .node__cover { aspect-ratio: 5 / 2; } }
  </style>
</Gryphline>
