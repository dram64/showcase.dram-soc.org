  <script is:inline>
    const roster = {
      ame:      { name: "Ame",      letters: "AME",      faction: "Off & online",         universe: "Needy Streamer Overload", tag: "NSO", img: "/showcase/roster/ame.webp",      num: "01" },
      kangel:   { name: "K.Angel",  letters: "KANGEL",   faction: "Public-face streamer", universe: "Needy Streamer Overload", tag: "NSO", img: "/showcase/roster/kangel.webp",   num: "02" },
      panty:    { name: "Panty",    letters: "PANTY",    faction: "Anarchy sisters",      universe: "Panty & Stocking",        tag: "PSG", img: "/showcase/roster/panty.webp",    num: "03" },
      stocking: { name: "Stocking", letters: "STOCKING", faction: "Anarchy sisters",      universe: "Panty & Stocking",        tag: "PSG", img: "/showcase/roster/stocking.webp", num: "04" },
      yuzuha:   { name: "Yuzuha",   letters: "YUZUHA",   faction: "Tokyo Zero original",  universe: "Chromadipity Core",       tag: "OC",  img: "/showcase/roster/yuzuha.webp",   num: "05" },
      chii:     { name: "Chii",     letters: "CHII",     faction: "Vtuber commission",    universe: "Independent commission",  tag: "VT",  img: "/showcase/roster/chii.webp",     num: "06" },
    };
    document.querySelectorAll(".portrait[data-key]").forEach(btn => {
      btn.addEventListener("click", () => {
        const r = roster[btn.dataset.key];
        if (!r) return;
        document.querySelectorAll(".portrait").forEach(b => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        const set = (t, v) => { const el = document.querySelector(`[data-target="${t}"]`); if (el) el.textContent = v; };
        set("name", r.name); set("letters", r.letters); set("faction", r.faction); set("universe", r.universe); set("tag", r.tag);
        set("num", r.num + " / 06");  // roster carousel counter (kept — 6 characters)
        const img = document.querySelector('[data-target="img"]'); if (img) img.src = r.img;
      });
    });

    // Tracker — IntersectionObserver highlights the active section + smooth-scroll on click
    const trackerItems = document.querySelectorAll(".tracker__item[data-section]");
    const sectionIds = ["hero", "graphic", "roster", "photo", "catalog"];
    const setActive = (id) => trackerItems.forEach(el => el.classList.toggle("is-active", el.dataset.section === id));
    const io = new IntersectionObserver((entries) => {
      let best = null;
      entries.forEach(e => { if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) best = e; });
      if (best) setActive(best.target.id);
    }, { rootMargin: "-25% 0px -50% 0px", threshold: [0, 0.2, 0.5, 0.8, 1] });
    sectionIds.forEach(id => { const el = document.getElementById(id); if (el) io.observe(el); });
    trackerItems.forEach(item => {
      item.addEventListener("click", (e) => {
        e.preventDefault();
        const target = document.getElementById(item.dataset.section);
        if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    // Rail dark/light transition — dark while hero is in view (matches the
    // hero backdrop), fades to light misc palette once scrolled past.
    (function () {
      const html = document.documentElement;
      const heroEl = document.getElementById("hero");
      if (!heroEl) return;
      html.setAttribute("data-rail", "dark");
      const railObs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          html.setAttribute("data-rail", e.isIntersecting && e.intersectionRatio > 0.2 ? "dark" : "light");
        });
      }, { threshold: [0, 0.2, 0.5, 0.8, 1] });
      railObs.observe(heroEl);
    })();

    // Autoplay-when-visible for editorial motion pieces (graphic-section
     // vertical reel + graphic→roster interlude). Videos paused off-screen
     // to save CPU/battery; resumed only when >20% visible. Respects the
     // user's prefers-reduced-motion setting — videos stay paused if set.
    (function () {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const videos = document.querySelectorAll("#graphic video, .interlude--video video");
      if (!videos.length) return;
      if (reduce) { videos.forEach(v => v.pause()); return; }
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          const v = e.target;
          if (e.isIntersecting && e.intersectionRatio > 0.2) {
            const p = v.play();
            if (p && typeof p.catch === "function") p.catch(() => {});
          } else {
            v.pause();
          }
        });
      }, { threshold: [0, 0.2, 0.6, 1] });
      videos.forEach(v => io.observe(v));
    })();

    // 3D coverflow carousel for the featured product photography section.
    // Auto-advances every 4.5s; click any card, dot, or arrow to control.
    // Center card is bright + forward; side cards angle back at ~35deg with
    // reduced opacity for depth.
    (function () {
      const stage = document.querySelector(".lead-3d__stage");
      if (!stage) return;
      const cards = Array.from(stage.querySelectorAll(".lead-3d__card"));
      const dots  = Array.from(document.querySelectorAll(".lead-3d__dots button[data-goto]"));
      const nav = {
        prev: document.querySelector('.lead-3d__arrow[data-nav="prev"]'),
        next: document.querySelector('.lead-3d__arrow[data-nav="next"]'),
      };
      const products = [
        { name: "Frame 01", label: "flat-lay",     idx: "01",
          specs: [["set","studio · natural light"], ["capture","a7iii · 35mm"], ["process","color · retouch"]] },
        { name: "Frame 02", label: "portrait",     idx: "02",
          specs: [["set","tabletop · softbox"],    ["capture","a7iii · 50mm"], ["process","color · dodge"]] },
        { name: "Frame 03", label: "flat-lay",     idx: "03",
          specs: [["set","overhead · daylight"],   ["capture","a7iii · 35mm"], ["process","color · sharpen"]] },
        { name: "Frame 04", label: "editorial",    idx: "04",
          specs: [["set","studio · rim light"],    ["capture","a7iii · 85mm"], ["process","tone · retouch"]] },
        { name: "Frame 05", label: "lifestyle",    idx: "05",
          specs: [["set","desk build · daylight"], ["capture","a7iii · 35mm"], ["process","color · balance"]] },
        { name: "Frame 06", label: "detail",       idx: "06",
          specs: [["set","macro · softbox"],       ["capture","a7iii · 90mm"], ["process","tone · dodge"]] },
        { name: "Frame 07", label: "editorial",    idx: "07",
          specs: [["set","seamless · softbox"],    ["capture","a7iii · 50mm"], ["process","color · retouch"]] },
        { name: "Frame 08", label: "flat-lay",     idx: "08",
          specs: [["set","overhead · daylight"],   ["capture","a7iii · 35mm"], ["process","color · balance"]] },
        { name: "Frame 09", label: "portrait",     idx: "09",
          specs: [["set","studio · window light"], ["capture","a7iii · 85mm"], ["process","tone · retouch"]] },
        { name: "Frame 10", label: "lifestyle",    idx: "10",
          specs: [["set","desk build · softbox"],  ["capture","a7iii · 35mm"], ["process","color · sharpen"]] },
      ];
      const N = cards.length;
      let current = 0;
      let timer = null;
      const INTERVAL = 4500;

      const paint = () => {
        cards.forEach((card, i) => {
          let diff = i - current;
          if (diff >  N / 2) diff -= N;
          if (diff < -N / 2) diff += N;
          const abs = Math.abs(diff);
          const isCenter = diff === 0;
          const x   = diff * 60;                    // horizontal spread
          const z   = isCenter ? 0 : -180 - abs * 60;
          const rot = -diff * 32;                    // rotate around Y
          const scale = isCenter ? 1 : 0.85 - (abs - 1) * 0.05;
          card.style.transform =
            `translate(-50%, -50%) translateX(${x}%) translateZ(${z}px) rotateY(${rot}deg) scale(${scale})`;
          card.style.zIndex   = String(20 - abs);
          card.style.opacity  = String(abs > 2 ? 0 : abs > 1 ? 0.25 : abs > 0 ? 0.55 : 1);
          card.classList.toggle("is-center", isCenter);
          card.tabIndex = isCenter ? 0 : -1;
        });
        dots.forEach((d, i) => d.classList.toggle("is-active", i === current));
        const p = products[current] || {};
        const setEl = (t, v) => { const el = document.querySelector(`[data-target="${t}"]`); if (el) el.textContent = v; };
        setEl("side-idx",   p.idx);
        setEl("side-label", p.label);
        setEl("side-name",  p.name);
        const specsEl = document.querySelector('[data-target="side-specs"]');
        if (specsEl && p.specs) {
          specsEl.innerHTML = p.specs.map(([k, v]) => `<span><em>${k}</em>${v}</span>`).join("");
        }
      };

      const advance = () => { current = (current + 1) % N; paint(); };
      const back    = () => { current = (current - 1 + N) % N; paint(); };
      const start   = () => { stop(); timer = setInterval(advance, INTERVAL); };
      const stop    = () => { if (timer) { clearInterval(timer); timer = null; } };

      cards.forEach((card, i) => card.addEventListener("click", () => { current = i; paint(); start(); }));
      dots.forEach((dot, i) => dot.addEventListener("click", () => { current = i; paint(); start(); }));
      if (nav.prev) nav.prev.addEventListener("click", () => { back();    start(); });
      if (nav.next) nav.next.addEventListener("click", () => { advance(); start(); });

      document.addEventListener("visibilitychange", () => { if (document.hidden) stop(); else start(); });

      paint();
      start();
    })();

    // Hero carousel — auto-crossfade between NSO and Yuzuha/Alice keyart.
    // Pauses while the tab isn't visible. Click a dot to jump to a slide
    // and reset the auto-timer.
    (function () {
      const slides = Array.from(document.querySelectorAll(".hero__art[data-slide]"));
      const dots   = Array.from(document.querySelectorAll(".hero__dot[data-goto]"));
      if (slides.length < 2) return;
      const INTERVAL_MS = 6500;
      let current = 0;
      let timer   = null;

      const show = (idx) => {
        current = ((idx % slides.length) + slides.length) % slides.length;
        slides.forEach((el, i) => el.classList.toggle("is-active", i === current));
        dots.forEach((el, i)   => el.classList.toggle("is-active", i === current));
      };
      const advance = () => show(current + 1);
      const start = () => { stop(); timer = setInterval(advance, INTERVAL_MS); };
      const stop  = () => { if (timer) { clearInterval(timer); timer = null; } };

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const idx = parseInt(dot.dataset.goto, 10);
          if (!Number.isNaN(idx)) { show(idx); start(); }
        });
      });

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) stop(); else start();
      });

      start();
    })();
  </script>

  <style>
    /* ============================================================
       BASE — kill the shopify padding and full-bleed the hero + boundary
       ============================================================ */
    body.page-index .content-for-layout {
      padding: 0 !important;
      max-width: none !important;
    }
    body.page-index main.content-for-layout {
      padding-left: var(--rails-w) !important;
      padding-right: var(--rails-w) !important;
      box-sizing: border-box;
    }
    /* Hero + strip + boundary divider bleed past the rail padding */
    .hero,
    .hero-strip,
    .section-divider--boundary {
      width: 100vw;
      margin-left: calc((100% - 100vw) / 2);
      max-width: 100vw;
      box-sizing: border-box;
    }
    .misc__grid { max-width: none !important; }

    /* ============================================================
       TRACKER — misc-styled, soft, slate-violet accent
       ============================================================ */
    .tracker {
      position: fixed;
      right: calc(var(--rails-w, 60px) + 14px);
      top: 50%;
      transform: translateY(-50%);
      z-index: 96;
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 10px 8px;
      background: rgba(255, 255, 255, 0.85);
      border: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      backdrop-filter: blur(10px);
    }
    .tracker__item {
      display: grid;
      grid-template-columns: 3px auto 1fr;
      align-items: center;
      gap: 10px;
      padding: 8px 8px 8px 4px;
      color: var(--misc-ink-soft, #6b6b6b);
      text-decoration: none;
      font-family: 'Apex Mk3', 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: lowercase;
      transition: color 180ms ease, background 180ms ease;
    }
    .tracker__bar {
      display: block;
      width: 3px;
      height: 14px;
      background: rgba(0, 0, 0, 0.15);
      transition: background 180ms ease, height 180ms ease;
    }
    .tracker__num { font-weight: 500; color: var(--misc-ink, #14131a); }
    .tracker__lbl {
      max-width: 0;
      overflow: hidden;
      white-space: nowrap;
      opacity: 0;
      transition: max-width 220ms ease, opacity 200ms ease;
    }
    .tracker__item:hover .tracker__lbl,
    .tracker:hover .tracker__item .tracker__lbl,
    .tracker__item.is-active .tracker__lbl {
      max-width: 90px;
      opacity: 1;
    }
    .tracker__item:hover { color: var(--misc-ink, #14131a); }
    .tracker__item:hover .tracker__bar { background: var(--misc-accent, #5061b9); height: 20px; }
    .tracker__item.is-active {
      color: var(--misc-accent, #5061b9);
      background: rgba(80, 97, 185, 0.08);
    }
    .tracker__item.is-active .tracker__bar {
      background: var(--misc-accent, #5061b9);
      height: 22px;
    }
    .tracker__item.is-active .tracker__num { color: var(--misc-accent, #5061b9); }

    @media (max-width: 800px) {
      .tracker {
        top: auto;
        bottom: 12px;
        right: 50%;
        transform: translateX(50%);
        flex-direction: row;
        padding: 8px 10px;
      }
      .tracker__bar, .tracker__lbl { display: none; }
    }

    /* ============================================================
       01 · HERO — NSOHero.png full-viewport backdrop
       ============================================================ */
    .hero {
      position: relative;
      display: block;
      height: 100vh;
      height: 100svh;
      overflow: hidden;
      background: #14131a;
      line-height: 0;
      font-size: 0;
      box-sizing: border-box;
    }
    .hero__art {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      /* Anchor the top of the image to the top of the container so nothing
         above the horizon line ever gets clipped. Cropping (if any due to
         viewport aspect mismatch) happens at the bottom only. */
      object-position: center top;
      display: block;
      pointer-events: none;
      opacity: 0;
      transition: opacity 900ms ease-in-out;
      will-change: opacity;
    }
    .hero__art.is-active { opacity: 1; }

    .hero__dots {
      position: absolute;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 5;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      background: rgba(20, 19, 26, 0.4);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 999px;
    }
    .hero__dot {
      width: 32px;
      height: 6px;
      padding: 0;
      background: rgba(255, 255, 255, 0.35);
      border: none;
      border-radius: 3px;
      cursor: pointer;
      transition: background 260ms ease, width 260ms ease;
    }
    .hero__dot:hover { background: rgba(255, 255, 255, 0.6); }
    .hero__dot.is-active {
      background: #ffee00;
      width: 44px;
    }
    /* Shared CTA button — used by other sections that reference .btn */
    .btn {
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      padding: 14px 26px;
      border: 1px solid var(--misc-ink, #14131a);
      color: var(--misc-ink, #14131a);
      background: transparent;
      text-decoration: none;
      transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .btn:hover { background: var(--misc-ink, #14131a); color: #fff; }
    .btn--primary {
      background: var(--misc-accent, #5061b9);
      color: #fff;
      border-color: var(--misc-accent, #5061b9);
    }
    .btn--primary:hover { background: var(--misc-ink, #14131a); border-color: var(--misc-ink, #14131a); }

    /* ============================================================
       POST-HERO STRIP — soft
       ============================================================ */
    .hero-strip {
      background: rgba(80, 97, 185, 0.05);
      color: var(--misc-ink-soft, #6b6b6b);
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      border-bottom: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      padding: 14px clamp(80px, 8vw, 120px);
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.85rem;
      display: flex;
      justify-content: center;
      gap: clamp(20px, 4vw, 48px);
      flex-wrap: wrap;
    }
    .hero-strip em {
      font-style: normal;
      font-family: 'Apex Mk3', 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
      margin-right: 10px;
    }
    .hero-strip a { color: var(--misc-accent, #5061b9); text-decoration: none; border-bottom: 1px solid currentColor; }

    /* ============================================================
       SECTION DIVIDERS — thin hairline with small caps text
       ============================================================ */
    .section-divider {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 16px clamp(80px, 8vw, 120px);
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      border-bottom: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      background: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
    }
    .section-divider__num {
      color: var(--misc-accent, #5061b9);
      font-weight: 500;
    }
    .section-divider__label { flex: 1; }
    .section-divider__mark {
      display: inline-block;
      width: 32px;
      height: 2px;
      background: var(--misc-accent, #5061b9);
    }

    /* ============================================================
       SHARED — section shell (used by sec02 through sec06).
       Sections fill the full space between rails (main padding = --rails-w)
       with a small internal breathing gutter so content doesn't touch
       the rail edges.
       ============================================================ */
    .sec {
      padding: clamp(60px, 8vw, 100px) clamp(24px, 4vw, 64px);
      max-width: none;
      width: 100%;
      margin: 0 auto;
      box-sizing: border-box;
    }
    .sec__head { margin-bottom: 5vh; max-width: 820px; }
    .sec__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0 0 12px;
    }
    .sec__eyebrow {
      font-family: 'Beam Visionary', cursive;
      font-size: clamp(1.1rem, 1.6vw, 1.4rem);
      color: var(--misc-accent, #5061b9);
      margin: 0 0 8px;
      line-height: 1;
    }
    .sec__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(2rem, 4vw, 2.8rem);
      line-height: 1;
      color: var(--misc-ink, #1a1a1a);
      text-transform: lowercase;
      margin: 0 0 20px;
      letter-spacing: -0.01em;
    }
    .sec__lede {
      font-family: 'Branding Pro', sans-serif;
      font-size: 1rem;
      line-height: 1.55;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
      max-width: 620px;
    }
    .sec-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.10));
      gap: 20px;
      flex-wrap: wrap;
    }
    .sec-foot__meta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
    }
    .pager { display: inline-flex; align-items: center; gap: 14px; }
    .pager button {
      width: 38px; height: 38px;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      background: transparent;
      color: var(--misc-ink, #14131a);
      cursor: pointer;
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
      transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .pager button:hover { background: var(--misc-accent, #5061b9); color: #fff; border-color: var(--misc-accent, #5061b9); }
    .pager__nums {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.82rem;
      letter-spacing: 0.14em;
      color: var(--misc-ink, #14131a);
    }

    /* ============================================================
       GRAPHIC DESIGN
       ============================================================ */
    .sec-tabs {
      display: flex;
      gap: 20px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      margin-bottom: 32px;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      overflow-x: auto;
    }
    .sec-tab {
      color: var(--misc-ink-soft, #6b6b6b);
      text-decoration: none;
      padding-bottom: 4px;
      border-bottom: 1px solid transparent;
      transition: color 140ms ease, border-color 140ms ease;
      cursor: pointer;
      white-space: nowrap;
    }
    .sec-tab:hover { color: var(--misc-ink, #14131a); }
    .sec-tab.is-active {
      color: var(--misc-ink, #14131a);
      border-bottom-color: var(--misc-accent, #5061b9);
    }
    .graphic-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 60px;
      gap: 32px;
    }
    .graphic-vrail {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 40px;
    }
    .graphic-vrail span {
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-family: 'Apex Mk3', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
      white-space: nowrap;
    }
    .graphic-stage { position: relative; }
    .graphic-caption {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.88rem;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 16px 0 0;
      font-style: italic;
    }
    /* Legacy single-slot (unused now; kept for safety) */
    .graphic-slot {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding: 60px;
      min-height: 460px;
      background: #fff;
      border: 1px dashed rgba(80, 97, 185, 0.4);
    }

    /* ============================================================
       Cinema editorial board (dark) — .gd-board container
       ============================================================ */
    #graphic {
      padding-top: clamp(40px, 5vw, 72px);
      padding-bottom: clamp(40px, 5vw, 72px);
    }
    .gd-board {
      display: flex;
      flex-direction: column;
      gap: clamp(12px, 1.6vw, 22px);
      padding: clamp(6px, 1vw, 12px) 0;
    }
    /* Masonry — packs cells shortest-column-first so no white space is
       left between images within a column. Column-order visually, but
       every cell keeps its native aspect ratio (--ar). */
    .gd-mason {
      columns: 3;
      column-gap: clamp(10px, 1.2vw, 16px);
      break-inside: avoid;
    }
    .gd-mason .gd-cell {
      break-inside: avoid;
      -webkit-column-break-inside: avoid;
      page-break-inside: avoid;
      margin: 0 0 clamp(10px, 1.2vw, 16px) 0;
      width: 100%;
      display: block;
    }
    @media (max-width: 900px) { .gd-mason { columns: 2; } }
    @media (max-width: 560px) { .gd-mason { columns: 1; } }

    /* ============================================================
       Six presentation variants — shared frame
       ============================================================ */
    .gd-board--variants { gap: 0; padding: 0; }
    .gd-variant {
      position: relative;
      width: 100vw;
      margin-left: calc((100% - 100vw) / 2);
      max-width: 100vw;
      box-sizing: border-box;
      padding: clamp(48px, 6vw, 88px) clamp(24px, 5vw, 96px);
      overflow: hidden;
    }
    .gd-variant__label {
      display: grid;
      grid-template-columns: auto auto 1fr;
      align-items: baseline;
      gap: clamp(12px, 2vw, 28px);
      margin-bottom: clamp(24px, 3vw, 48px);
      padding-bottom: 14px;
      border-bottom: 1px solid currentColor;
      opacity: 0.92;
    }
    .gd-variant__num {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(2.6rem, 4vw, 4rem);
      line-height: 0.85;
      letter-spacing: -0.03em;
      opacity: 0.62;
    }
    .gd-variant__name {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(1.4rem, 2.2vw, 2rem);
      line-height: 1;
      letter-spacing: -0.01em;
      text-transform: lowercase;
      margin: 0;
    }
    .gd-variant__desc {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
      opacity: 0.6;
      align-self: end;
      padding-bottom: 4px;
      text-align: right;
    }
    @media (max-width: 700px) {
      .gd-variant__label { grid-template-columns: auto 1fr; }
      .gd-variant__desc { grid-column: 1 / -1; text-align: left; }
    }

    /* ============================================================
       01 · KINETIC BLUEPRINT
       ============================================================ */
    .gd-variant--blueprint {
      background:
        linear-gradient(to right,  rgba(20, 40, 100, 0.09) 1px, transparent 1px) 0 0 / 40px 40px,
        linear-gradient(to bottom, rgba(20, 40, 100, 0.09) 1px, transparent 1px) 0 0 / 40px 40px,
        linear-gradient(to right,  rgba(20, 40, 100, 0.04) 1px, transparent 1px) 0 0 / 8px 8px,
        linear-gradient(to bottom, rgba(20, 40, 100, 0.04) 1px, transparent 1px) 0 0 / 8px 8px,
        #eef2f8;
      color: #14264a;
    }
    .gd-variant--blueprint .gd-variant__num,
    .gd-variant--blueprint .gd-variant__name,
    .gd-variant--blueprint .gd-variant__desc { color: #14264a; }
    .bp-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: clamp(56px, 6vw, 112px);
      align-items: end;
      padding: 40px 30px 30px;
    }
    .bp-sheet {
      position: relative;
      margin: 0;
      aspect-ratio: var(--ar, 1);
      background: #fff;
      border: 1px solid #14264a;
      box-shadow: 5px 5px 0 rgba(20, 40, 100, 0.14);
    }
    .bp-sheet img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .bp-name {
      position: absolute;
      top: -24px;
      left: 0;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.16em;
      color: #14264a;
      text-transform: lowercase;
    }
    .bp-dim {
      position: absolute;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      color: #14264a;
      background: #eef2f8;
      padding: 2px 8px;
      border: 1px solid #14264a;
      white-space: nowrap;
      z-index: 2;
    }
    .bp-dim--w {
      bottom: -14px;
      left: 50%;
      transform: translateX(-50%);
    }
    .bp-dim--h {
      top: 50%;
      right: -14px;
      transform: translate(50%, -50%) rotate(90deg);
      transform-origin: center;
    }
    @media (max-width: 900px) {
      .bp-grid { grid-template-columns: 1fr; gap: 60px; }
      .bp-dim--h { display: none; }
    }

    /* ============================================================
       02 · CONTACT-SHEET LIGHTBOX
       ============================================================ */
    .gd-variant--lightbox {
      background: radial-gradient(ellipse at center, #201d17 0%, #0d0b08 100%);
      color: #d9c9a8;
    }
    .gd-variant--lightbox .gd-variant__num,
    .gd-variant--lightbox .gd-variant__name,
    .gd-variant--lightbox .gd-variant__desc { color: #d9c9a8; }
    .lb-table {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: clamp(24px, 3vw, 44px);
      align-items: end;
      padding: clamp(24px, 4vw, 56px) 0;
      background:
        radial-gradient(ellipse at 50% 100%, rgba(255, 210, 130, 0.14) 0%, transparent 70%);
    }
    .lb-slide { position: relative; margin: 0; }
    .lb-slide__mount {
      position: relative;
      padding: clamp(12px, 1.4vw, 18px);
      background: #f4efe4;
      border: 1px solid rgba(0, 0, 0, 0.30);
      box-shadow:
        inset 0 0 0 1px #d3c8a8,
        0 14px 44px rgba(255, 220, 150, 0.28);
      aspect-ratio: var(--ar, 1);
      overflow: hidden;
      transition: box-shadow 260ms ease, transform 260ms ease;
    }
    .lb-slide__mount::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(255, 235, 180, 0.35) 0%, transparent 70%);
      z-index: 1;
      pointer-events: none;
      mix-blend-mode: soft-light;
    }
    .lb-slide__mount img {
      position: relative;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: brightness(0.96) saturate(1.05);
      z-index: 0;
    }
    .lb-slide:hover .lb-slide__mount {
      transform: translateY(-6px) scale(1.03);
      box-shadow:
        inset 0 0 0 1px #d3c8a8,
        0 24px 68px rgba(255, 220, 150, 0.48);
    }
    .lb-slide figcaption {
      display: block;
      margin-top: 14px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
      color: #b8a884;
    }
    .lb-slide__idx {
      display: block;
      color: #ffd07a;
      margin-bottom: 4px;
    }
    @media (max-width: 900px) { .lb-table { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .lb-table { grid-template-columns: 1fr; } }

    /* ============================================================
       03 · TERMINAL / CLI
       ============================================================ */
    .gd-variant--terminal {
      background: #0a0a0a;
      color: #ffb648;
    }
    .gd-variant--terminal .gd-variant__num,
    .gd-variant--terminal .gd-variant__name,
    .gd-variant--terminal .gd-variant__desc { color: #ffb648; }
    .cli-win {
      border: 1px solid #2a2a2a;
      background: #050505;
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
      max-width: 1080px;
      margin: 0 auto;
    }
    .cli-win__bar {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 14px;
      background: #101010;
      border-bottom: 1px solid #2a2a2a;
    }
    .cli-win__dot { width: 12px; height: 12px; border-radius: 50%; }
    .cli-win__dot--r { background: #ff5f56; }
    .cli-win__dot--y { background: #ffbd2e; }
    .cli-win__dot--g { background: #27c93f; }
    .cli-win__title {
      flex: 1;
      text-align: center;
      color: #666;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.10em;
      padding-right: 60px;
    }
    .cli-win__body {
      padding: clamp(20px, 3vw, 40px);
      background:
        linear-gradient(rgba(255, 255, 255, 0.02) 50%, transparent 50%) 0 0 / 100% 3px,
        #050505;
      min-height: 400px;
      font-family: 'JetBrains Mono', monospace;
    }
    .cli-line {
      font-size: 0.9rem;
      color: #b0a888;
      margin: 20px 0 14px;
      line-height: 1.6;
    }
    .cli-prompt { color: #7ccf67; }
    .cli-sep { color: #666; margin: 0 8px 0 0; }
    .cli-frame {
      margin: 0 0 20px;
      padding: 0;
      aspect-ratio: var(--ar, 1);
      border: 1px solid #2a2a2a;
      overflow: hidden;
      background: #0a0a0a;
      max-width: 900px;
    }
    .cli-frame img,
    .cli-frame video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: saturate(0.96);
    }
    .cli-cursor {
      display: inline-block;
      width: 9px;
      height: 1.1em;
      background: #ffb648;
      vertical-align: -3px;
      animation: cliBlink 1s steps(1) infinite;
    }
    @keyframes cliBlink { 50% { opacity: 0; } }

    /* ============================================================
       04 · MUSEUM WALL
       ============================================================ */
    .gd-variant--museum {
      background:
        radial-gradient(ellipse at 50% -10%, rgba(255, 244, 220, 0.85) 0%, transparent 60%),
        #efe9df;
      color: #2c261e;
    }
    .gd-variant--museum .gd-variant__num,
    .gd-variant--museum .gd-variant__name,
    .gd-variant--museum .gd-variant__desc { color: #2c261e; }
    .mw-hang {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(48px, 5vw, 96px);
      align-items: start;
      padding: clamp(20px, 3vw, 40px) 0;
    }
    .mw-piece {
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 26px;
    }
    .mw-mat {
      position: relative;
      padding: clamp(20px, 3vw, 44px);
      background: #fbf7ee;
      border: 1px solid rgba(60, 45, 20, 0.15);
      box-shadow:
        0 30px 50px -20px rgba(60, 45, 20, 0.25),
        0 8px 16px -8px rgba(60, 45, 20, 0.20);
      transition: transform 320ms ease, box-shadow 320ms ease;
      aspect-ratio: var(--ar, 1);
      width: 100%;
      overflow: hidden;
    }
    .mw-mat::before {
      content: "";
      position: absolute;
      inset: clamp(10px, 1.5vw, 22px);
      border: 1px solid rgba(60, 45, 20, 0.28);
      pointer-events: none;
    }
    .mw-mat img {
      position: relative;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .mw-piece:hover .mw-mat {
      transform: translateY(-4px);
      box-shadow:
        0 40px 60px -20px rgba(60, 45, 20, 0.35),
        0 12px 20px -8px rgba(60, 45, 20, 0.25);
    }
    .mw-plaque {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      text-align: center;
      max-width: 320px;
    }
    .mw-plaque__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 400;
      font-size: 1.05rem;
      color: #2c261e;
      letter-spacing: 0.01em;
    }
    .mw-plaque__title em {
      font-style: italic;
      font-weight: 300;
      color: #5a4b32;
    }
    .mw-plaque__meta,
    .mw-plaque__credit {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      color: #706250;
      text-transform: lowercase;
    }
    @media (max-width: 900px) { .mw-hang { grid-template-columns: 1fr; } }

    /* ============================================================
       05 · EDITORIAL MAGAZINE SPREAD
       ============================================================ */
    .gd-variant--editorial {
      background: #faf8f2;
      color: #1a1815;
    }
    .gd-variant--editorial .gd-variant__num,
    .gd-variant--editorial .gd-variant__name,
    .gd-variant--editorial .gd-variant__desc { color: #1a1815; }
    .em-spread {
      position: relative;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(32px, 4vw, 72px);
      padding: 40px clamp(0px, 2vw, 40px) 0;
      min-height: 620px;
    }
    .em-folio {
      position: absolute;
      top: 4px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(26, 24, 21, 0.55);
    }
    .em-folio--l { left: 0; }
    .em-folio--r { right: 0; }
    .em-crease {
      position: absolute;
      top: 0; bottom: 0;
      left: 50%;
      width: 1px;
      background: linear-gradient(180deg,
        transparent 0%,
        rgba(26, 24, 21, 0.12) 20%,
        rgba(26, 24, 21, 0.32) 50%,
        rgba(26, 24, 21, 0.12) 80%,
        transparent 100%);
      transform: translateX(-50%);
      pointer-events: none;
    }
    .em-page {
      display: flex;
      flex-direction: column;
      gap: clamp(20px, 2.6vw, 36px);
    }
    .em-kicker {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: #7a6a40;
      margin: 0;
    }
    .em-kicker--r { text-align: right; }
    .em-quote {
      font-family: 'Beam Visionary', serif;
      font-style: italic;
      font-size: clamp(2rem, 3.4vw, 3.4rem);
      line-height: 1.05;
      color: #1a1815;
      margin: 0;
      letter-spacing: -0.01em;
    }
    .em-fig { margin: 0; }
    .em-fig img {
      width: 100%;
      aspect-ratio: var(--ar, 1);
      object-fit: cover;
      display: block;
      border-radius: 1px;
    }
    .em-fig figcaption {
      margin-top: 12px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.14em;
      color: #7a6a40;
      text-transform: lowercase;
    }
    .em-fig figcaption em {
      font-family: 'Beam Visionary', serif;
      font-style: italic;
      color: #1a1815;
      margin-right: 6px;
      font-size: 0.92rem;
      letter-spacing: 0;
      text-transform: none;
    }
    @media (max-width: 900px) {
      .em-spread { grid-template-columns: 1fr; min-height: 0; }
      .em-crease { display: none; }
    }

    /* ============================================================
       06 · CONSTELLATION NETWORK
       ============================================================ */
    .gd-variant--constellation {
      background:
        radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.04) 0%, transparent 40%),
        radial-gradient(circle at 70% 80%, rgba(80, 97, 185, 0.12) 0%, transparent 50%),
        #05050a;
      color: #d0d4e2;
    }
    .gd-variant--constellation .gd-variant__num,
    .gd-variant--constellation .gd-variant__name,
    .gd-variant--constellation .gd-variant__desc { color: #d0d4e2; }
    .cn-space {
      position: relative;
      aspect-ratio: 16 / 9;
      min-height: 520px;
      max-height: 720px;
    }
    .cn-edges {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }
    .cn-edge {
      stroke: rgba(255, 255, 255, 0.22);
      stroke-width: 0.18;
      fill: none;
      vector-effect: non-scaling-stroke;
      stroke-dasharray: 2 2.5;
      animation: cnFlow 12s linear infinite;
    }
    @keyframes cnFlow {
      from { stroke-dashoffset: 0; }
      to   { stroke-dashoffset: -22; }
    }
    .cn-node {
      position: absolute;
      margin: 0;
      aspect-ratio: var(--ar, 1);
      width: clamp(90px, 12vw, 160px);
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.15);
      background: #0a0a0a;
      transition: transform 400ms cubic-bezier(0.34, 1.2, 0.64, 1),
                  border-color 260ms ease,
                  box-shadow 400ms ease;
    }
    .cn-node img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .cn-node__tag {
      position: absolute;
      bottom: 6px;
      left: 6px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.56rem;
      letter-spacing: 0.16em;
      color: #fff;
      background: rgba(0, 0, 0, 0.7);
      padding: 3px 6px;
      text-transform: lowercase;
      pointer-events: none;
    }
    .cn-node:hover {
      transform: translate(-50%, -50%) scale(1.12);
      border-color: #ffee00;
      box-shadow: 0 0 44px rgba(255, 238, 0, 0.4);
      z-index: 5;
    }
    /* Absolute node positions in the SVG viewBox — match the edge coords */
    .cn-node--a { top: 30%; left: 18%; transform: translate(-50%, -50%); }
    .cn-node--b { top: 52%; left: 48%; transform: translate(-50%, -50%); }
    .cn-node--c { top: 28%; left: 82%; transform: translate(-50%, -50%); }
    .cn-node--d { top: 80%; left: 34%; transform: translate(-50%, -50%); }
    .cn-node--e { top: 78%; left: 72%; transform: translate(-50%, -50%); }
    .cn-node--f { top: 62%; left: 15%; transform: translate(-50%, -50%); }
    @media (max-width: 900px) {
      .cn-space { aspect-ratio: 3 / 4; min-height: 720px; }
      .cn-node { width: clamp(70px, 22vw, 120px); }
    }

    /* Editorial marks — mono pills that thread through the spread */
    .gd-mark {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 5px 14px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      align-self: flex-start;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: lowercase;
      color: rgba(255, 255, 255, 0.72);
      white-space: nowrap;
      overflow-x: auto;
      max-width: 100%;
    }
    .gd-mark--head,
    .gd-mark--foot {
      background: rgba(255, 238, 0, 0.06);
      border-color: rgba(255, 238, 0, 0.28);
      color: #ffee00;
    }
    .gd-mark__dot {
      width: 8px; height: 8px;
      background: #ffee00;
      border-radius: 50%;
      box-shadow: 0 0 12px rgba(255, 238, 0, 0.55);
      animation: gdMarkPulse 2.2s ease-in-out infinite;
    }
    .gd-mark__sep { color: rgba(255, 255, 255, 0.24); }
    @keyframes gdMarkPulse {
      0%, 100% { opacity: 0.65; }
      50%      { opacity: 1;    box-shadow: 0 0 18px rgba(255, 238, 0, 0.8); }
    }

    /* Rows */
    .gd-row {
      display: grid;
      gap: clamp(12px, 1.4vw, 22px);
      align-items: start;
    }
    .gd-row--hero { grid-template-columns: 1fr; }
    .gd-row--3    { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr); }
    .gd-row--4    { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .gd-row--2    { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
    /* Rows where mixed aspect ratios should align at their bottom edge */
    .gd-row--baseline { align-items: end; }
    /* Narrow-middle 3-col — for accents that shouldn't dominate their neighbors */
    .gd-row--sm-mid.gd-row--3 {
      grid-template-columns: minmax(0, 1.5fr) minmax(0, 0.55fr) minmax(0, 1.5fr);
    }
    /* Slim row — constrained max-width, centered. Use for tall banner
       pairs so they don't render at full section width. */
    .gd-row--slim {
      max-width: 72%;
      margin-left: auto;
      margin-right: auto;
    }
    @media (max-width: 900px) {
      .gd-row--slim { max-width: 100%; }
    }

    /* Cells — every one uses native aspect-ratio (--ar) */
    .gd-cell {
      position: relative;
      margin: 0;
      aspect-ratio: var(--ar, 1);
      overflow: hidden;
      background: #0a0913;
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: transform 340ms cubic-bezier(0.34, 1.20, 0.64, 1),
                  border-color 220ms ease,
                  box-shadow 340ms ease;
    }
    .gd-cell:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 238, 0, 0.7);
      box-shadow: 0 26px 48px -22px rgba(0, 0, 0, 0.6);
    }
    .gd-cell img,
    .gd-cell video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }
    /* Blueprint numeral top-left — big, light-weight, translucent */
    .gd-cell::before {
      content: attr(data-idx);
      position: absolute;
      top: 10px;
      left: 14px;
      z-index: 3;
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(1.6rem, 2.4vw, 2.6rem);
      line-height: 0.85;
      color: rgba(255, 255, 255, 0.78);
      text-shadow: 0 2px 14px rgba(0, 0, 0, 0.65);
      letter-spacing: -0.04em;
      pointer-events: none;
    }
    /* Metadata caption — reveals on hover from the bottom */
    .gd-cell::after {
      content: attr(data-name) " · " attr(data-ratio) " · " attr(data-dim);
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 3;
      padding: 10px 14px 10px 14px;
      background: linear-gradient(180deg, transparent 0%, rgba(20, 19, 26, 0.82) 100%);
      color: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
      text-align: right;
      opacity: 0;
      transform: translateY(6px);
      transition: opacity 260ms ease, transform 260ms ease;
      pointer-events: none;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .gd-cell:hover::after { opacity: 1; transform: translateY(0); }

    /* Video cell — small yellow "playing" pulse */
    .gd-cell--video .gd-cell__pulse {
      position: absolute;
      top: 14px;
      right: 16px;
      width: 8px;
      height: 8px;
      background: #ffee00;
      border-radius: 50%;
      z-index: 3;
      animation: gdPulse 1.6s ease-in-out infinite;
      pointer-events: none;
    }
    @keyframes gdPulse {
      0%, 100% { opacity: 0.55; transform: scale(0.9); box-shadow: 0 0 0 0 rgba(255, 238, 0, 0.55); }
      50%      { opacity: 1;    transform: scale(1.1); box-shadow: 0 0 0 8px rgba(255, 238, 0, 0); }
    }

    /* Responsive collapse */
    @media (max-width: 900px) {
      .graphic-grid { grid-template-columns: 1fr; }
      .graphic-vrail { display: none; }
      .gd-row--3, .gd-row--4 { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 560px) {
      .gd-row--3, .gd-row--4, .gd-row--2 { grid-template-columns: 1fr; }
    }

    /* ============================================================
       Interlude — full-bleed editorial cut (video or still)
       ============================================================ */
    .interlude {
      position: relative;
      margin: clamp(28px, 4vw, 56px) 0;
      width: 100vw;
      margin-left: calc((100% - 100vw) / 2);
      max-width: 100vw;
      box-sizing: border-box;
      background: #14131a;
      overflow: hidden;
      display: block;
    }
    .interlude img,
    .interlude video {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
    }
    .interlude figcaption {
      position: absolute;
      right: clamp(20px, 3vw, 44px);
      bottom: clamp(16px, 2vw, 28px);
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 6px 12px;
      background: rgba(20, 19, 26, 0.55);
      color: #fff;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
    }
    .interlude__lbl { opacity: 0.9; }
    .interlude__ratio {
      color: #ffee00;
      letter-spacing: 0.22em;
      border-left: 1px solid rgba(255,255,255,0.28);
      padding-left: 12px;
    }
    /* Motion badge on video interludes */
    .interlude--video::before {
      content: "";
      position: absolute;
      top: clamp(16px, 2vw, 28px);
      left: clamp(20px, 3vw, 44px);
      width: 10px;
      height: 10px;
      background: #ffee00;
      border-radius: 50%;
      z-index: 2;
      animation: gdPulse 1.6s ease-in-out infinite;
    }
    @media (max-width: 600px) {
      .interlude figcaption { font-size: 0.58rem; padding: 4px 8px; }
      .interlude__ratio { padding-left: 8px; }
    }

    /* ============================================================
       ROSTER (character showcase)
       ============================================================ */
    .roster-body {
      display: grid;
      grid-template-columns: 100px minmax(0, 1fr);
      gap: 40px;
      position: relative;
    }
    .roster-rail {
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: center;
    }
    .portrait {
      display: block;
      width: 72px;
      height: 72px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid var(--misc-line, rgba(0,0,0,0.15));
      background: #fff;
      cursor: pointer;
      padding: 0;
      transition: border-color 180ms ease, transform 180ms ease;
    }
    .portrait img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
    .portrait:hover { transform: scale(1.05); }
    .portrait.is-active {
      border-color: var(--misc-accent, #5061b9);
      box-shadow: 0 0 0 4px rgba(80, 97, 185, 0.15);
    }
    .roster-all {
      margin-top: 16px;
      padding: 8px 12px;
      color: var(--misc-ink, #14131a);
      text-decoration: none;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
      border: 1px solid var(--misc-ink, #14131a);
      transition: background 140ms ease, color 140ms ease;
    }
    .roster-all:hover { background: var(--misc-ink, #14131a); color: #fff; }

    .roster-stage {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
      gap: 40px;
      align-items: start;
    }
    .roster-block {
      position: absolute;
      top: 4%;
      right: 30%;
      width: 55%;
      height: 92%;
      max-width: 620px;
      background: rgba(80, 97, 185, 0.06);
      z-index: 0;
    }
    .roster-letters {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(6rem, 18vw, 16rem);
      letter-spacing: -0.03em;
      color: rgba(80, 97, 185, 0.06);
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
      white-space: nowrap;
      text-transform: uppercase;
    }
    .roster-hero { position: relative; z-index: 2; }
    .roster-img {
      display: block;
      width: 100%;
      max-width: 520px;
      height: auto;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
    }
    .roster-card {
      position: relative;
      z-index: 2;
      padding: 28px 24px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
    }
    .roster-card__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 8px;
    }
    .roster-card__name {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(1.6rem, 2.5vw, 2rem);
      line-height: 1;
      color: var(--misc-ink, #14131a);
      margin: 0 0 16px;
      text-transform: lowercase;
    }
    .roster-card__rule {
      height: 1px;
      background: var(--misc-line, rgba(0,0,0,0.14));
      margin-bottom: 16px;
      position: relative;
    }
    .roster-card__rule::after {
      content: "";
      position: absolute;
      left: 0; top: 0;
      width: 48px;
      height: 2px;
      background: var(--misc-accent, #5061b9);
    }
    .roster-card__dl {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 8px 20px;
      margin: 0 0 16px;
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.9rem;
    }
    .roster-card__dl dt {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
      align-self: center;
    }
    .roster-card__dl dd { margin: 0; color: var(--misc-ink, #14131a); }
    .roster-card__desc {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.88rem;
      line-height: 1.55;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
    }
    @media (max-width: 900px) {
      .roster-body { grid-template-columns: 1fr; }
      .roster-rail { flex-direction: row; flex-wrap: wrap; }
      .roster-stage { grid-template-columns: 1fr; }
      .roster-block { display: none; }
      .roster-letters { font-size: 10rem; }
    }

    /* ============================================================
       CATALOG
       ============================================================ */
    .catalog-grid { grid-template-columns: repeat(4, 1fr) !important; gap: 5vh 3vw !important; }
    @media (max-width: 900px) { .catalog-grid { grid-template-columns: repeat(2, 1fr) !important; } }

    /* ============================================================
       THEMED ROOMS
       ============================================================ */
    .rooms {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .room {
      position: relative;
      display: block;
      min-height: 480px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      transition: transform 220ms ease, border-color 220ms ease;
    }
    .room:hover { transform: translateY(-4px); border-color: var(--misc-accent, #5061b9); }
    .room--psg { background: linear-gradient(150deg, #ffe0eb 0%, #fff4fa 60%, #d6f8ff 100%); }
    .room--nso { background: linear-gradient(150deg, #e0e6ff 0%, #f6f2ff 60%, #ffe0f4 100%); }
    .room__meta-top {
      position: absolute;
      top: 16px;
      left: 16px;
      right: 16px;
      z-index: 3;
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }
    .room__tag, .room__live {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 3px 8px;
      background: rgba(255, 255, 255, 0.85);
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      color: var(--misc-ink, #14131a);
    }
    .room__live { color: var(--misc-accent, #5061b9); }
    .room__chars { position: absolute; bottom: 0; left: 0; right: 0; height: 65%; pointer-events: none; z-index: 1; }
    .room__char {
      position: absolute;
      bottom: -8%;
      height: 110%;
      width: auto;
      max-width: 60%;
      object-fit: contain;
      object-position: bottom center;
      filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.12));
      transition: transform 320ms ease;
    }
    .room__char--l { left: -6%; }
    .room__char--r { right: -6%; }
    .room:hover .room__char--l { transform: translate(-3px, -6px) rotate(-1deg); }
    .room:hover .room__char--r { transform: translate(3px, -6px) rotate(1deg); }
    .room__title-wrap {
      position: relative;
      z-index: 2;
      padding: 56px 28px 0;
      text-align: center;
    }
    .room__eyebrow {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: lowercase;
      color: var(--misc-ink-soft, #6b6b6b);
      margin-bottom: 6px;
    }
    .room__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(3.4rem, 8vw, 6rem);
      line-height: 0.95;
      color: var(--misc-ink, #14131a);
      margin: 0 0 8px;
      text-transform: lowercase;
    }
    .room__sub {
      font-family: 'Beam Visionary', cursive;
      font-size: clamp(1rem, 1.6vw, 1.4rem);
      color: var(--misc-accent, #5061b9);
      margin: 0;
    }
    .room__foot {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      z-index: 3;
      padding: 16px 20px;
      background: linear-gradient(to top, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.4) 80%, transparent 100%);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .room__enter {
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      color: var(--misc-accent, #5061b9);
    }
    .room__specs {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--misc-ink-soft, #6b6b6b);
    }
    @media (max-width: 900px) { .rooms { grid-template-columns: 1fr; } }

    /* ============================================================
       PRODUCT PHOTOGRAPHY + PATHS
       ============================================================ */
    .prod-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 60px;
    }
    .prod {
      margin: 0;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      overflow: hidden;
      transition: transform 200ms ease, border-color 200ms ease;
      display: flex;
      flex-direction: column;
    }
    .prod:hover { transform: translateY(-3px); border-color: var(--misc-accent, #5061b9); }
    .prod__img {
      background: #f7f6f2;
      aspect-ratio: 4/5;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .prod__img img { max-width: 100%; max-height: 100%; object-fit: contain; }
    .prod figcaption {
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.10));
    }
    .prod__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
    }
    .prod__name {
      font-family: 'Apex Mk3', sans-serif;
      font-size: 1.05rem;
      color: var(--misc-ink, #14131a);
    }
    .prod__spec {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.78rem;
      color: var(--misc-ink-soft, #6b6b6b);
      line-height: 1.4;
    }
    .paths {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .path {
      display: block;
      padding: 24px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      text-decoration: none;
      color: inherit;
      transition: border-color 180ms ease, transform 180ms ease;
    }
    .path:hover { border-color: var(--misc-accent, #5061b9); transform: translateY(-2px); }
    .path__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 12px;
    }
    .path__title {
      font-family: 'Apex Mk3', sans-serif;
      font-size: 1.2rem;
      color: var(--misc-ink, #14131a);
      margin: 0 0 8px;
      font-weight: 400;
      text-transform: lowercase;
    }
    .path__desc {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.9rem;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
      line-height: 1.5;
    }
    @media (max-width: 900px) {
      .prod-grid { grid-template-columns: repeat(2, 1fr); }
      .paths { grid-template-columns: 1fr; }
    }

    /* =========================================================================
       ENHANCEMENTS — Illustration + Roster + Editorial Photography + Themes mini
       ========================================================================= */

    #roster {
      background:
        radial-gradient(circle at 8% 12%, rgba(80, 97, 185, 0.05) 0%, transparent 45%),
        radial-gradient(circle at 92% 88%, rgba(255, 129, 176, 0.045) 0%, transparent 50%),
        var(--misc-bg, #fdfcf9);
      position: relative;
      overflow: hidden;
    }
    /* Cinema editorial dark mode — graphic section only */
    #graphic {
      background:
        radial-gradient(circle at 8% 12%, rgba(80, 97, 185, 0.18) 0%, transparent 45%),
        radial-gradient(circle at 92% 88%, rgba(255, 129, 176, 0.08) 0%, transparent 50%),
        linear-gradient(180deg, #0d0c13 0%, #14131a 100%);
      color: #f5f4f0;
      position: relative;
      overflow: hidden;
    }
    #graphic .sec__num       { color: rgba(255, 255, 255, 0.55); }
    #graphic .sec__eyebrow   { color: #ffee00; }
    #graphic .sec__title     { color: #fff; }
    #graphic .sec__lede      { color: rgba(255, 255, 255, 0.72); }
    #graphic .sec-tabs       { border-bottom-color: rgba(255, 255, 255, 0.12); }
    #graphic .sec-tab        { color: rgba(255, 255, 255, 0.55); }
    #graphic .sec-tab:hover  { color: #fff; }
    #graphic .sec-tab.is-active { color: #fff; border-bottom-color: #ffee00; }
    #graphic .sec-foot       { border-top-color: rgba(255, 255, 255, 0.10); }
    #graphic .sec-foot__meta { color: rgba(255, 255, 255, 0.55); }
    #graphic .pager button   { border-color: rgba(255, 255, 255, 0.18); color: #fff; background: transparent; }
    #graphic .pager button:hover { background: #ffee00; border-color: #ffee00; color: #14131a; }
    #graphic .pager__nums    { color: #fff; }

    /* ---- Illustration ---- */
    #graphic .graphic-slot {
      min-height: 520px;
      background:
        radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.9) 0%, transparent 50%),
        repeating-linear-gradient(
          -45deg,
          rgba(80, 97, 185, 0.04) 0px,
          rgba(80, 97, 185, 0.04) 8px,
          transparent 8px,
          transparent 22px
        ),
        #fff;
      border: 1px dashed rgba(80, 97, 185, 0.35);
      position: relative;
    }
    #graphic .graphic-slot::before {
      content: "";
      position: absolute;
      inset: 12px;
      border: 1px solid rgba(80, 97, 185, 0.1);
      pointer-events: none;
    }
    #graphic .graphic-slot__icon { font-size: 3rem; opacity: 0.55; }
    #graphic .graphic-slot__label {
      font-size: 0.78rem;
      color: var(--misc-accent);
      font-weight: 600;
      letter-spacing: 0.24em;
    }
    #graphic .graphic-stage { position: relative; }
    /* (Left graphic-rail removed) */

    /* ---- Roster — viewport-presence character showcase ---- */
    #roster {
      padding-top: clamp(60px, 8vh, 120px);
      padding-bottom: clamp(60px, 8vh, 120px);
    }
    #roster .roster-body {
      min-height: calc(100vh - clamp(140px, 16vh, 220px));
      min-height: calc(100svh - clamp(140px, 16vh, 220px));
      align-items: stretch;
    }
    /* Single-column stage — character owns the full width, info card
       floats in as an editorial overlay in the top-right corner. */
    #roster .roster-stage {
      grid-template-columns: 1fr;
      gap: 0;
      align-items: stretch;
      position: relative;
    }
    #roster .roster-hero,
    #roster .roster-block,
    #roster .roster-letters {
      grid-column: 1 / -1;
    }
    #roster .roster-card {
      position: absolute;
      top: 24px;
      right: 24px;
      width: min(400px, 34vw);
      z-index: 4;
    }
    #roster .roster-block {
      top: 0%;
      right: 10%;
      width: 80%;
      height: 100%;
      max-width: none;
      background:
        radial-gradient(circle at 30% 30%, rgba(255, 129, 176, 0.05) 0%, transparent 60%),
        rgba(80, 97, 185, 0.06);
    }
    #roster .roster-letters {
      font-size: clamp(9rem, 26vw, 24rem);
      color: rgba(80, 97, 185, 0.07);
    }
    #roster .roster-img {
      max-width: 100%;
      max-height: 88vh;
      max-height: 88svh;
      width: auto;
      height: auto;
      padding: 0;
      background: transparent;
      border: none;
      box-shadow: none;
      filter: drop-shadow(0 34px 50px rgba(20, 19, 26, 0.24))
              drop-shadow(0 10px 20px rgba(20, 19, 26, 0.14));
      object-fit: contain;
      display: block;
      margin: 0 auto;
      transition: filter 220ms ease, transform 320ms cubic-bezier(0.34, 1.20, 0.64, 1);
    }
    #roster .roster-img:hover {
      transform: translateY(-4px);
      filter: drop-shadow(0 44px 60px rgba(20, 19, 26, 0.30))
              drop-shadow(0 14px 24px rgba(20, 19, 26, 0.16));
    }
    #roster .roster-hero {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: flex-end;
      min-height: 88vh;
      min-height: 88svh;
      height: 100%;
    }
    @media (max-width: 900px) {
      #roster .roster-body { min-height: 0; }
      #roster .roster-hero { min-height: 620px; }
      #roster .roster-img { max-width: 100%; max-height: 70vh; max-height: 70svh; }
      /* Collapse info-card overlay back to normal flow below the character */
      #roster .roster-card {
        position: static;
        width: auto;
        margin-top: 24px;
      }
    }
    #roster .roster-card {
      padding: 32px 28px;
      background: linear-gradient(180deg, #fff 0%, #faf9f5 100%);
      border: 1px solid var(--misc-line);
      box-shadow: 0 20px 40px -20px rgba(20, 19, 26, 0.10);
      position: relative;
    }
    #roster .roster-card::before {
      content: "profile";
      position: absolute;
      top: -12px;
      right: 20px;
      background: var(--misc-accent);
      color: #fff;
      padding: 3px 10px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    #roster .roster-card__dl {
      grid-template-columns: auto 1fr;
      gap: 10px 16px;
      align-items: center;
    }
    #roster .roster-card__dl dt {
      background: rgba(80, 97, 185, 0.10);
      color: var(--misc-accent);
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 0.6rem;
      justify-self: start;
      font-weight: 600;
    }

    /* ---- Compact theme selector at bottom of roster ---- */
    .theme-mini {
      margin-top: clamp(56px, 7vw, 96px);
      padding-top: clamp(40px, 4.5vw, 56px);
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      display: grid;
      grid-template-columns: minmax(260px, 340px) 1fr;
      gap: clamp(24px, 4vw, 64px);
      align-items: center;
    }
    .theme-mini__eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent);
      margin: 0 0 10px;
    }
    .theme-mini__lede {
      font-family: 'Branding Pro', sans-serif;
      font-size: 1rem;
      line-height: 1.5;
      color: var(--misc-ink-soft);
      margin: 0;
    }
    .theme-mini__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      max-width: 760px;
      justify-self: end;
    }
    .theme-sq {
      position: relative;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      aspect-ratio: 1.4 / 1;
      background: #fff;
      border: 1px solid var(--misc-line);
      overflow: hidden;
      text-decoration: none;
      transition: transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
      box-shadow: 0 8px 22px -12px rgba(20, 19, 26, 0.10);
    }
    .theme-sq:hover {
      transform: translateY(-3px);
      border-color: var(--misc-accent);
      box-shadow: 0 16px 32px -14px rgba(20, 19, 26, 0.18);
    }
    .theme-sq--psg { background: linear-gradient(180deg, #ffe0eb 0%, #fff4fa 60%, #d6f8ff 100%); }
    .theme-sq--nso { background: linear-gradient(180deg, #e0e6ff 0%, #f6f2ff 60%, #ffe0f4 100%); }
    .theme-sq__char {
      position: absolute;
      bottom: 0;
      height: 92%;
      width: auto;
      max-width: 48%;
    }
    .theme-sq__char--l { left: 3%; }
    .theme-sq__char--r { right: 3%; }
    .theme-sq__label {
      position: relative;
      z-index: 2;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.9rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--misc-ink);
      background: rgba(255, 255, 255, 0.92);
      padding: 5px 16px;
      margin-bottom: 12px;
    }
    @media (max-width: 800px) {
      .theme-mini { grid-template-columns: 1fr; }
      .theme-mini__grid { justify-self: stretch; max-width: none; }
    }

    /* ---- Editorial photography — viewport-fit wrapper ---- */
    #photo {
      padding-top: clamp(48px, 6vh, 88px);
      padding-bottom: clamp(48px, 6vw, 100px);
    }
    #photo .photo-viewport {
      min-height: calc(100vh - clamp(96px, 12vh, 176px));
      min-height: calc(100svh - clamp(96px, 12vh, 176px));
      display: flex;
      flex-direction: column;
      gap: clamp(24px, 3vh, 40px);
      margin-bottom: clamp(56px, 6vw, 96px);
    }
    #photo .photo-viewport .sec__head { margin-bottom: 0; }

    .photo-editorial {
      display: grid;
      grid-template-columns: minmax(0, 1.65fr) minmax(280px, 380px);
      gap: clamp(24px, 4vw, 56px);
      flex: 1;
      min-height: 0;
      align-items: stretch;
    }

    /* ---- 3D coverflow carousel — PSP/PS2 magazine-showcase aesthetic
           Products float freely with cast floor shadows, no frames or
           borders, subtle soft floor plane suggests a gallery display. ---- */
    .lead-3d {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 0;
      perspective: 1800px;
      perspective-origin: 50% 60%;
      background:
        radial-gradient(ellipse at 50% 100%, rgba(80, 97, 185, 0.05) 0%, transparent 60%),
        linear-gradient(180deg, transparent 40%, rgba(80, 97, 185, 0.02) 100%);
    }
    /* Soft horizon floor line, receding into distance */
    .lead-3d::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 68px;
      height: 1px;
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(80, 97, 185, 0.15) 20%,
        rgba(80, 97, 185, 0.30) 50%,
        rgba(80, 97, 185, 0.15) 80%,
        transparent 100%
      );
      pointer-events: none;
      z-index: 1;
    }
    .lead-3d__stage {
      position: relative;
      flex: 1;
      min-height: 480px;
      transform-style: preserve-3d;
      display: block;
    }
    .lead-3d__card {
      position: absolute;
      top: 50%;
      left: 50%;
      width: clamp(340px, 44vw, 640px);
      aspect-ratio: 4 / 5;
      background: transparent;
      border: none;
      padding: 0;
      cursor: pointer;
      transform: translate(-50%, -50%);
      transform-origin: center center;
      transform-style: preserve-3d;
      transition:
        transform 780ms cubic-bezier(0.34, 1.20, 0.64, 1),
        opacity 620ms ease,
        z-index 0ms 320ms;
      will-change: transform, opacity;
      -webkit-tap-highlight-color: transparent;
    }
    /* No frame, no background — just a stage for the product to float on */
    .lead-3d__card-inner {
      position: relative;
      width: 100%;
      height: 100%;
      background: transparent;
      border: none;
      box-shadow: none;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: visible;
    }
    /* Product image floats with a soft render-style drop-shadow */
    .lead-3d__card-inner img {
      max-width: 98%;
      max-height: 98%;
      object-fit: contain;
      filter:
        drop-shadow(0 8px 16px rgba(20, 19, 26, 0.18))
        drop-shadow(0 22px 30px rgba(20, 19, 26, 0.22));
      transition: filter 400ms ease, transform 400ms ease;
    }
    /* Cast floor shadow — elliptical blur beneath the product, like a
       game-asset render. Sits behind the image on the "floor" plane. */
    .lead-3d__card-inner::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: 3%;
      width: 74%;
      height: 22px;
      transform: translateX(-50%);
      background: radial-gradient(ellipse,
        rgba(20, 19, 26, 0.42) 0%,
        rgba(20, 19, 26, 0.15) 40%,
        transparent 70%
      );
      filter: blur(6px);
      opacity: 0.75;
      transition: opacity 400ms ease, width 400ms ease, filter 400ms ease;
      z-index: -1;
      pointer-events: none;
    }
    /* Minimal numbered tag — no border, no bg, just a floating label */
    .lead-3d__card-tag {
      position: absolute;
      top: 8px;
      left: 12px;
      color: var(--misc-accent, #5061b9);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.24em;
      opacity: 0.85;
      pointer-events: none;
      z-index: 2;
      background: transparent;
      border: none;
      padding: 0;
    }
    /* Center card — brighter shadow, slightly larger shadow footprint */
    .lead-3d__card.is-center .lead-3d__card-inner img {
      filter:
        drop-shadow(0 10px 20px rgba(20, 19, 26, 0.22))
        drop-shadow(0 32px 44px rgba(20, 19, 26, 0.30));
    }
    .lead-3d__card.is-center .lead-3d__card-inner::after {
      opacity: 1;
      width: 82%;
      filter: blur(8px);
    }
    /* Side cards fade their floor shadow so it doesn't compete with the center */
    .lead-3d__card:not(.is-center) .lead-3d__card-inner::after {
      opacity: 0.4;
    }
    /* On hover, subtle lift feel */
    .lead-3d__card.is-center:hover .lead-3d__card-inner img {
      transform: translateY(-4px);
    }
    .lead-3d__card.is-center:hover .lead-3d__card-inner::after {
      width: 88%;
      opacity: 0.6;
    }

    /* Carousel controls */
    .lead-3d__ctrl {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      padding: 16px 0 0;
    }
    .lead-3d__arrow {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid var(--misc-line, rgba(0, 0, 0, 0.14));
      background: #fff;
      color: var(--misc-ink, #14131a);
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
      cursor: pointer;
      transition: background 160ms ease, color 160ms ease, border-color 160ms ease, transform 160ms ease;
    }
    .lead-3d__arrow:hover {
      background: var(--misc-accent, #5061b9);
      color: #fff;
      border-color: var(--misc-accent, #5061b9);
      transform: translateY(-1px);
    }
    .lead-3d__dots {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .lead-3d__dots button {
      width: 28px;
      height: 4px;
      padding: 0;
      border: none;
      background: rgba(0, 0, 0, 0.16);
      border-radius: 2px;
      cursor: pointer;
      transition: background 220ms ease, width 220ms ease;
    }
    .lead-3d__dots button:hover { background: rgba(0, 0, 0, 0.3); }
    .lead-3d__dots button.is-active {
      background: var(--misc-accent, #5061b9);
      width: 42px;
    }

    /* ---- Editorial sidebar ---- */
    .photo-side {
      display: flex;
      flex-direction: column;
      padding: 8px 4px;
      min-height: 0;
    }
    .photo-side__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 8px;
    }
    .photo-side__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(2rem, 3.4vw, 2.8rem);
      line-height: 0.95;
      color: var(--misc-ink, #14131a);
      margin: 0 0 24px;
      text-transform: lowercase;
      letter-spacing: -0.02em;
    }

    /* Dynamic caption block */
    .photo-side__cap {
      padding: 20px 20px 22px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0, 0, 0, 0.12));
      border-left: 3px solid var(--misc-accent, #5061b9);
      margin-bottom: 20px;
    }
    .photo-side__idx {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: 2.4rem;
      line-height: 0.9;
      color: rgba(80, 97, 185, 0.35);
      margin: 0 0 4px;
      letter-spacing: -0.04em;
    }
    .photo-side__cap-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 4px;
    }
    .photo-side__cap-name {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: 1.7rem;
      line-height: 1;
      color: var(--misc-ink, #14131a);
      margin: 0 0 12px;
      text-transform: lowercase;
      letter-spacing: -0.01em;
    }
    .photo-side__dot { color: var(--misc-accent, #5061b9); }
    .photo-side__specs {
      display: grid;
      gap: 6px;
    }
    .photo-side__specs span {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.88rem;
      color: var(--misc-ink, #14131a);
      display: grid;
      grid-template-columns: 80px 1fr;
      align-items: baseline;
    }
    .photo-side__specs em {
      font-style: normal;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
    }

    .photo-side__quote {
      padding: 16px;
      background: rgba(80, 97, 185, 0.06);
      border-left: 3px solid var(--misc-accent, #5061b9);
      margin-top: auto;
    }
    .photo-side__quote p {
      font-family: 'Beam Visionary', cursive;
      font-size: 1.1rem;
      line-height: 1.4;
      color: var(--misc-ink, #14131a);
      margin: 0 0 6px;
    }
    .photo-side__by {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.14em;
      color: var(--misc-ink-soft, #6b6b6b);
    }

    @media (max-width: 900px) {
      #photo .photo-viewport { min-height: 0; }
      .photo-editorial { grid-template-columns: 1fr; }
      .lead-3d__stage { min-height: 320px; }
    }
    .photo-lead {
      position: relative;
      margin: 0;
      background: #fff;
      border: 1px solid var(--misc-line);
      overflow: hidden;
    }
    .photo-lead__num {
      position: absolute;
      top: 20px;
      left: 24px;
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(4rem, 9vw, 8rem);
      line-height: 0.8;
      color: rgba(80, 97, 185, 0.10);
      letter-spacing: -0.04em;
      z-index: 1;
      pointer-events: none;
    }
    .photo-lead__img {
      background: linear-gradient(180deg, #f7f6f2 0%, #efece4 100%);
      aspect-ratio: 5 / 4;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }
    .photo-lead__img img {
      max-width: 78%;
      max-height: 82%;
      object-fit: contain;
      filter: drop-shadow(0 20px 30px rgba(20, 19, 26, 0.15));
    }
    .photo-lead__cap {
      padding: 28px clamp(24px, 3vw, 40px);
      display: grid;
      gap: 12px;
      border-top: 1px solid var(--misc-line);
    }
    .photo-lead__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent);
      margin: 0;
    }
    .photo-lead__name {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      color: var(--misc-ink);
      margin: 0;
      text-transform: lowercase;
      letter-spacing: -0.01em;
    }
    .photo-lead__dot { color: var(--misc-accent); }
    .photo-lead__specs {
      display: flex;
      flex-wrap: wrap;
      gap: 12px 28px;
      margin-top: 6px;
    }
    .photo-lead__specs span {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.9rem;
      color: var(--misc-ink);
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
    }
    .photo-lead__specs em {
      font-style: normal;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--misc-ink-soft);
    }

    .photo-index { padding: 8px 4px; }
    .photo-index__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent);
      margin: 0 0 8px;
    }
    .photo-index__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(2.2rem, 3.5vw, 3rem);
      line-height: 0.95;
      color: var(--misc-ink);
      margin: 0 0 20px;
      letter-spacing: -0.02em;
      text-transform: lowercase;
    }
    .photo-index__list {
      display: grid;
      gap: 8px;
      padding: 16px 0;
      border-top: 1px solid var(--misc-line);
      border-bottom: 1px solid var(--misc-line);
      margin-bottom: 20px;
    }
    .photo-index__list span {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 12px;
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.92rem;
      color: var(--misc-ink);
    }
    .photo-index__list em {
