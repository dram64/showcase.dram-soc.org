---
export const prerender = true;
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";
import { products } from "../data/products.ts";

const featured = [
  "deskmat-yuzuha-alice",
  "tapestry-astra-yao",
  "print-yuzuha",
  "sticker-blanc-bunny",
  "deskmat-toki-bunny",
  "tapestry-citlali",
  "print-castorice",
  "sticker-alice",
].map(slug => products.find(p => p.slug === slug)).filter(Boolean);

const roster = [
  { key: "kafka",     img: "/portfolio/kafka.webp",     name: "Kafka",             faction: "Stellaron Hunters",         universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "topaz",     img: "/portfolio/topaz.webp",     name: "Topaz",             faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "psg",       img: "/portfolio/psg.webp",       name: "Panty & Stocking",  faction: "Daten City Church",         universe: "Panty & Stocking",  tag: "PSG" },
  { key: "ayaka",     img: "/portfolio/ayaka.webp",     name: "Kamisato Ayaka",    faction: "Kamisato Clan",             universe: "Genshin Impact",    tag: "GI" },
  { key: "jane",      img: "/portfolio/jane.webp",      name: "Jane Doe",          faction: "Tokyo Zero Original",       universe: "Chromadipity Core", tag: "OC" },
  { key: "ironmouse", img: "/portfolio/ironmouse.webp", name: "Ironmouse",         faction: "VShojo",                    universe: "Vtuber",            tag: "VT" },
];
---
<Base title="portfolio" pageClass="page-index" showHeader={false} showFooter={true}>

  <!-- ==================================================================
       01 · HERO — magazine cover, Tokyo Zero misc palette
       ================================================================== -->
  <section class="tz-hero">
    <div class="tz-hero__inner">
      <!-- LEFT — editorial column -->
      <div class="tz-hero__copy">
        <p class="tz-hero__eyebrow-line">
          <span class="tz-hero__eyebrow-script">chromadipity core</span>
          <span class="tz-hero__eyebrow-mono">// portfolio · 01 / 04</span>
        </p>
        <h1 class="tz-hero__title">tokyo<br/>zero<span class="tz-hero__title-dot">.</span></h1>
        <p class="tz-hero__lede">
          A small set of pieces that don&rsquo;t fit any one drop &mdash; three themed
          storefronts, hand-illustrated character work, shipped on a serverless
          AWS stack.
        </p>
        <div class="tz-hero__cta">
          <a class="tz-hero__btn tz-hero__btn--primary" href="/catalog/">enter catalog &rarr;</a>
          <a class="tz-hero__btn" href="/architecture/">the aws stack</a>
        </div>
        <div class="tz-hero__meta-strip">
          <span><em>design</em> Apex Mk3 · Beam Visionary · Branding Pro</span>
          <span><em>cloud</em> S3 · CloudFront · Lambda · Athena · Terraform</span>
          <span><em>spend</em> ~$2/mo &mdash; <a href="/status/">/status</a></span>
        </div>
      </div>

      <!-- RIGHT — character composition -->
      <div class="tz-hero__stage" aria-hidden="true">
        <div class="tz-hero__halftone tz-hero__halftone--l"></div>
        <div class="tz-hero__halftone tz-hero__halftone--r"></div>
        <img class="tz-hero__char tz-hero__char--l" src="/assets/psg-panty.webp"    alt="" />
        <img class="tz-hero__char tz-hero__char--r" src="/assets/psg-stocking.webp" alt="" />
      </div>
    </div>

    <!-- theme selector — same tiles as the misc header -->
    <div class="tz-hero__themes">
      <p class="tz-hero__themes-h">
        <span class="tz-hero__themes-eyebrow">experimental</span>
        <span class="tz-hero__themes-title">theme selector</span>
      </p>
      <nav class="tz-hero__theme-switch" aria-label="Theme">
        <a class="tz-hero__sq tz-hero__sq--psg" href="/work/psg/" aria-label="PSG theme">
          <img src="/assets/psg-panty-sticker.webp" alt="" aria-hidden="true" />
          <img src="/assets/psg-stocking-sticker.webp" alt="" aria-hidden="true" />
          <span>psg</span>
        </a>
        <a class="tz-hero__sq tz-hero__sq--nso" href="/work/nso/" aria-label="NSO theme">
          <img src="/assets/nso-ame-sticker.webp" alt="" aria-hidden="true" />
          <img src="/assets/nso-kangel-sticker.webp" alt="" aria-hidden="true" />
          <span>nso</span>
        </a>
      </nav>
    </div>
  </section>

  <!-- ==================================================================
       02 · GRAPHIC DESIGN — soft magazine layout, filler slot
       ================================================================== -->
  <section class="tz-sec02">
    <div class="tz-sec02__head">
      <p class="tz-sec02__num">02 / 04</p>
      <p class="tz-sec02__eyebrow">// graphic design</p>
      <h2 class="tz-sec02__title">the illustration.</h2>
      <p class="tz-sec02__lede">
        Character studies, key art, print-ready compositions. A featured piece
        rotates in this frame &mdash; each one is the source for something in the
        catalog.
      </p>
    </div>

    <div class="tz-sec02__nav">
      <a class="tz-sec02__tab is-active">chromadipity</a>
      <span aria-hidden="true">·</span>
      <a class="tz-sec02__tab">psg</a>
      <span aria-hidden="true">·</span>
      <a class="tz-sec02__tab">nso</a>
      <span aria-hidden="true">·</span>
      <a class="tz-sec02__tab">genshin · hsr</a>
      <span aria-hidden="true">·</span>
      <a class="tz-sec02__tab">vtuber</a>
    </div>

    <div class="tz-sec02__grid">
      <!-- Left rail — theme info block -->
      <aside class="tz-sec02__rail">
        <span class="tz-sec02__chip"></span>
        <div class="tz-sec02__meta">
          <p><em>theme</em>&mdash; chromadipity core</p>
          <p><em>creator</em>&mdash; dram</p>
          <p><em>index</em>&mdash; 01 of 12</p>
        </div>
        <p class="tz-sec02__signature">from the desk.</p>
      </aside>

      <!-- Center — filler slot -->
      <div class="tz-sec02__stage">
        <div class="tz-slot">
          <span class="tz-slot__label">// slot 01 · featured illustration</span>
          <span class="tz-slot__icon">◇</span>
          <span class="tz-slot__dim">2400 &times; 1600 · webp · drop the graphic here</span>
        </div>
        <p class="tz-sec02__caption">&mdash; swap freely; portrait &amp; landscape both fit.</p>
      </div>

      <!-- Right rail — vertical text -->
      <aside class="tz-sec02__rail-r">
        <span class="tz-sec02__vrail">chromadipity core &middot; drop 01</span>
      </aside>
    </div>

    <div class="tz-sec02__foot">
      <div class="tz-sec02__pager">
        <button aria-label="previous">&larr;</button>
        <span class="tz-sec02__pager-nums">01 / 12</span>
        <button aria-label="next">&rarr;</button>
      </div>
      <p class="tz-sec02__foot-meta">// interface &mdash; graphic 02</p>
    </div>
  </section>

  <!-- ==================================================================
       03 · CHARACTER SHOWCASE — interactive roster with soft palette
       ================================================================== -->
  <section class="tz-sec03">
    <div class="tz-sec03__head">
      <p class="tz-sec03__num">03 / 04</p>
      <p class="tz-sec03__eyebrow">// the roster</p>
      <h2 class="tz-sec03__title">character work.</h2>
    </div>

    <div class="tz-sec03__body">
      <!-- Left rail — portrait carousel -->
      <aside class="tz-sec03__rail">
        {roster.map((r, i) => (
          <button class:list={["tz-portrait", i === 0 && "is-active"]} data-key={r.key} aria-label={r.name}>
            <img src={r.img} alt={r.name} />
          </button>
        ))}
        <a class="tz-sec03__all" href="/catalog/">all &rarr;</a>
      </aside>

      <!-- Center — big stage -->
      <div class="tz-sec03__stage">
        <div class="tz-sec03__soft-block" aria-hidden="true"></div>
        <div class="tz-sec03__bleed-letters" data-target="letters" aria-hidden="true">KAFKA</div>

        <div class="tz-sec03__hero">
          <div class="tz-sec03__hero-frame">
            <img class="tz-sec03__img" src="/portfolio/kafka.webp" alt="Kafka" data-target="img" />
          </div>
        </div>

        <!-- Nyalra-style info card -->
        <div class="tz-sec03__card">
          <p class="tz-sec03__card-num">01 / 06</p>
          <h3 class="tz-sec03__card-name" data-target="name">Kafka</h3>
          <div class="tz-sec03__card-rule"></div>
          <dl class="tz-sec03__card-dl">
            <dt>faction</dt><dd data-target="faction">Stellaron Hunters</dd>
            <dt>universe</dt><dd data-target="universe">Honkai: Star Rail</dd>
            <dt>tag</dt><dd data-target="tag">HSR</dd>
          </dl>
          <p class="tz-sec03__card-desc">
            Portrait, key art, chibi variant, full-body pose &mdash; each character
            in the roster serves at least one product category. Deskmats,
            tapestries, prints, or acrylic stands.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================================================================
       04 · CATALOG — misc__card product tiles (shopify-native)
       ================================================================== -->
  <section class="tz-sec04">
    <div class="tz-sec04__head">
      <p class="tz-sec04__num">04 / 04</p>
      <p class="tz-sec04__eyebrow">// from the catalog</p>
      <h2 class="tz-sec04__title">the drops.</h2>
      <p class="tz-sec04__lede">
        A curated eight from the 30-piece drop &mdash; deskmats, tapestries, prints,
        stickers. Each carries a character. Full catalog below.
      </p>
    </div>

    <div class="misc__grid tz-sec04__grid">
      {featured.map((p, i) => (
        <ProductCard product={p} index={String(i + 1).padStart(2, "0")} category={p.category} />
      ))}
    </div>

    <div class="tz-sec04__foot">
      <a class="tz-hero__btn tz-hero__btn--primary" href="/catalog/">see the full catalog &rarr;</a>
    </div>
  </section>

  <!-- ==================================================================
       05 · PRODUCT PHOTOGRAPHY + PATHS (retained from earlier build)
       ================================================================== -->
  <section class="tz-sec05">
    <div class="tz-sec05__head">
      <p class="tz-sec05__eyebrow">// finished pieces</p>
      <h2 class="tz-sec05__title">product photography.</h2>
      <p class="tz-sec05__lede">Illustration &rarr; production &rarr; photography. Four physical drops from the roster.</p>
    </div>
    <div class="tz-sec05__grid">
      <figure class="tz-prod">
        <div class="tz-prod__img"><img src="/portfolio/prod-kafka-acrylic.webp" alt="Kafka Acrylic Stand" loading="lazy" /></div>
        <figcaption>
          <span class="tz-prod__label">acrylic stand</span>
          <span class="tz-prod__name">Kafka</span>
          <span class="tz-prod__spec">5.6 &times; 7.4 in &middot; clear acrylic</span>
        </figcaption>
      </figure>
      <figure class="tz-prod">
        <div class="tz-prod__img"><img src="/portfolio/prod-topaz-acrylic.webp" alt="Topaz Acrylic Stand" loading="lazy" /></div>
        <figcaption>
          <span class="tz-prod__label">acrylic stand</span>
          <span class="tz-prod__name">Topaz</span>
          <span class="tz-prod__spec">5.6 &times; 7.4 in &middot; clear acrylic</span>
        </figcaption>
      </figure>
      <figure class="tz-prod">
        <div class="tz-prod__img"><img src="/portfolio/prod-faruzan.webp" alt="Faruzan Deskmat" loading="lazy" /></div>
        <figcaption>
          <span class="tz-prod__label">deskmat</span>
          <span class="tz-prod__name">Faruzan</span>
          <span class="tz-prod__spec">900 &times; 400 mm &middot; sublimated</span>
        </figcaption>
      </figure>
      <figure class="tz-prod">
        <div class="tz-prod__img"><img src="/portfolio/prod-miku.webp" alt="Cinna Miku" loading="lazy" /></div>
        <figcaption>
          <span class="tz-prod__label">print</span>
          <span class="tz-prod__name">Cinna Miku</span>
          <span class="tz-prod__spec">12 &times; 18 in &middot; satin card stock</span>
        </figcaption>
      </figure>
    </div>

    <div class="tz-sec05__paths">
      <a class="tz-path" href="/work/">
        <p class="tz-path__num">&mdash; 01</p>
        <h3 class="tz-path__title">the three themes</h3>
        <p class="tz-path__desc">psg &middot; nso &middot; misc &mdash; each with a distinct visual system.</p>
      </a>
      <a class="tz-path" href="/process/">
        <p class="tz-path__num">&mdash; 02</p>
        <h3 class="tz-path__title">design case study</h3>
        <p class="tz-path__desc">voice, typography, color, three-theme system.</p>
      </a>
      <a class="tz-path" href="/architecture/">
        <p class="tz-path__num">&mdash; 03</p>
        <h3 class="tz-path__title">the aws stack</h3>
        <p class="tz-path__desc">serverless breakdown &mdash; 12 services, ~$2/mo.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const roster = {
      kafka:     { name: "Kafka",             letters: "KAFKA", faction: "Stellaron Hunters",           universe: "Honkai: Star Rail", tag: "HSR", img: "/portfolio/kafka.webp",     num: "01" },
      topaz:     { name: "Topaz",             letters: "TOPAZ", faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR", img: "/portfolio/topaz.webp",     num: "02" },
      psg:       { name: "Panty & Stocking",  letters: "PSG",   faction: "Daten City Church",           universe: "Panty & Stocking",  tag: "PSG", img: "/portfolio/psg.webp",       num: "03" },
      ayaka:     { name: "Kamisato Ayaka",    letters: "AYAKA", faction: "Kamisato Clan",               universe: "Genshin Impact",     tag: "GI",  img: "/portfolio/ayaka.webp",     num: "04" },
      jane:      { name: "Jane Doe",          letters: "JANE",  faction: "Tokyo Zero Original",         universe: "Chromadipity Core",  tag: "OC",  img: "/portfolio/jane.webp",      num: "05" },
      ironmouse: { name: "Ironmouse",         letters: "MOUSE", faction: "VShojo",                      universe: "Vtuber",             tag: "VT",  img: "/portfolio/ironmouse.webp", num: "06" },
    };
    document.querySelectorAll(".tz-portrait[data-key]").forEach(btn => {
      btn.addEventListener("click", () => {
        const r = roster[btn.dataset.key];
        if (!r) return;
        document.querySelectorAll(".tz-portrait").forEach(b => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        const set = (t, v) => { const el = document.querySelector(`[data-target="${t}"]`); if (el) el.textContent = v; };
        set("name", r.name); set("letters", r.letters); set("faction", r.faction); set("universe", r.universe); set("tag", r.tag);
        const img = document.querySelector('[data-target="img"]'); if (img) img.src = r.img;
        const num = document.querySelector(".tz-sec03__card-num"); if (num) num.textContent = r.num + " / 06";
      });
    });
  </script>

  <style>
    /* ============================================================
       01 · HERO — soft magazine cover, misc palette
       ============================================================ */
    .tz-hero {
      background: var(--misc-bg, #fdfcf9);
      padding: clamp(60px, 8vw, 120px) clamp(24px, 6vw, 80px) 0;
      overflow: hidden;
    }
    .tz-hero__inner {
      max-width: 1440px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(24px, 4vw, 72px);
      align-items: center;
      min-height: min(72vh, 720px);
    }
    .tz-hero__copy { position: relative; z-index: 2; }
    .tz-hero__eyebrow-line {
      display: flex;
      align-items: baseline;
      gap: 16px;
      flex-wrap: wrap;
      margin: 0 0 20px;
    }
    .tz-hero__eyebrow-script {
      font-family: 'Beam Visionary', cursive;
      font-size: clamp(1.4rem, 2.2vw, 1.9rem);
      color: var(--misc-accent, #5061b9);
      line-height: 1;
    }
    .tz-hero__eyebrow-mono {
      font-family: 'JetBrains Mono', 'Apex Mk3', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
      padding-left: 16px;
      border-left: 1px solid var(--misc-line, rgba(0,0,0,0.14));
    }
    .tz-hero__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(3.6rem, 10vw, 8rem);
      line-height: 0.9;
      letter-spacing: -0.02em;
      color: var(--misc-ink, #1a1a1a);
      margin: 0 0 24px;
      text-transform: lowercase;
    }
    .tz-hero__title-dot { color: var(--misc-accent, #5061b9); }
    .tz-hero__lede {
      font-family: 'Branding Pro', sans-serif;
      font-weight: 300;
      font-size: clamp(1rem, 1.3vw, 1.15rem);
      line-height: 1.55;
      color: var(--misc-ink, #1a1a1a);
      max-width: 520px;
      margin: 0 0 32px;
    }
    .tz-hero__cta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 40px;
    }
    .tz-hero__btn {
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      padding: 14px 26px;
      border: 1px solid var(--misc-ink, #1a1a1a);
      color: var(--misc-ink, #1a1a1a);
      background: transparent;
      text-decoration: none;
      transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .tz-hero__btn:hover {
      background: var(--misc-ink, #1a1a1a);
      color: #fff;
    }
    .tz-hero__btn--primary {
      background: var(--misc-accent, #5061b9);
      color: #fff;
      border-color: var(--misc-accent, #5061b9);
    }
    .tz-hero__btn--primary:hover { background: var(--misc-ink); border-color: var(--misc-ink); }

    .tz-hero__meta-strip {
      display: grid;
      gap: 4px;
      padding-top: 20px;
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.82rem;
      color: var(--misc-ink-soft, #6b6b6b);
    }
    .tz-hero__meta-strip em {
      font-family: 'JetBrains Mono', monospace;
      font-style: normal;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent);
      margin-right: 10px;
    }
    .tz-hero__meta-strip a { color: var(--misc-accent); text-decoration: none; border-bottom: 1px solid currentColor; }

    /* Right stage — character composition */
    .tz-hero__stage {
      position: relative;
      align-self: stretch;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      min-height: 480px;
    }
    .tz-hero__halftone {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
    }
    .tz-hero__halftone--l {
      width: 55%; height: 55%;
      top: 10%; left: 5%;
      background: radial-gradient(circle, rgba(80, 97, 185, 0.10) 0%, transparent 70%);
    }
    .tz-hero__halftone--r {
      width: 60%; height: 60%;
      bottom: 5%; right: 0%;
      background: radial-gradient(circle, rgba(255, 129, 176, 0.14) 0%, transparent 70%);
    }
    .tz-hero__char {
      position: absolute;
      bottom: -6%;
      height: 105%;
      width: auto;
      max-width: 60%;
      object-fit: contain;
      object-position: bottom center;
      filter: drop-shadow(0 20px 30px rgba(20, 19, 26, 0.15));
      pointer-events: none;
    }
    .tz-hero__char--l { left: 0; }
    .tz-hero__char--r { right: 0; }

    /* Theme selector — same as misc header, integrated into hero base */
    .tz-hero__themes {
      max-width: 1440px;
      margin: clamp(32px, 5vw, 60px) auto 0;
      padding: 24px 0;
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 20px;
    }
    .tz-hero__themes-h { display: flex; flex-direction: column; margin: 0; gap: 4px; line-height: 1; }
    .tz-hero__themes-eyebrow {
      font-family: 'Apex Mk3', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
    }
    .tz-hero__themes-title {
      font-family: 'Coves', 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(1.3rem, 2vw, 1.6rem);
      color: var(--misc-ink);
      text-transform: lowercase;
    }
    .tz-hero__theme-switch {
      display: flex;
      gap: 16px;
    }
    .tz-hero__sq {
      position: relative;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      width: 210px;
      aspect-ratio: 1.8 / 1;
      background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.8) 100%), #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      overflow: hidden;
      text-decoration: none;
      color: var(--misc-ink);
      transition: transform 200ms ease, border-color 200ms ease;
    }
    .tz-hero__sq:hover { transform: translateY(-3px); border-color: var(--misc-accent); }
    .tz-hero__sq--psg { background: linear-gradient(180deg, rgba(255,224,235,0.6) 0%, rgba(255,244,250,0.9) 100%); }
    .tz-hero__sq--nso { background: linear-gradient(180deg, rgba(224,230,255,0.6) 0%, rgba(246,242,255,0.9) 100%); }
    .tz-hero__sq img {
      position: absolute;
      bottom: 0;
      height: 88%;
      width: auto;
      max-width: 48%;
    }
    .tz-hero__sq img:first-of-type { left: 3%; }
    .tz-hero__sq img:last-of-type  { right: 3%; }
    .tz-hero__sq span {
      position: relative;
      z-index: 2;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--misc-ink);
      background: rgba(255,255,255,0.85);
      padding: 4px 12px;
      margin-bottom: 8px;
    }

    @media (max-width: 900px) {
      .tz-hero__inner { grid-template-columns: 1fr; }
      .tz-hero__stage { min-height: 320px; }
      .tz-hero__char { opacity: 0.6; }
      .tz-hero__themes { grid-template-columns: 1fr; }
    }

    /* ============================================================
       02 · GRAPHIC DESIGN — soft magazine layout
       ============================================================ */
    .tz-sec02 {
      background: var(--misc-bg, #fdfcf9);
      padding: clamp(80px, 10vw, 140px) clamp(24px, 6vw, 80px);
    }
    .tz-sec02__head { max-width: 720px; margin-bottom: 6vh; }
    .tz-sec02__num {
