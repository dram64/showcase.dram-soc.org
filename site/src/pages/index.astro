---
export const prerender = true;
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";
import { products } from "../data/products.ts";

const featured = [
  "deskmat-yuzuha-alice",
  "tapestry-astra-yao",
  "print-yuzuha",
  "sticker-blanc-bunny",
  "deskmat-toki-bunny",
  "tapestry-citlali",
  "print-castorice",
  "sticker-alice",
].map(slug => products.find(p => p.slug === slug)).filter(Boolean);

const roster = [
  { key: "kafka",     img: "/portfolio/kafka.webp",     name: "Kafka",             faction: "Stellaron Hunters",           universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "topaz",     img: "/portfolio/topaz.webp",     name: "Topaz",             faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "psg",       img: "/portfolio/psg.webp",       name: "Panty & Stocking",  faction: "Daten City Church",           universe: "Panty & Stocking",  tag: "PSG" },
  { key: "ayaka",     img: "/portfolio/ayaka.webp",     name: "Kamisato Ayaka",    faction: "Kamisato Clan",               universe: "Genshin Impact",     tag: "GI" },
  { key: "jane",      img: "/portfolio/jane.webp",      name: "Jane Doe",          faction: "Tokyo Zero Original",         universe: "Chromadipity Core",  tag: "OC" },
  { key: "ironmouse", img: "/portfolio/ironmouse.webp", name: "Ironmouse",         faction: "VShojo",                      universe: "Vtuber",             tag: "VT" },
];
---
<Base title="portfolio" pageClass="page-index" showHeader={false} showFooter={true}>

  <!-- ================================================================
       SECTION TRACKER — fixed right rail, misc-styled
       ================================================================ -->
  <nav class="tracker" aria-label="Section navigation">
    <a class="tracker__item is-active" data-section="hero" href="#hero">
      <span class="tracker__bar"></span><span class="tracker__num">01</span><span class="tracker__lbl">hero</span>
    </a>
    <a class="tracker__item" data-section="graphic" href="#graphic">
      <span class="tracker__bar"></span><span class="tracker__num">02</span><span class="tracker__lbl">graphic</span>
    </a>
    <a class="tracker__item" data-section="roster" href="#roster">
      <span class="tracker__bar"></span><span class="tracker__num">03</span><span class="tracker__lbl">roster</span>
    </a>
    <a class="tracker__item" data-section="catalog" href="#catalog">
      <span class="tracker__bar"></span><span class="tracker__num">04</span><span class="tracker__lbl">catalog</span>
    </a>
    <a class="tracker__item" data-section="themes" href="#themes">
      <span class="tracker__bar"></span><span class="tracker__num">05</span><span class="tracker__lbl">themes</span>
    </a>
    <a class="tracker__item" data-section="photo" href="#photo">
      <span class="tracker__bar"></span><span class="tracker__num">06</span><span class="tracker__lbl">photo</span>
    </a>
  </nav>

  <!-- ================================================================
       01 · HERO — nyalra magazine cover, misc palette
       ================================================================ -->
  <section id="hero" class="hero" aria-label="hero">
    <div class="hero__glow-l" aria-hidden="true"></div>
    <div class="hero__glow-r" aria-hidden="true"></div>

    <img class="hero__char hero__char--l" src="/assets/psg-panty.webp"    alt="" aria-hidden="true" />
    <img class="hero__char hero__char--r" src="/assets/psg-stocking.webp" alt="" aria-hidden="true" />

    <div class="hero__frame">
      <p class="hero__eyebrow">
        <span class="hero__eyebrow-script">chromadipity core</span>
        <span class="hero__eyebrow-mono">portfolio · 01 / 06</span>
      </p>
      <h1 class="hero__title">tokyo<br/>zero<span class="hero__dot">.</span></h1>
      <p class="hero__lede">
        A small set of pieces that don&rsquo;t fit any one drop &mdash; three
        themed storefronts, hand-illustrated character work, magazine-style
        catalog, shipped on a serverless AWS stack.
      </p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="https://ac41ps-i0.myshopify.com" target="_blank" rel="noopener">shop the drop &rarr;</a>
        <a class="btn" href="#catalog">catalog</a>
      </div>
    </div>
  </section>

  <!-- ================================================================
       POST-HERO STRIP — soft info bar
       ================================================================ -->
  <div class="hero-strip" aria-hidden="true">
    <span><em>design</em> apex mk3 &middot; beam visionary &middot; branding pro</span>
    <span><em>cloud</em> s3 &middot; cloudfront &middot; lambda &middot; athena &middot; terraform</span>
    <span><em>spend</em> ~$2/mo &mdash; <a href="/status/">/status</a> &middot; <a href="/cost/">/cost</a></span>
  </div>

  <!-- ================================================================
       BOUNDARY DIVIDER — last full-bleed element
       ================================================================ -->
  <div class="section-divider section-divider--boundary">
    <span class="section-divider__num">01</span>
    <span class="section-divider__label">graphic interfaces &middot; drop 01</span>
    <span class="section-divider__mark"></span>
  </div>

  <!-- ================================================================
       02 · GRAPHIC DESIGN
       ================================================================ -->
  <section id="graphic" class="sec">
    <div class="sec__head">
      <p class="sec__num">02 / 06</p>
      <p class="sec__eyebrow">graphic design</p>
      <h2 class="sec__title">the illustration.</h2>
      <p class="sec__lede">
        Character studies, key art, print-ready compositions. A featured piece
        rotates in this frame &mdash; each one is the source for something
        in the catalog.
      </p>
    </div>

    <div class="sec-tabs">
      <a class="sec-tab is-active">chromadipity</a>
      <a class="sec-tab">psg</a>
      <a class="sec-tab">nso</a>
      <a class="sec-tab">genshin &middot; hsr</a>
      <a class="sec-tab">vtuber</a>
    </div>

    <div class="graphic-grid">
      <aside class="graphic-rail">
        <span class="graphic-chip"></span>
        <div class="graphic-meta">
          <p><em>theme</em>&mdash; chromadipity core</p>
          <p><em>creator</em>&mdash; dram</p>
          <p><em>format</em>&mdash; digital painting</p>
          <p><em>size</em>&mdash; 2400 &times; 1600</p>
          <p><em>roster</em>&mdash; 40+ pcs</p>
          <p><em>index</em>&mdash; 01 of 12</p>
        </div>
        <p class="graphic-signature">from the desk.</p>
      </aside>

      <div class="graphic-stage">
        <div class="graphic-slot">
          <span class="graphic-slot__label">slot 01 &middot; featured illustration</span>
          <span class="graphic-slot__icon">◇</span>
          <span class="graphic-slot__dim">2400 &times; 1600 &middot; drop the graphic here</span>
        </div>
        <p class="graphic-caption">&mdash; swap freely; portrait &amp; landscape both fit.</p>
      </div>

      <aside class="graphic-vrail">
        <span>chromadipity core &middot; drop 01</span>
      </aside>
    </div>

    <div class="sec-foot">
      <div class="pager">
        <button aria-label="previous">&larr;</button>
        <span class="pager__nums">01 / 12</span>
        <button aria-label="next">&rarr;</button>
      </div>
      <p class="sec-foot__meta">graphic 02 &middot; system interfaces</p>
    </div>
  </section>

  <!-- ================================================================
       03 · CHARACTER ROSTER
       ================================================================ -->
  <section id="roster" class="sec">
    <div class="sec__head">
      <p class="sec__num">03 / 06</p>
      <p class="sec__eyebrow">the roster</p>
      <h2 class="sec__title">character work.</h2>
      <p class="sec__lede">
        Portrait, key art, chibi variant, full-body pose &mdash; each character
        in the roster serves at least one product category.
      </p>
    </div>

    <div class="roster-body">
      <aside class="roster-rail">
        {roster.map((r, i) => (
          <button class:list={["portrait", i === 0 && "is-active"]} data-key={r.key} aria-label={r.name}>
            <img src={r.img} alt={r.name} />
          </button>
        ))}
        <a class="roster-all" href="/catalog/">all &rarr;</a>
      </aside>

      <div class="roster-stage">
        <div class="roster-block" aria-hidden="true"></div>
        <div class="roster-letters" data-target="letters" aria-hidden="true">KAFKA</div>

        <div class="roster-hero">
          <img class="roster-img" src="/portfolio/kafka.webp" alt="Kafka" data-target="img" />
        </div>

        <div class="roster-card">
          <p class="roster-card__num" data-target="num">01 / 06</p>
          <h3 class="roster-card__name" data-target="name">Kafka</h3>
          <div class="roster-card__rule"></div>
          <dl class="roster-card__dl">
            <dt>faction</dt><dd data-target="faction">Stellaron Hunters</dd>
            <dt>universe</dt><dd data-target="universe">Honkai: Star Rail</dd>
            <dt>tag</dt><dd data-target="tag">HSR</dd>
          </dl>
          <p class="roster-card__desc">
            Hand-illustrated character work &mdash; portraits, key art, chibi
            variants, and full-body poses. Each character in the roster serves
            a specific product category: deskmats, tapestries, prints, or
            acrylic stands.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       04 · CATALOG — misc__card grid, shopify-native
       ================================================================ -->
  <section id="catalog" class="sec">
    <div class="sec__head">
      <p class="sec__num">04 / 06</p>
      <p class="sec__eyebrow">from the catalog</p>
      <h2 class="sec__title">the drops.</h2>
      <p class="sec__lede">
        A curated eight from the 30-piece drop &mdash; deskmats, tapestries,
        prints, stickers. Each carries a character. Full catalog on shopify.
      </p>
    </div>

    <div class="misc__grid catalog-grid">
      {featured.map((p, i) => (
        <ProductCard product={p} index={String(i + 1).padStart(2, "0")} category={p.category} />
      ))}
    </div>

    <div class="sec-foot">
      <a class="btn btn--primary" href="https://ac41ps-i0.myshopify.com" target="_blank" rel="noopener">shop the full catalog &rarr;</a>
    </div>
  </section>

  <!-- ================================================================
       05 · THEMED ROOMS
       ================================================================ -->
  <section id="themes" class="sec">
    <div class="sec__head">
      <p class="sec__num">05 / 06</p>
      <p class="sec__eyebrow">experimental &middot; themed rooms</p>
      <h2 class="sec__title">select storefront.</h2>
      <p class="sec__lede">
        Two alternate storefronts &mdash; each with its own hero, product
        spread, typography, and vibe. Enter one and it takes over the full page.
      </p>
    </div>

    <div class="rooms">
      <a class="room room--psg" href="/work/psg/">
        <div class="room__meta-top">
          <span class="room__tag">room 01 · psg</span>
          <span class="room__live">live</span>
        </div>
        <div class="room__chars">
          <img class="room__char room__char--l" src="/assets/psg-panty.webp" alt="Panty" />
          <img class="room__char room__char--r" src="/assets/psg-stocking.webp" alt="Stocking" />
        </div>
        <div class="room__title-wrap">
          <p class="room__eyebrow">panty &amp; stocking with garterbelt</p>
          <h3 class="room__title">psg.</h3>
          <p class="room__sub">candy-halftone spectacle</p>
        </div>
        <div class="room__foot">
          <span class="room__enter">enter psg &rarr;</span>
          <span class="room__specs">7 items &middot; hot pink · cyan · gold &middot; fw &rsquo;26 drop 01</span>
        </div>
      </a>

      <a class="room room--nso" href="/work/nso/">
        <div class="room__meta-top">
          <span class="room__tag">room 02 · nso</span>
          <span class="room__live">live</span>
        </div>
        <div class="room__chars">
          <img class="room__char room__char--l" src="/assets/nso-ame-sticker.webp"    alt="Ame" />
          <img class="room__char room__char--r" src="/assets/nso-kangel-sticker.webp" alt="KAngel" />
        </div>
        <div class="room__title-wrap">
          <p class="room__eyebrow">needy streamer overload</p>
          <h3 class="room__title">nso.</h3>
          <p class="room__sub">crt streamer decay</p>
        </div>
        <div class="room__foot">
          <span class="room__enter">enter nso &rarr;</span>
          <span class="room__specs">6 items &middot; chrome · magenta · amber &middot; fw &rsquo;26 drop 02</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ================================================================
       06 · PRODUCT PHOTOGRAPHY + PATHS
       ================================================================ -->
  <section id="photo" class="sec">
    <div class="sec__head">
      <p class="sec__num">06 / 06</p>
      <p class="sec__eyebrow">product photography</p>
      <h2 class="sec__title">finished pieces.</h2>
      <p class="sec__lede">
        Illustration &rarr; production &rarr; photography. Four physical
        drops from the roster.
      </p>
    </div>

    <div class="prod-grid">
      <figure class="prod">
        <div class="prod__img"><img src="/portfolio/prod-kafka-acrylic.webp" alt="Kafka Acrylic Stand" loading="lazy" /></div>
        <figcaption>
          <span class="prod__label">acrylic stand</span>
          <span class="prod__name">Kafka</span>
          <span class="prod__spec">5.6 &times; 7.4 in &middot; clear acrylic</span>
        </figcaption>
      </figure>
      <figure class="prod">
        <div class="prod__img"><img src="/portfolio/prod-topaz-acrylic.webp" alt="Topaz Acrylic Stand" loading="lazy" /></div>
        <figcaption>
          <span class="prod__label">acrylic stand</span>
          <span class="prod__name">Topaz</span>
          <span class="prod__spec">5.6 &times; 7.4 in &middot; clear acrylic</span>
        </figcaption>
      </figure>
      <figure class="prod">
        <div class="prod__img"><img src="/portfolio/prod-faruzan.webp" alt="Faruzan Deskmat" loading="lazy" /></div>
        <figcaption>
          <span class="prod__label">deskmat</span>
          <span class="prod__name">Faruzan</span>
          <span class="prod__spec">900 &times; 400 mm &middot; sublimated</span>
        </figcaption>
      </figure>
      <figure class="prod">
        <div class="prod__img"><img src="/portfolio/prod-miku.webp" alt="Cinna Miku" loading="lazy" /></div>
        <figcaption>
          <span class="prod__label">print</span>
          <span class="prod__name">Cinna Miku</span>
          <span class="prod__spec">12 &times; 18 in &middot; satin card stock</span>
        </figcaption>
      </figure>
    </div>

    <div class="paths">
      <a class="path" href="/work/">
        <p class="path__num">&mdash; 01</p>
        <h3 class="path__title">the three themes</h3>
        <p class="path__desc">psg &middot; nso &middot; misc &mdash; each with a distinct system.</p>
      </a>
      <a class="path" href="/process/">
        <p class="path__num">&mdash; 02</p>
        <h3 class="path__title">design case study</h3>
        <p class="path__desc">voice, typography, color, three-theme system.</p>
      </a>
      <a class="path" href="/architecture/">
        <p class="path__num">&mdash; 03</p>
        <h3 class="path__title">the aws stack</h3>
        <p class="path__desc">serverless breakdown &mdash; 12 services, ~$2/mo.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const roster = {
      kafka:     { name: "Kafka",             letters: "KAFKA", faction: "Stellaron Hunters",           universe: "Honkai: Star Rail", tag: "HSR", img: "/portfolio/kafka.webp",     num: "01" },
      topaz:     { name: "Topaz",             letters: "TOPAZ", faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR", img: "/portfolio/topaz.webp",     num: "02" },
      psg:       { name: "Panty & Stocking",  letters: "PSG",   faction: "Daten City Church",           universe: "Panty & Stocking",  tag: "PSG", img: "/portfolio/psg.webp",       num: "03" },
      ayaka:     { name: "Kamisato Ayaka",    letters: "AYAKA", faction: "Kamisato Clan",               universe: "Genshin Impact",     tag: "GI",  img: "/portfolio/ayaka.webp",     num: "04" },
      jane:      { name: "Jane Doe",          letters: "JANE",  faction: "Tokyo Zero Original",         universe: "Chromadipity Core",  tag: "OC",  img: "/portfolio/jane.webp",      num: "05" },
      ironmouse: { name: "Ironmouse",         letters: "MOUSE", faction: "VShojo",                      universe: "Vtuber",             tag: "VT",  img: "/portfolio/ironmouse.webp", num: "06" },
    };
    document.querySelectorAll(".portrait[data-key]").forEach(btn => {
      btn.addEventListener("click", () => {
        const r = roster[btn.dataset.key];
        if (!r) return;
        document.querySelectorAll(".portrait").forEach(b => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        const set = (t, v) => { const el = document.querySelector(`[data-target="${t}"]`); if (el) el.textContent = v; };
        set("name", r.name); set("letters", r.letters); set("faction", r.faction); set("universe", r.universe); set("tag", r.tag);
        set("num", r.num + " / 06");
        const img = document.querySelector('[data-target="img"]'); if (img) img.src = r.img;
      });
    });

    // Tracker — IntersectionObserver highlights the active section + smooth-scroll on click
    const trackerItems = document.querySelectorAll(".tracker__item[data-section]");
    const sectionIds = ["hero", "graphic", "roster", "catalog", "themes", "photo"];
    const setActive = (id) => trackerItems.forEach(el => el.classList.toggle("is-active", el.dataset.section === id));
    const io = new IntersectionObserver((entries) => {
      let best = null;
      entries.forEach(e => { if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) best = e; });
      if (best) setActive(best.target.id);
    }, { rootMargin: "-25% 0px -50% 0px", threshold: [0, 0.2, 0.5, 0.8, 1] });
    sectionIds.forEach(id => { const el = document.getElementById(id); if (el) io.observe(el); });
    trackerItems.forEach(item => {
      item.addEventListener("click", (e) => {
        e.preventDefault();
        const target = document.getElementById(item.dataset.section);
        if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });
  </script>

  <style>
    /* ============================================================
       BASE — kill the shopify padding and full-bleed the hero + boundary
       ============================================================ */
    body.page-index .content-for-layout {
      padding: 0 !important;
      max-width: none !important;
    }
    body.page-index main.content-for-layout {
      padding-left: var(--rails-w) !important;
      padding-right: var(--rails-w) !important;
      box-sizing: border-box;
    }
    /* Hero + strip + boundary divider bleed past the rail padding */
    .hero,
    .hero-strip,
    .section-divider--boundary {
      width: 100vw;
      margin-left: calc((100% - 100vw) / 2);
      max-width: 100vw;
      box-sizing: border-box;
    }
    .misc__grid { max-width: none !important; }

    /* ============================================================
       TRACKER — misc-styled, soft, slate-violet accent
       ============================================================ */
    .tracker {
      position: fixed;
      right: calc(var(--rails-w, 60px) + 14px);
      top: 50%;
      transform: translateY(-50%);
      z-index: 96;
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 10px 8px;
      background: rgba(255, 255, 255, 0.85);
      border: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      backdrop-filter: blur(10px);
    }
    .tracker__item {
      display: grid;
      grid-template-columns: 3px auto 1fr;
      align-items: center;
      gap: 10px;
      padding: 8px 8px 8px 4px;
      color: var(--misc-ink-soft, #6b6b6b);
      text-decoration: none;
      font-family: 'Apex Mk3', 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: lowercase;
      transition: color 180ms ease, background 180ms ease;
    }
    .tracker__bar {
      display: block;
      width: 3px;
      height: 14px;
      background: rgba(0, 0, 0, 0.15);
      transition: background 180ms ease, height 180ms ease;
    }
    .tracker__num { font-weight: 500; color: var(--misc-ink, #14131a); }
    .tracker__lbl {
      max-width: 0;
      overflow: hidden;
      white-space: nowrap;
      opacity: 0;
      transition: max-width 220ms ease, opacity 200ms ease;
    }
    .tracker__item:hover .tracker__lbl,
    .tracker:hover .tracker__item .tracker__lbl,
    .tracker__item.is-active .tracker__lbl {
      max-width: 90px;
      opacity: 1;
    }
    .tracker__item:hover { color: var(--misc-ink, #14131a); }
    .tracker__item:hover .tracker__bar { background: var(--misc-accent, #5061b9); height: 20px; }
    .tracker__item.is-active {
      color: var(--misc-accent, #5061b9);
      background: rgba(80, 97, 185, 0.08);
    }
    .tracker__item.is-active .tracker__bar {
      background: var(--misc-accent, #5061b9);
      height: 22px;
    }
    .tracker__item.is-active .tracker__num { color: var(--misc-accent, #5061b9); }

    @media (max-width: 800px) {
      .tracker {
        top: auto;
        bottom: 12px;
        right: 50%;
        transform: translateX(50%);
        flex-direction: row;
        padding: 8px 10px;
      }
      .tracker__bar, .tracker__lbl { display: none; }
    }

    /* ============================================================
       01 · HERO — soft cream misc cover
       ============================================================ */
    .hero {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(ellipse at 20% 30%, rgba(80, 97, 185, 0.08) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 70%, rgba(255, 129, 176, 0.06) 0%, transparent 60%),
        var(--misc-bg, #fdfcf9);
      color: var(--misc-ink, #1a1a1a);
      min-height: 88vh;
      padding: clamp(48px, 6vw, 80px) clamp(80px, 8vw, 120px);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero__glow-l, .hero__glow-r {
      position: absolute;
      width: 40vw;
      height: 40vw;
      max-width: 700px;
      max-height: 700px;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
    }
    .hero__glow-l { background: rgba(80, 97, 185, 0.12); top: -12%; left: -12%; }
    .hero__glow-r { background: rgba(255, 129, 176, 0.10); bottom: -12%; right: -12%; }
    .hero__char {
      position: absolute;
      bottom: -3%;
      height: 90%;
      width: auto;
      max-width: 38%;
      object-fit: contain;
      object-position: bottom center;
      z-index: 1;
      pointer-events: none;
      filter: drop-shadow(0 20px 30px rgba(20, 19, 26, 0.15));
      opacity: 0.55;
    }
    .hero__char--l { left: 2%; }
    .hero__char--r { right: 2%; }

    .hero__frame {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 620px;
    }
    .hero__eyebrow {
      display: flex;
      justify-content: center;
      align-items: baseline;
      gap: 16px;
      flex-wrap: wrap;
      margin: 0 0 24px;
    }
    .hero__eyebrow-script {
      font-family: 'Beam Visionary', cursive;
      font-size: clamp(1.4rem, 2vw, 1.9rem);
      color: var(--misc-accent, #5061b9);
      line-height: 1;
    }
    .hero__eyebrow-mono {
      font-family: 'JetBrains Mono', 'Apex Mk3', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
      padding-left: 16px;
      border-left: 1px solid var(--misc-line, rgba(0,0,0,0.15));
    }
    .hero__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(3.6rem, 11vw, 8rem);
      line-height: 0.9;
      letter-spacing: -0.02em;
      color: var(--misc-ink, #14131a);
      margin: 0 0 24px;
      text-transform: lowercase;
    }
    .hero__dot { color: var(--misc-accent, #5061b9); }
    .hero__lede {
      font-family: 'Branding Pro', sans-serif;
      font-weight: 300;
      font-size: clamp(1rem, 1.3vw, 1.15rem);
      line-height: 1.55;
      color: var(--misc-ink, #1a1a1a);
      max-width: 520px;
      margin: 0 auto 32px;
    }
    .hero__cta { display: inline-flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
    .btn {
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      padding: 14px 26px;
      border: 1px solid var(--misc-ink, #14131a);
      color: var(--misc-ink, #14131a);
      background: transparent;
      text-decoration: none;
      transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .btn:hover { background: var(--misc-ink, #14131a); color: #fff; }
    .btn--primary {
      background: var(--misc-accent, #5061b9);
      color: #fff;
      border-color: var(--misc-accent, #5061b9);
    }
    .btn--primary:hover { background: var(--misc-ink, #14131a); border-color: var(--misc-ink, #14131a); }

    @media (max-width: 900px) {
      .hero { padding: 60px 20px; }
      .hero__char { opacity: 0.35; max-width: 55%; }
    }

    /* ============================================================
       POST-HERO STRIP — soft
       ============================================================ */
    .hero-strip {
      background: rgba(80, 97, 185, 0.05);
      color: var(--misc-ink-soft, #6b6b6b);
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      border-bottom: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      padding: 14px clamp(80px, 8vw, 120px);
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.85rem;
      display: flex;
      justify-content: center;
      gap: clamp(20px, 4vw, 48px);
      flex-wrap: wrap;
    }
    .hero-strip em {
      font-style: normal;
      font-family: 'Apex Mk3', 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
      margin-right: 10px;
    }
    .hero-strip a { color: var(--misc-accent, #5061b9); text-decoration: none; border-bottom: 1px solid currentColor; }

    /* ============================================================
       SECTION DIVIDERS — thin hairline with small caps text
       ============================================================ */
    .section-divider {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 16px clamp(80px, 8vw, 120px);
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      border-bottom: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      background: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
    }
    .section-divider__num {
      color: var(--misc-accent, #5061b9);
      font-weight: 500;
    }
    .section-divider__label { flex: 1; }
    .section-divider__mark {
      display: inline-block;
      width: 32px;
      height: 2px;
      background: var(--misc-accent, #5061b9);
    }

    /* ============================================================
       SHARED — section shell (used by sec02 through sec06)
       ============================================================ */
    .sec {
      padding: clamp(60px, 8vw, 100px) 0;
      max-width: 1280px;
      margin: 0 auto;
    }
    .sec__head { margin-bottom: 5vh; max-width: 720px; }
    .sec__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0 0 12px;
    }
    .sec__eyebrow {
      font-family: 'Beam Visionary', cursive;
      font-size: clamp(1.1rem, 1.6vw, 1.4rem);
      color: var(--misc-accent, #5061b9);
      margin: 0 0 8px;
      line-height: 1;
    }
    .sec__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(2rem, 4vw, 2.8rem);
      line-height: 1;
      color: var(--misc-ink, #1a1a1a);
      text-transform: lowercase;
      margin: 0 0 20px;
      letter-spacing: -0.01em;
    }
    .sec__lede {
      font-family: 'Branding Pro', sans-serif;
      font-size: 1rem;
      line-height: 1.55;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
      max-width: 620px;
    }
    .sec-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.10));
      gap: 20px;
      flex-wrap: wrap;
    }
    .sec-foot__meta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
    }
    .pager { display: inline-flex; align-items: center; gap: 14px; }
    .pager button {
      width: 38px; height: 38px;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      background: transparent;
      color: var(--misc-ink, #14131a);
      cursor: pointer;
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
      transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .pager button:hover { background: var(--misc-accent, #5061b9); color: #fff; border-color: var(--misc-accent, #5061b9); }
    .pager__nums {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.82rem;
      letter-spacing: 0.14em;
      color: var(--misc-ink, #14131a);
    }

    /* ============================================================
       GRAPHIC DESIGN
       ============================================================ */
    .sec-tabs {
      display: flex;
      gap: 20px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--misc-line, rgba(0,0,0,0.12));
      margin-bottom: 32px;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      overflow-x: auto;
    }
    .sec-tab {
      color: var(--misc-ink-soft, #6b6b6b);
      text-decoration: none;
      padding-bottom: 4px;
      border-bottom: 1px solid transparent;
      transition: color 140ms ease, border-color 140ms ease;
      cursor: pointer;
      white-space: nowrap;
    }
    .sec-tab:hover { color: var(--misc-ink, #14131a); }
    .sec-tab.is-active {
      color: var(--misc-ink, #14131a);
      border-bottom-color: var(--misc-accent, #5061b9);
    }
    .graphic-grid {
      display: grid;
      grid-template-columns: 240px minmax(0, 1fr) 60px;
      gap: 32px;
    }
    .graphic-rail { display: flex; flex-direction: column; gap: 16px; }
    .graphic-chip {
      width: 32px; height: 32px;
      background: rgba(80, 97, 185, 0.15);
      border: 2px solid var(--misc-accent, #5061b9);
    }
    .graphic-meta {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.9rem;
      color: var(--misc-ink, #1a1a1a);
    }
    .graphic-meta p { margin: 0 0 6px; }
    .graphic-meta em {
      font-family: 'JetBrains Mono', monospace;
      font-style: normal;
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
      margin-right: 8px;
    }
    .graphic-signature {
      font-family: 'Beam Visionary', cursive;
      font-size: 1.4rem;
      color: var(--misc-accent, #5061b9);
      margin: 8px 0 0;
    }
    .graphic-vrail {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 40px;
    }
    .graphic-vrail span {
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-family: 'Apex Mk3', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
      white-space: nowrap;
    }
    .graphic-stage { position: relative; }
    .graphic-caption {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.88rem;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 16px 0 0;
      font-style: italic;
    }
    .graphic-slot {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding: 60px;
      min-height: 460px;
      background:
        repeating-linear-gradient(
          -45deg,
          rgba(80, 97, 185, 0.03) 0px,
          rgba(80, 97, 185, 0.03) 8px,
          transparent 8px,
          transparent 20px
        ),
        #fff;
      border: 1px dashed rgba(80, 97, 185, 0.4);
    }
    .graphic-slot__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
    }
    .graphic-slot__icon {
      font-size: 2rem;
      color: var(--misc-accent, #5061b9);
      opacity: 0.45;
    }
    .graphic-slot__dim {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      color: var(--misc-ink-soft, #6b6b6b);
      letter-spacing: 0.08em;
    }
    @media (max-width: 900px) {
      .graphic-grid { grid-template-columns: 1fr; }
      .graphic-vrail { display: none; }
    }

    /* ============================================================
       ROSTER (character showcase)
       ============================================================ */
    .roster-body {
      display: grid;
      grid-template-columns: 100px minmax(0, 1fr);
      gap: 40px;
      position: relative;
    }
    .roster-rail {
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: center;
    }
    .portrait {
      display: block;
      width: 72px;
      height: 72px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid var(--misc-line, rgba(0,0,0,0.15));
      background: #fff;
      cursor: pointer;
      padding: 0;
      transition: border-color 180ms ease, transform 180ms ease;
    }
    .portrait img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .portrait:hover { transform: scale(1.05); }
    .portrait.is-active {
      border-color: var(--misc-accent, #5061b9);
      box-shadow: 0 0 0 4px rgba(80, 97, 185, 0.15);
    }
    .roster-all {
      margin-top: 16px;
      padding: 8px 12px;
      color: var(--misc-ink, #14131a);
      text-decoration: none;
      font-family: 'Apex Mk3', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: lowercase;
      border: 1px solid var(--misc-ink, #14131a);
      transition: background 140ms ease, color 140ms ease;
    }
    .roster-all:hover { background: var(--misc-ink, #14131a); color: #fff; }

    .roster-stage {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
      gap: 40px;
      align-items: start;
    }
    .roster-block {
      position: absolute;
      top: 4%;
      right: 30%;
      width: 55%;
      height: 92%;
      max-width: 620px;
      background: rgba(80, 97, 185, 0.06);
      z-index: 0;
    }
    .roster-letters {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(6rem, 18vw, 16rem);
      letter-spacing: -0.03em;
      color: rgba(80, 97, 185, 0.06);
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
      white-space: nowrap;
      text-transform: uppercase;
    }
    .roster-hero { position: relative; z-index: 2; }
    .roster-img {
      display: block;
      width: 100%;
      max-width: 520px;
      height: auto;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
    }
    .roster-card {
      position: relative;
      z-index: 2;
      padding: 28px 24px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
    }
    .roster-card__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 8px;
    }
    .roster-card__name {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(1.6rem, 2.5vw, 2rem);
      line-height: 1;
      color: var(--misc-ink, #14131a);
      margin: 0 0 16px;
      text-transform: lowercase;
    }
    .roster-card__rule {
      height: 1px;
      background: var(--misc-line, rgba(0,0,0,0.14));
      margin-bottom: 16px;
      position: relative;
    }
    .roster-card__rule::after {
      content: "";
      position: absolute;
      left: 0; top: 0;
      width: 48px;
      height: 2px;
      background: var(--misc-accent, #5061b9);
    }
    .roster-card__dl {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 8px 20px;
      margin: 0 0 16px;
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.9rem;
    }
    .roster-card__dl dt {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.66rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--misc-ink-soft, #6b6b6b);
      align-self: center;
    }
    .roster-card__dl dd { margin: 0; color: var(--misc-ink, #14131a); }
    .roster-card__desc {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.88rem;
      line-height: 1.55;
      color: var(--misc-ink-soft, #6b6b6b);
      margin: 0;
    }
    @media (max-width: 900px) {
      .roster-body { grid-template-columns: 1fr; }
      .roster-rail { flex-direction: row; flex-wrap: wrap; }
      .roster-stage { grid-template-columns: 1fr; }
      .roster-block { display: none; }
      .roster-letters { font-size: 10rem; }
    }

    /* ============================================================
       CATALOG
       ============================================================ */
    .catalog-grid { grid-template-columns: repeat(4, 1fr) !important; gap: 5vh 3vw !important; }
    @media (max-width: 900px) { .catalog-grid { grid-template-columns: repeat(2, 1fr) !important; } }

    /* ============================================================
       THEMED ROOMS
       ============================================================ */
    .rooms {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .room {
      position: relative;
      display: block;
      min-height: 480px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      transition: transform 220ms ease, border-color 220ms ease;
    }
    .room:hover { transform: translateY(-4px); border-color: var(--misc-accent, #5061b9); }
    .room--psg { background: linear-gradient(150deg, #ffe0eb 0%, #fff4fa 60%, #d6f8ff 100%); }
    .room--nso { background: linear-gradient(150deg, #e0e6ff 0%, #f6f2ff 60%, #ffe0f4 100%); }
    .room__meta-top {
      position: absolute;
      top: 16px;
      left: 16px;
      right: 16px;
      z-index: 3;
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }
    .room__tag, .room__live {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 3px 8px;
      background: rgba(255, 255, 255, 0.85);
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      color: var(--misc-ink, #14131a);
    }
    .room__live { color: var(--misc-accent, #5061b9); }
    .room__chars { position: absolute; bottom: 0; left: 0; right: 0; height: 65%; pointer-events: none; z-index: 1; }
    .room__char {
      position: absolute;
      bottom: -8%;
      height: 110%;
      width: auto;
      max-width: 60%;
      object-fit: contain;
      object-position: bottom center;
      filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.12));
      transition: transform 320ms ease;
    }
    .room__char--l { left: -6%; }
    .room__char--r { right: -6%; }
    .room:hover .room__char--l { transform: translate(-3px, -6px) rotate(-1deg); }
    .room:hover .room__char--r { transform: translate(3px, -6px) rotate(1deg); }
    .room__title-wrap {
      position: relative;
      z-index: 2;
      padding: 56px 28px 0;
      text-align: center;
    }
    .room__eyebrow {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: lowercase;
      color: var(--misc-ink-soft, #6b6b6b);
      margin-bottom: 6px;
    }
    .room__title {
      font-family: 'Apex Mk3', sans-serif;
      font-weight: 300;
      font-size: clamp(3.4rem, 8vw, 6rem);
      line-height: 0.95;
      color: var(--misc-ink, #14131a);
      margin: 0 0 8px;
      text-transform: lowercase;
    }
    .room__sub {
      font-family: 'Beam Visionary', cursive;
      font-size: clamp(1rem, 1.6vw, 1.4rem);
      color: var(--misc-accent, #5061b9);
      margin: 0;
    }
    .room__foot {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      z-index: 3;
      padding: 16px 20px;
      background: linear-gradient(to top, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.4) 80%, transparent 100%);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .room__enter {
      font-family: 'Apex Mk3', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      color: var(--misc-accent, #5061b9);
    }
    .room__specs {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--misc-ink-soft, #6b6b6b);
    }
    @media (max-width: 900px) { .rooms { grid-template-columns: 1fr; } }

    /* ============================================================
       PRODUCT PHOTOGRAPHY + PATHS
       ============================================================ */
    .prod-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 60px;
    }
    .prod {
      margin: 0;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      overflow: hidden;
      transition: transform 200ms ease, border-color 200ms ease;
      display: flex;
      flex-direction: column;
    }
    .prod:hover { transform: translateY(-3px); border-color: var(--misc-accent, #5061b9); }
    .prod__img {
      background: #f7f6f2;
      aspect-ratio: 4/5;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .prod__img img { max-width: 100%; max-height: 100%; object-fit: contain; }
    .prod figcaption {
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      border-top: 1px solid var(--misc-line, rgba(0,0,0,0.10));
    }
    .prod__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--misc-accent, #5061b9);
    }
    .prod__name {
      font-family: 'Apex Mk3', sans-serif;
      font-size: 1.05rem;
      color: var(--misc-ink, #14131a);
    }
    .prod__spec {
      font-family: 'Branding Pro', sans-serif;
      font-size: 0.78rem;
      color: var(--misc-ink-soft, #6b6b6b);
      line-height: 1.4;
    }
    .paths {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .path {
      display: block;
      padding: 24px;
      background: #fff;
      border: 1px solid var(--misc-line, rgba(0,0,0,0.14));
      text-decoration: none;
      color: inherit;
      transition: border-color 180ms ease, transform 180ms ease;
    }
    .path:hover { border-color: var(--misc-accent, #5061b9); transform: translateY(-2px); }
    .path__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      color: var(--misc-accent, #5061b9);
      margin: 0 0 12px;
    }
    .path__title {
      font-family: 'Apex Mk3', sans-serif;
      font-size: 1.2rem;
      color: var(--misc-ink, #14131a);
