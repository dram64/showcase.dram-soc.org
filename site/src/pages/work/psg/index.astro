---
export const prerender = true;
import "../../../styles/shopify/psg.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PSG — Tokyo Zero</title>
    <meta name="description" content="Panty & Stocking pastiche — candy halftone showcase from the Tokyo Zero brand system." />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="page-psg intro-done">
    <nav class="theme-nav theme-nav--psg" aria-label="Theme navigation">
      <button type="button" class="theme-nav__btn theme-nav__btn--back" aria-label="Go back" onclick="if(history.length>1){history.back()}else{location.href='/'}">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M14 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <a class="theme-nav__btn theme-nav__btn--home" href="/" aria-label="Home">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M4 11l8-7 8 7v9a1 1 0 0 1-1 1h-4v-6h-6v6H5a1 1 0 0 1-1-1z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </nav>

    <div class="canvas">
      <img class="heart-bg" src="/assets/psg-pink-heart.webp" alt="" aria-hidden="true" />
      <div class="frill-top" aria-hidden="true"></div>
      <img class="char char--panty"    src="/assets/psg-panty.webp"    alt="Panty" />
      <img class="char char--stocking" src="/assets/psg-stocking.webp" alt="Stocking" />
      <div class="char-silh char-silh--panty"    aria-hidden="true"></div>
      <div class="char-silh char-silh--stocking" aria-hidden="true"></div>
      <div class="bg-pink" aria-hidden="true"></div>
      <img class="halftone-circle halftone-circle--left"  src="/assets/psg-halftone-circle.webp" alt="" aria-hidden="true" />
      <img class="halftone-circle halftone-circle--right" src="/assets/psg-halftone-circle.webp" alt="" aria-hidden="true" />
      <div class="products-bg-tilt" aria-hidden="true"></div>
      <div class="products-bg" aria-hidden="true"></div>

      <footer class="site-footer">
        <nav class="footer-nav" aria-label="Footer">
          <a href="/contact/">Contact Us</a>
          <a href="/work/">About Us</a>
          <a href="/">Tokyo Zero</a>
        </nav>
      </footer>

      <p class="items-kicker">FW '26 · Drop 01</p>
      <h2 class="items-title">PRODUCTS</h2>
      <img class="items-asset" src="/assets/psg-7-items.webp" alt="" aria-hidden="true" />
      <p class="items-sub">Limited Time Only</p>

      <div class="products-showcase">
        <article class="psg-item psg-item--a psg-item--clickable">
          <span class="psg-item__no" aria-hidden="true">01</span>
          <img class="product-item product-item--print" src="/assets/psg-print.webp" alt="Art Print" />
          <h3 class="psg-item__name">Art Print <i aria-hidden="true">♥</i></h3>
          <span class="psg-item__rule" aria-hidden="true"></span>
          <p class="psg-item__desc">11×17 in print on extra-heavy card stock.</p>
          <p class="psg-item__price"><em aria-hidden="true">·</em>$5.00</p>
        </article>

        <article class="psg-item psg-item--b psg-item--clickable">
          <span class="psg-item__no" aria-hidden="true">02</span>
          <img class="product-item product-item--deskmat" src="/assets/psg-deskmat.webp" alt="Deskmat" />
          <h3 class="psg-item__name">Deskmat <i aria-hidden="true">★</i></h3>
          <span class="psg-item__rule" aria-hidden="true"></span>
          <p class="psg-item__desc">900 × 400 × 4 mm stitched-edge mouse pad.</p>
          <p class="psg-item__price"><em aria-hidden="true">·</em>$35.00</p>
        </article>

        <article class="psg-item psg-item--a psg-item--clickable">
          <span class="psg-item__no" aria-hidden="true">03</span>
          <img class="product-item product-item--tote" src="/assets/psg-tote.webp" alt="Tote Bag" />
          <h3 class="psg-item__name">Tote Bag <i aria-hidden="true">♥</i></h3>
          <span class="psg-item__rule" aria-hidden="true"></span>
          <p class="psg-item__desc">Canvas tote, 40 × 35 cm, single-sided print.</p>
          <p class="psg-item__price"><em aria-hidden="true">·</em>$10.00</p>
        </article>

        <article class="psg-item psg-item--b psg-item--clickable">
          <span class="psg-item__no" aria-hidden="true">04</span>
          <img class="product-item product-item--lanyard" src="/assets/psg-lanyard.webp" alt="Lanyard" />
          <h3 class="psg-item__name">Lanyard <i aria-hidden="true">★</i></h3>
          <span class="psg-item__rule" aria-hidden="true"></span>
          <p class="psg-item__desc">Polyester cord, double-sided print, bolt clip.</p>
          <p class="psg-item__price"><em aria-hidden="true">·</em>$5.00</p>
        </article>

        <article class="psg-item psg-item--a psg-item--clickable">
          <span class="psg-item__no" aria-hidden="true">05</span>
          <div class="psg-pair">
            <img class="product-item product-item--acrylic product-item--shake-a" src="/assets/psg-panty-acrylic.webp"    alt="Panty Acrylic Stand" />
            <img class="product-item product-item--acrylic product-item--shake-b" src="/assets/psg-stocking-acrylic.webp" alt="Stocking Acrylic Stand" />
          </div>
          <h3 class="psg-item__name">Acrylic Stand <i aria-hidden="true">♡</i></h3>
          <span class="psg-item__rule" aria-hidden="true"></span>
          <p class="psg-item__desc">5.6 × 7.4 in clear acrylic. Available as Panty or Stocking — sold separately.</p>
          <p class="psg-item__price"><em aria-hidden="true">·</em>$15.00 each</p>
        </article>

        <article class="psg-item psg-item--b psg-item--clickable">
          <span class="psg-item__no" aria-hidden="true">06</span>
          <div class="psg-pair">
            <img class="product-item product-item--tapestry product-item--shake-a" src="/assets/psg-panty-tapestry.webp"    alt="Panty Tapestry" />
            <img class="product-item product-item--tapestry product-item--shake-b" src="/assets/psg-stocking-tapestry.webp" alt="Stocking Tapestry" />
          </div>
          <h3 class="psg-item__name">Tapestry <i aria-hidden="true">☆</i></h3>
          <span class="psg-item__rule" aria-hidden="true"></span>
          <p class="psg-item__desc">Polyester wall scroll, white rods top + bottom, string hanger.</p>
          <p class="psg-item__price"><em aria-hidden="true">·</em>$35.00 each</p>
        </article>

        <article class="psg-item psg-item--a psg-item--solo psg-item--clickable">
          <span class="psg-item__no" aria-hidden="true">07</span>
          <div class="psg-pair">
            <img class="product-item product-item--sticker product-item--shake-a" src="/assets/psg-panty-sticker.webp"    alt="Panty Sticker" />
            <img class="product-item product-item--sticker product-item--shake-b" src="/assets/psg-stocking-sticker.webp" alt="Stocking Sticker" />
          </div>
          <h3 class="psg-item__name">Sticker <i aria-hidden="true">★</i></h3>
          <span class="psg-item__rule" aria-hidden="true"></span>
          <p class="psg-item__desc">Satin kiss-cut vinyl, peel-and-stick.</p>
          <p class="psg-item__price"><em aria-hidden="true">·</em>$5.00 each</p>
        </article>
      </div>

      <div class="psg-impact" aria-hidden="true">
        <span class="smoke smoke--1"></span><span class="smoke smoke--2"></span>
        <span class="smoke smoke--3"></span><span class="smoke smoke--4"></span>
        <span class="smoke smoke--5"></span><span class="smoke smoke--6"></span>
        <span class="smoke smoke--7"></span><span class="smoke smoke--8"></span>
      </div>
      <img class="psg-logo" src="/assets/psg-logo.svg" alt="Panty & Stocking" />
    </div>

    <style is:global>
      .theme-nav {
        position: fixed; top: 22px; left: 22px; z-index: 250;
        display: flex; gap: 10px;
      }
      .theme-nav__btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 44px; height: 44px; padding: 0;
        border: 1px solid rgba(255, 255, 255, 0.45); border-radius: 50%;
        background: rgba(255, 255, 255, 0.55);
        backdrop-filter: blur(16px) saturate(160%);
        -webkit-backdrop-filter: blur(16px) saturate(160%);
        color: #1a1a1a; cursor: pointer; text-decoration: none;
        box-shadow: 0 4px 14px rgba(20,18,38,0.10), 0 1px 3px rgba(20,18,38,0.06), inset 0 1px 0 rgba(255,255,255,0.55);
        transition: transform .2s ease, background .2s ease;
      }
      .theme-nav__btn svg { width: 18px; height: 18px; }
      .theme-nav__btn:hover { background: rgba(255,255,255,0.92); transform: translateY(-1px); }
    </style>
  </body>
</html>
