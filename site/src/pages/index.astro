            <p class="photo-side__cap-label" data-target="side-label">flat-lay</p>
            <h4 class="photo-side__cap-name">
              <span data-target="side-name">Frame 01</span><span class="photo-side__dot">.</span>
            </h4>
            <div class="photo-side__specs" data-target="side-specs">
              <span><em>set</em>studio &middot; natural light</span>
              <span><em>capture</em>a7iii &middot; 35mm</span>
              <span><em>process</em>color &middot; retouch</span>
