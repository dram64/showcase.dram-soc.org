---
export const prerender = true;
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";
import { products } from "../data/products.ts";

const featured = [
  "deskmat-yuzuha-alice",
  "tapestry-astra-yao",
  "print-yuzuha",
  "sticker-blanc-bunny",
  "deskmat-toki-bunny",
  "tapestry-citlali",
  "print-castorice",
  "sticker-alice",
].map(slug => products.find(p => p.slug === slug)).filter(Boolean);

const roster = [
  { key: "kafka",     img: "/portfolio/kafka.webp",     name: "Kafka",             faction: "Stellaron Hunters", universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "topaz",     img: "/portfolio/topaz.webp",     name: "Topaz",             faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "psg",       img: "/portfolio/psg.webp",       name: "Panty & Stocking",  faction: "Daten City Church",  universe: "Panty & Stocking",  tag: "PSG" },
  { key: "ayaka",     img: "/portfolio/ayaka.webp",     name: "Kamisato Ayaka",    faction: "Kamisato Clan",       universe: "Genshin Impact",     tag: "GI" },
  { key: "jane",      img: "/portfolio/jane.webp",      name: "Jane Doe",          faction: "Tokyo Zero Original", universe: "Chromadipity Core",  tag: "OC" },
  { key: "ironmouse", img: "/portfolio/ironmouse.webp", name: "Ironmouse",         faction: "VShojo",              universe: "Vtuber",             tag: "VT" },
];
---
<Base title="portfolio" pageClass="page-index" showHeader={false} showFooter={true}>

  <!-- ============================================================
       SECTION TRACKER — fixed right-rail scroll indicator
       ============================================================ -->
  <nav class="tracker" aria-label="Section navigation">
    <a class="tracker__item is-active" data-section="hero" href="#hero">
      <span class="tracker__bar"></span>
      <span class="tracker__num">01</span>
      <span class="tracker__lbl">HERO</span>
    </a>
    <a class="tracker__item" data-section="graphic" href="#graphic">
      <span class="tracker__bar"></span>
      <span class="tracker__num">02</span>
      <span class="tracker__lbl">GRAPHIC</span>
    </a>
    <a class="tracker__item" data-section="roster" href="#roster">
      <span class="tracker__bar"></span>
      <span class="tracker__num">03</span>
      <span class="tracker__lbl">ROSTER</span>
    </a>
    <a class="tracker__item" data-section="catalog" href="#catalog">
      <span class="tracker__bar"></span>
      <span class="tracker__num">04</span>
      <span class="tracker__lbl">CATALOG</span>
    </a>
    <a class="tracker__item" data-section="themes" href="#themes">
      <span class="tracker__bar"></span>
      <span class="tracker__num">05</span>
      <span class="tracker__lbl">THEMES</span>
    </a>
    <a class="tracker__item" data-section="photo" href="#photo">
      <span class="tracker__bar"></span>
      <span class="tracker__num">06</span>
      <span class="tracker__lbl">PHOTOGRAPHY</span>
    </a>
  </nav>

  <!-- ============================================================
       SECTION 01 · HERO — dark cinematic banner
       ============================================================ -->
  <section id="hero" class="hero" aria-label="hero">
    <!-- Left rail — vertical brand + section indicator -->
    <div class="hero__rail hero__rail--l" aria-hidden="true">
      <span class="hero__mark"></span>
      <span class="ef-vrail">// TOKYO ZERO · CHROMADIPITY CORE</span>
    </div>

    <!-- Right rail — social icons -->
    <div class="hero__rail hero__rail--r">
      <a href="https://www.instagram.com/tokyozeroofficial/" target="_blank" rel="noopener" aria-label="Instagram">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="4" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="17" cy="7" r="1" fill="currentColor"/></svg>
      </a>
      <a href="https://github.com/dram64" target="_blank" rel="noopener" aria-label="GitHub">
        <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 00-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.15-1.1-1.46-1.1-1.46-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.9.83.1-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 015 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.86v2.75c0 .27.18.58.69.48A10 10 0 0012 2z" fill="currentColor"/></svg>
      </a>
      <a href="mailto:dez6220@gmail.com" aria-label="Email">
        <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="1" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M4 6l8 7 8-7" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
      </a>
    </div>

    <!-- Full-bleed hero backdrop artwork — that's it, just the art -->
    <img class="hero__art" src="/hero/nso-hero.webp" alt="Tokyo Zero hero artwork" />
  </section>

  <!-- ============ POST-HERO INFO STRIP ============ -->
  <div class="post-hero-strip" aria-hidden="true">
    <div class="post-hero-strip__inner">
      <span><em>// DESIGN</em> Astro · Space Grotesk · Chakra Petch · Beam Visionary</span>
      <span><em>// CLOUD</em> S3 · CloudFront · Lambda · Athena · Terraform</span>
      <span><em>// SPEND</em> ~$2/mo &middot; <a href="/status/">/status</a> &middot; <a href="/cost/">/cost</a> &middot; <a href="/insights/">/insights</a></span>
    </div>
    <div class="post-hero-strip__coords">
      <span>N 34.05° · W 118.24°</span>
      <span>BUILD 2026.07 · REV.001</span>
      <span>SIG.RSSI -42 dBm · LOCKED</span>
      <span>CH.7 // CHROMADIPITY</span>
      <span>FRAME.T-04 · REC.OK</span>
    </div>
  </div>

  <!-- ============ SECTION DIVIDER ============ -->
  <div class="ef-divider ef-divider--dark">
    <span class="ef-divider__mark">◤</span>
    <span class="ef-divider__code">SYS.02 · <em>GRAPHIC INTERFACES</em> · DROP-01 · REV.2026.07</span>
    <span class="ef-divider__mark">◢</span>
  </div>

  <!-- ============================================================
       SECTION 02 · GRAPHIC DESIGN WORK — Themed-Gallery layout
       ============================================================ -->
  <section id="graphic" class="sec02" aria-label="graphic design work">
    <!-- Ambient background layers -->
    <div class="ef-grid-bg" aria-hidden="true"></div>
    <div class="ef-watermark" style="top: 10%; right: -4%;">CHROMADIPITY</div>
    <div class="ef-watermark ef-watermark--accent" style="bottom: -8%; left: -4%; font-size: clamp(4rem, 12vw, 14rem);">/ ILLUSTRATION</div>

    <!-- Ambient annotation labels -->
    <span class="ef-coord ef-coord--dark" style="top: 20px; right: 24px;">T-01 · GRAPHIC / 02</span>
    <span class="ef-coord ef-coord--dark" style="bottom: 20px; left: 24px;">** MISSION-DEPENDENT PAYLOAD · SYSTEM INTERFACES</span>

    <!-- Tab bar -->
    <div class="sec02__tabs-wrap">
      <div class="sec02__brand">
        <span class="sec02__brand-mark"></span>
        <span class="sec02__brand-txt">TOKYO ZERO</span>
      </div>
      <div class="ef-tabs" role="tablist">
        <a class="is-active">Chromadipity</a>
        <a>PSG</a>
        <a>NSO</a>
        <a>Genshin · HSR</a>
        <a>Vtuber</a>
      </div>
    </div>

    <div class="sec02__body">
      <!-- Left rail — theme info -->
      <aside class="sec02__rail">
        <span class="sec02__chip"></span>
        <p class="ef-counter"><strong>02</strong><span class="sep">/</span>04</p>
        <p class="ef-meta">// THEME <em>&mdash; the roster</em></p>
        <p class="ef-meta">// CREATOR <em>&mdash; dram</em></p>
        <p class="ef-meta">// FORMAT <em>&mdash; digital painting</em></p>
        <p class="ef-meta">// SIZE <em>&mdash; 2400 &times; 1600</em></p>
        <p class="ef-meta">// ROSTER <em>&mdash; 40+ pcs</em></p>

        <dl class="ef-readout" style="margin-top: 20px;">
          <dt>track</dt><dd>03 / 12</dd>
          <dt>rev</dt><dd>2026.07</dd>
          <dt>state</dt><dd>ACTIVE</dd>
        </dl>

        <span class="ef-barcode" style="margin-top: 24px;">CTC.001.24</span>

        <p class="ef-meta" style="margin-top: 24px;">// SAMPLE ROSTER</p>
        <div class="ef-sprite-strip">
          <img src="/portfolio/kafka.webp"     alt="Kafka" />
          <img src="/portfolio/topaz.webp"     alt="Topaz" />
          <img src="/portfolio/psg.webp"       alt="PSG" />
          <img src="/portfolio/ayaka.webp"     alt="Ayaka" />
          <img src="/portfolio/jane.webp"      alt="Jane" />
          <img src="/portfolio/ironmouse.webp" alt="Ironmouse" />
        </div>

        <div class="sec02__rail-num" aria-hidden="true">
          <span class="sec02__rail-num-lg">02</span>
          <span class="sec02__rail-num-sub">CHROMADIPITY</span>
        </div>
      </aside>

      <!-- Center — filler slot with big graphic to drop in -->
      <div class="sec02__stage ef-corners">
        <span class="ef-corner--tr"></span>
        <span class="ef-corner--bl"></span>

        <!-- Floating sample thumbnails on the slot edges -->
        <span class="ef-code" style="position: absolute; top: 10px; left: 10px; z-index: 3;">[ T-01 · REC ]</span>
        <span class="ef-code ef-code--yellow" style="position: absolute; top: 10px; right: 10px; z-index: 3;">04 / 12</span>

        <div class="ef-slot">
          <span class="ef-slot__label">// slot 01 · illustration</span>
          <span class="ef-slot__icon">◇</span>
          <span class="ef-slot__dim">2400 &times; 1600 · webp · portrait or landscape both fit</span>
          <span class="ef-slot__dim">DROP HERO GRAPHIC HERE</span>
        </div>

        <span class="ef-code" style="position: absolute; bottom: 10px; left: 10px; z-index: 3;">** MISSION-DEPENDENT PAYLOAD // GRAPHIC-04</span>
        <span class="ef-code" style="position: absolute; bottom: 10px; right: 10px; z-index: 3;">SIG.LOCKED</span>

        <p class="sec02__stage-caption">// FEATURED PIECE &mdash; SWAP FREELY</p>
      </div>

      <!-- Right rail — rotated section text -->
      <aside class="sec02__rail sec02__rail--r">
        <span class="ef-vrail">OVER THE FRONTIER · CHROMADIPITY CORE</span>
      </aside>
    </div>

    <div class="sec02__foot">
      <div class="sec02__nav" aria-hidden="true">
        <button class="sec02__arrow">&larr;</button>
        <div class="sec02__progress">
          <span class="sec02__progress-bar">01 / 12</span>
        </div>
        <button class="sec02__arrow">&rarr;</button>
      </div>
      <p class="ef-meta">** MISSION-DEPENDENT PAYLOAD &mdash; INTERFACE / 002</p>
    </div>
  </section>

  <!-- ============ SECTION DIVIDER ============ -->
  <div class="ef-divider">
    <span class="ef-divider__mark">◤</span>
    <span class="ef-divider__code">SYS.03 · <em>OPERATOR ROSTER</em> · 40+ ENTRIES · DEEP RECORD</span>
    <span class="ef-divider__mark">◢</span>
  </div>

  <!-- ============================================================
       SECTION 03 · CHARACTER SHOWCASE — Operators layout
       ============================================================ -->
  <section id="roster" class="sec03" aria-label="character roster">
    <!-- Ambient background layers -->
    <div class="ef-grid-bg ef-grid-bg--fine" aria-hidden="true"></div>
    <div class="ef-watermark" style="top: -8%; left: 45%; letter-spacing: -0.06em; opacity: 0.6;">ROSTER</div>
    <div class="ef-watermark ef-watermark--accent" style="bottom: 6%; right: -6%; font-size: clamp(3rem, 8vw, 8rem);">/ / OP.001</div>

    <!-- Decorative halftone circle overlays from PSG assets -->
    <img class="ef-silhouette" src="/assets/psg-halftone-circle.webp" alt="" aria-hidden="true" style="top: -8%; left: -8%; width: 400px; opacity: 0.15;" />
    <img class="ef-silhouette" src="/assets/psg-halftone-circle.webp" alt="" aria-hidden="true" style="bottom: -12%; right: -8%; width: 500px; opacity: 0.12;" />

    <!-- Corner codes + coord labels -->
    <span class="ef-coord ef-coord--dark" style="top: 20px; right: 24px;">T-03 · ROSTER / 03</span>
    <span class="ef-coord ef-coord--dark" style="top: 20px; left: 24px;">// LIVE ROSTER · 06 ACTIVE</span>
    <span class="ef-coord ef-coord--dark" style="bottom: 20px; left: 24px;">** DEEP RECORD · CHROMADIPITY-CORE</span>
    <span class="ef-coord ef-coord--dark" style="bottom: 20px; right: 24px;">FRAME.T-04 · REC.OK</span>

    <!-- Left rail — portrait carousel -->
    <aside class="sec03__rail">
      <button class="sec03__scroll" aria-label="scroll up">&uarr;</button>
      {roster.map((r, i) => (
        <button class:list={["ef-portrait", i === 0 && "is-active"]} data-key={r.key} aria-label={r.name}>
          <img src={r.img} alt={r.name} />
        </button>
      ))}
      <button class="sec03__scroll" aria-label="scroll down">&darr;</button>
      <button class="sec03__all">
        <span class="ef-mono">All Characters</span>
      </button>
    </aside>

    <!-- Center — big character illustration + big bleed letters + yellow block -->
    <div class="sec03__stage">
      <div class="ef-yellow-block sec03__yellow"></div>
      <div class="ef-bleed-letters" data-target="letters">KAFKA</div>

      <div class="sec03__hero">
        <p class="ef-brk ef-brk--rec">
          <span class="rec-dot"></span> REC
        </p>
        <p class="sec03__index">
          <span class="sec03__name" data-target="name">Kafka</span>
          <span class="sec03__count"><em id="c-num">01</em> / 06</span>
        </p>

        <div class="sec03__ranking">
          <span class="sec03__diamond"></span>
          <span class="sec03__diamond"></span>
          <span class="sec03__diamond"></span>
          <span class="sec03__diamond"></span>
          <span class="sec03__diamond"></span>
        </div>

        <div class="sec03__img-wrap ef-corners">
          <span class="ef-corner--tr"></span>
          <span class="ef-corner--bl"></span>
          <img class="sec03__img" src="/portfolio/kafka.webp" alt="Kafka" data-target="img" />
          <!-- Corner codes on the illustration frame -->
          <span class="ef-code" style="position: absolute; top: 12px; left: 12px; z-index: 5;">[ RENDER · 01 ]</span>
          <span class="ef-code ef-code--yellow" style="position: absolute; top: 12px; right: 12px; z-index: 5;">4K · SIGNED</span>
          <span class="ef-code" style="position: absolute; bottom: 12px; left: 12px; z-index: 5;">** CAPTURED ON DESK · 2025.12</span>
        </div>

        <!-- Ambient annotations pointing near the illustration -->
        <div class="ef-annotation" style="top: 24%; left: -10%; max-width: 200px;">
          NOTE.01 · LINE WORK RENDERED PIXEL-EXACT AT 300 DPI
        </div>
        <div class="ef-annotation" style="bottom: 8%; left: -10%; max-width: 200px;">
          NOTE.02 · CHIBI + FULL-BODY VARIANTS SHIP TOGETHER
        </div>
      </div>

      <!-- Info card -->
      <div class="sec03__info">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
          <div class="sec03__info-icons">
            <span aria-hidden="true">◤◢</span>
          </div>
          <span class="ef-code ef-code--dark">FILE.01.KAFKA</span>
        </div>

        <p class="ef-brk" style="font-size: 1.1rem; letter-spacing: 0.06em;">
          <span data-target="brk-name">Kafka</span>
        </p>
        <div class="sec03__accent-bar"></div>

        <div class="sec03__tags">
          <span class="sec03__tag sec03__tag--k">Faction</span>
          <span class="sec03__tag-val" data-target="faction">Stellaron Hunters</span>
          <span class="sec03__tag sec03__tag--k">Universe</span>
          <span class="sec03__tag-val" data-target="universe">Honkai: Star Rail</span>
        </div>

        <div class="sec03__voice">
          <span class="sec03__voice-tag">✽</span>
          <span data-target="tag">HSR</span>
        </div>

        <p class="sec03__desc">
          Hand-illustrated character work &mdash; portraits, key art, chibi variants,
          and full-body poses. Each character in the roster serves a specific product
          category: deskmats, tapestries, prints, or acrylic stands.
        </p>

        <!-- Technical readout below the description -->
        <dl class="ef-readout" style="margin-top: 20px; grid-template-columns: auto 1fr auto 1fr; gap: 4px 12px;">
          <dt>medium</dt><dd>digital</dd>
          <dt>size</dt><dd>2400 &times; 3600</dd>
          <dt>dpi</dt><dd>300</dd>
          <dt>rev</dt><dd>v.03</dd>
          <dt>state</dt><dd>SHIPPED</dd>
          <dt>drop</dt><dd>D-04</dd>
        </dl>

        <!-- Barcode + ID strip -->
        <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 16px; padding-top: 12px; border-top: 1px dashed rgba(0,0,0,0.15);">
          <span class="ef-barcode">TZ.C-01.KAFKA.24</span>
          <span class="ef-code">◆ VERIFIED</span>
        </div>
      </div>
    </div>

    <!-- Right rail — vertical text + "Go to Catalog" -->
    <aside class="sec03__rail sec03__rail--r">
      <span class="ef-vrail">// FULL ROSTER &mdash; 40+ PIECES</span>
      <a class="sec03__cta" href="/catalog/">
        <span class="sec03__cta-mark">▲</span>
        <span class="sec03__cta-txt">Go to<br/>Catalog</span>
      </a>
    </aside>
  </section>

  <!-- ============ SECTION DIVIDER ============ -->
  <div class="ef-divider">
    <span class="ef-divider__mark">◤</span>
    <span class="ef-divider__code">SYS.04 · <em>CATALOG / DROP-01</em> · 30 SKUs · SHIPMENT ACTIVE</span>
    <span class="ef-divider__mark">◢</span>
  </div>

  <!-- ============================================================
       SECTION 04 · PRODUCT TILES — Tokyo Zero misc__card grid
       ============================================================ -->
  <section id="catalog" class="sec04" aria-label="from the catalog" style="position: relative;">
    <!-- Ambient background layers -->
    <div class="ef-grid-bg ef-grid-bg--fine" aria-hidden="true"></div>
    <div class="ef-watermark" style="top: -6%; right: -6%; opacity: 0.5;">CATALOG</div>
    <div class="ef-watermark ef-watermark--yellow" style="bottom: 20%; left: -4%; font-size: clamp(3rem, 10vw, 10rem);">/ / DROP.01</div>

    <span class="ef-coord ef-coord--dark" style="top: 20px; right: 24px;">T-04 · CATALOG / 04</span>
    <span class="ef-coord ef-coord--dark" style="top: 20px; left: 24px;">// SHIPMENT · ACTIVE · 30 UNITS</span>

    <div class="sec04__head">
      <p class="ef-meta">// TOKYO ZERO · CHROMADIPITY CORE ↘</p>
      <h2 class="ef-h ef-h--xl ef-h--block" style="text-transform: uppercase;">CATALOG</h2>
      <p class="ef-meta" style="margin-top: 12px;">// 08 FEATURED · 30 TOTAL · <em>DROP 01 / 2026</em></p>
    </div>

    <div class="sec04__meta-row">
      <p class="ef-meta">// Notices &nbsp; 2026-06-24 &nbsp; [ Tokyo Zero ] Featured Drops &nbsp; <em>&mdash; SIG.LIVE</em></p>
    </div>

    <!-- Decorative readout strip -->
    <div style="display: flex; gap: 24px; flex-wrap: wrap; margin-bottom: 32px;">
      <dl class="ef-readout">
        <dt>drop</dt><dd>01 / 2026</dd>
        <dt>ship</dt><dd>WORLDWIDE</dd>
      </dl>
      <dl class="ef-readout">
        <dt>shipping</dt><dd>$6.99 flat</dd>
        <dt>free at</dt><dd>$50+</dd>
      </dl>
      <dl class="ef-readout">
        <dt>drop rate</dt><dd>+1 sticker / $10</dd>
        <dt>status</dt><dd>ACTIVE</dd>
      </dl>
    </div>

    <div class="misc__grid">
      {featured.map((p, i) => (
        <ProductCard product={p} index={String(i + 1).padStart(2, "0")} category={p.category} />
      ))}
    </div>

    <div class="sec04__foot">
      <div class="sec02__nav">
        <button class="sec02__arrow" aria-label="prev">&larr;</button>
        <button class="sec02__arrow" aria-label="next">&rarr;</button>
      </div>
      <a class="ef-btn" href="/catalog/">
        <span class="ef-btn__bar"></span>
        <span class="ef-btn__body">More Intel &rarr;</span>
      </a>
    </div>
  </section>

  <!-- ============ SECTION DIVIDER ============ -->
  <div class="ef-divider">
    <span class="ef-divider__mark">◤</span>
    <span class="ef-divider__code">SYS.05 · <em>THEMED ROOMS</em> · 02 STOREFRONTS · SELECT PATH</span>
    <span class="ef-divider__mark">◢</span>
  </div>

  <!-- ============================================================
       SECTION 05 · THEMED ROOMS — big theme selector
       ============================================================ -->
  <section id="themes" class="sec-themes" aria-label="theme selector">
    <div class="ef-grid-bg ef-grid-bg--fine" aria-hidden="true"></div>
    <div class="ef-watermark" style="top: -8%; left: 45%; opacity: 0.5;">THEMES</div>
    <div class="ef-watermark ef-watermark--accent" style="bottom: 6%; right: -6%; font-size: clamp(3rem, 8vw, 8rem);">/ / RM.05</div>

    <span class="ef-coord ef-coord--dark" style="top: 20px; right: 24px;">T-05 · THEMED ROOMS / 05</span>
    <span class="ef-coord ef-coord--dark" style="top: 20px; left: 24px;">// SELECT STOREFRONT · 02 ACTIVE</span>
    <span class="ef-coord ef-coord--dark" style="bottom: 20px; left: 24px;">** EACH THEME · FULL PAGE EXPERIENCE · CLICK TO ENTER</span>

    <div class="sec-themes__head">
      <p class="ef-meta">// EXPERIMENTAL / THEMED ROOMS</p>
      <h2 class="ef-h ef-h--lg">select storefront.</h2>
      <p class="sec-themes__lede">
        Two alternate storefronts &mdash; each with its own hero, product spread,
        typography, and vibe. Enter one and it takes over the full page.
      </p>
    </div>

    <div class="theme-cards">
      <!-- PSG CARD -->
      <a class="theme-card theme-card--psg ef-corners" href="/work/psg/">
        <span class="ef-corner--tr"></span>
        <span class="ef-corner--bl"></span>

        <div class="theme-card__bg" aria-hidden="true"></div>
        <img class="theme-card__halftone" src="/assets/psg-halftone-circle.webp" alt="" aria-hidden="true" />

