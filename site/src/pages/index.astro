---
export const prerender = true;
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";
import { products } from "../data/products.ts";

// Every NSO / PSG / Yuzuha / Alice product on the catalog (21 items).
// Toki, Blanc Bunny and Evelyn intentionally excluded (per prior ask).
const featured = [
  // NSO drop (6)
  "nso-deskmat",
  "nso-ame-tapestry",
  "nso-kangel-tapestry",
  "nso-print",
  "nso-ame-sticker",
  "nso-kangel-sticker",
  // PSG drop (10)
  "psg-deskmat",
  "psg-panty-tapestry",
  "psg-stocking-tapestry",
  "psg-panty-acrylic",
  "psg-stocking-acrylic",
  "psg-print",
  "psg-panty-sticker",
  "psg-stocking-sticker",
  "psg-tote",
  "psg-lanyard",
  // Yuzuha & Alice (5)
  "deskmat-yuzuha-alice",
  "print-yuzuha",
  "print-alice",
  "sticker-yuzuha",
  "sticker-alice",
].map(slug => products.find(p => p.slug === slug)).filter(Boolean);
---
<Base title="portfolio" pageClass="page-index" showHeader={false} showFooter={true}>

  <!-- ================================================================
       SECTION TRACKER — fixed right rail, misc-styled
       ================================================================ -->
  <nav class="tracker" aria-label="Section navigation">
    <a class="tracker__item is-active" data-section="hero" href="#hero">
      <span class="tracker__bar"></span><span class="tracker__num">01</span><span class="tracker__lbl">hero</span>
    </a>
    <a class="tracker__item" data-section="graphic" href="#graphic">
      <span class="tracker__bar"></span><span class="tracker__num">02</span><span class="tracker__lbl">graphic</span>
    </a>
    <a class="tracker__item" data-section="photo" href="#photo">
      <span class="tracker__bar"></span><span class="tracker__num">03</span><span class="tracker__lbl">photo</span>
    </a>
    <a class="tracker__item" data-section="catalog" href="#catalog">
      <span class="tracker__bar"></span><span class="tracker__num">04</span><span class="tracker__lbl">catalog</span>
    </a>
  </nav>

  <!-- ================================================================
       01 · HERO — auto-crossfade carousel between NSO + Yuzuha/Alice
       ================================================================ -->
  <section id="hero" class="hero" aria-label="hero">
    <img class="hero__art is-active" src="/hero/nso-hero.webp"          alt="NSO — Ame &amp; KAngel key art" data-slide="0" />
    <img class="hero__art"           src="/hero/yuzuha-alice-hero.webp" alt="Yuzuha &amp; Alice key art"     data-slide="1" />

    <div class="hero__dots" role="tablist" aria-label="Hero carousel">
      <button class="hero__dot is-active" data-goto="0" aria-label="Slide 1"></button>
      <button class="hero__dot"           data-goto="1" aria-label="Slide 2"></button>
    </div>
  </section>

  <!-- ================================================================
       POST-HERO STRIP — soft info bar
       ================================================================ -->
  <div class="hero-strip" aria-hidden="true" data-reveal>
    <span><em>design</em> apex mk3 &middot; beam visionary &middot; branding pro</span>
    <span><em>cloud</em> s3 &middot; cloudfront &middot; lambda &middot; athena &middot; terraform</span>
    <span><em>spend</em> ~$2/mo &mdash; <a href="/status/">/status</a> &middot; <a href="/cost/">/cost</a></span>
  </div>

  <!-- ================================================================
       BOUNDARY DIVIDER — last full-bleed element
       ================================================================ -->
  <div class="section-divider section-divider--boundary" data-reveal>
    <span class="section-divider__num">01</span>
    <span class="section-divider__label">graphic interfaces &middot; drop 01</span>
    <span class="section-divider__mark"></span>
  </div>

  <!-- ================================================================
       02 · GRAPHIC DESIGN
       ================================================================ -->
  <section id="graphic" class="sec">
    <div class="sec__head sec__head--with-themes" data-reveal>
      <div class="sec__head-text">
        <p class="sec__num">02 / 04</p>
        <p class="sec__eyebrow">Graphics designs</p>
        <h2 class="sec__title">VARIOUS</h2>
        <p class="sec__lede">
          All character artworks commissioned. Graphic designs done by me.
        </p>
      </div>
      <aside class="theme-picks" aria-label="Themed storefronts">
        <span class="theme-picks__label">themed rooms</span>
        <nav class="misc__theme-switch" aria-label="Theme">
          <a class="misc__theme-square misc__theme-square--psg" href="/work/psg/" aria-label="PSG theme">
            <img class="misc__theme-square-char misc__theme-square-char--panty"    src="/assets/psg-panty-sticker.webp"    alt="" aria-hidden="true" loading="lazy" />
            <img class="misc__theme-square-char misc__theme-square-char--stocking" src="/assets/psg-stocking-sticker.webp" alt="" aria-hidden="true" loading="lazy" />
            <span class="misc__theme-square-label">psg</span>
          </a>
          <a class="misc__theme-square misc__theme-square--nso" href="/work/nso/" aria-label="NSO theme">
            <img class="misc__theme-square-char misc__theme-square-char--ame"    src="/assets/nso-ame-sticker.webp"    alt="" aria-hidden="true" loading="lazy" />
            <img class="misc__theme-square-char misc__theme-square-char--kangel" src="/assets/nso-kangel-sticker.webp" alt="" aria-hidden="true" loading="lazy" />
            <span class="misc__theme-square-label">nso</span>
          </a>
        </nav>
      </aside>
    </div>

    <div class="gd-board">

      <!-- ================================================================
           THE CONSTELLATION — full-viewport dark theatre of design work
           14 nodes: 12 stills + 2 reels. Positioned by cluster:
             upper-left  · character portraits (cover, citlali, fmig)
             center      · motion + hero widescreens
             upper-right · wide banner headers
             right edge  · tall vertical banners
             bottom      · square set & prints, wide floaters
           SVG edges connect within clusters (bright/yellow) and across
           clusters (faint) to visualize the relationship graph.
           ================================================================ -->
      <div class="cn-space" aria-label="Constellation of graphic design pieces">
        <svg class="cn-edges" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
          <!-- Motion/hero triad (yellow — the two reels + widescreen) -->
          <line class="cn-edge cn-edge--yellow" x1="30" y1="28" x2="52" y2="50" />
          <line class="cn-edge cn-edge--yellow" x1="30" y1="28" x2="24" y2="50" />
          <line class="cn-edge cn-edge--yellow" x1="24" y1="50" x2="52" y2="50" />

          <!-- Row 1 top lace -->
          <line class="cn-edge" x1="14" y1="12" x2="36" y2="8" />
          <line class="cn-edge" x1="36" y1="8"  x2="62" y2="10" />
          <line class="cn-edge" x1="62" y1="10" x2="86" y2="12" />

          <!-- Row 2 spine -->
          <line class="cn-edge" x1="8"  y1="32" x2="30" y2="28" />
          <line class="cn-edge" x1="60" y1="30" x2="84" y2="30" />
          <line class="cn-edge" x1="84" y1="30" x2="96" y2="30" />

          <!-- Row 3 spine -->
          <line class="cn-edge" x1="8"  y1="50" x2="24" y2="50" />
          <line class="cn-edge" x1="52" y1="50" x2="78" y2="50" />
          <line class="cn-edge" x1="78" y1="50" x2="94" y2="50" />

          <!-- Row 4 lace -->
          <line class="cn-edge" x1="10" y1="70" x2="28" y2="70" />
          <line class="cn-edge" x1="28" y1="70" x2="48" y2="70" />
          <line class="cn-edge" x1="48" y1="70" x2="68" y2="70" />
          <line class="cn-edge" x1="68" y1="70" x2="88" y2="70" />

          <!-- Row 5 baseline -->
          <line class="cn-edge" x1="18" y1="88" x2="38" y2="88" />
          <line class="cn-edge" x1="38" y1="88" x2="60" y2="88" />
          <line class="cn-edge" x1="60" y1="88" x2="88" y2="88" />

          <!-- Left totem rail -->
          <line class="cn-edge" x1="5"  y1="84" x2="10" y2="70" />

          <!-- Cross-cluster narrative edges (faint) -->
          <line class="cn-edge cn-edge--faint" x1="30" y1="28" x2="36" y2="8" />
          <line class="cn-edge cn-edge--faint" x1="60" y1="30" x2="52" y2="50" />
          <line class="cn-edge cn-edge--faint" x1="24" y1="50" x2="28" y2="70" />
          <line class="cn-edge cn-edge--faint" x1="52" y1="50" x2="48" y2="70" />
          <line class="cn-edge cn-edge--faint" x1="94" y1="50" x2="88" y2="70" />
        </svg>

        <!-- Ambient stars — pulses filling gaps between nodes -->
        <span class="cn-star" style="--x: 46%; --y: 20%; --sd: 0" aria-hidden="true"></span>
        <span class="cn-star" style="--x: 66%; --y: 20%; --sd: 1" aria-hidden="true"></span>
        <span class="cn-star" style="--x: 84%; --y: 42%; --sd: 2" aria-hidden="true"></span>
        <span class="cn-star" style="--x: 40%; --y: 40%; --sd: 3" aria-hidden="true"></span>
        <span class="cn-star" style="--x: 84%; --y: 60%; --sd: 4" aria-hidden="true"></span>
        <span class="cn-star" style="--x: 40%; --y: 60%; --sd: 5" aria-hidden="true"></span>
        <span class="cn-star" style="--x: 60%; --y: 80%; --sd: 6" aria-hidden="true"></span>
        <span class="cn-star" style="--x: 30%; --y: 80%; --sd: 7" aria-hidden="true"></span>
        <span class="cn-star cn-star--big" style="--x: 96%; --y: 4%; --sd: 8" aria-hidden="true"></span>
        <span class="cn-star cn-star--big" style="--x: 6%; --y: 4%; --sd: 9" aria-hidden="true"></span>

        <!-- Row 1 · Top (4 nodes) — portrait, wide banner, wide banner, portrait -->
        <figure class="cn-node cn-node--s" style="--ar: 0.80; --x: 14%; --y: 12%; --d: 0" data-tag="portrait · 01">
          <img src="/showcase/graphics/portrait-01.webp" alt="Portrait 01" loading="lazy" />
          <span class="cn-node__tag">portrait &middot; 01</span>
        </figure>
        <figure class="cn-node cn-node--m" style="--ar: 2.22; --x: 36%; --y: 8%; --d: 1" data-tag="banner · 01">
          <img src="/showcase/graphics/banner-01.webp" alt="Banner 01" loading="lazy" />
          <span class="cn-node__tag">banner &middot; 01</span>
        </figure>
        <figure class="cn-node cn-node--m" style="--ar: 2.22; --x: 62%; --y: 10%; --d: 2" data-tag="psg · deskmat">
          <img src="/showcase/graphics/psg-deskmat.webp" alt="PSG deskmat" loading="lazy" />
          <span class="cn-node__tag">psg &middot; deskmat</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 0.75; --x: 86%; --y: 12%; --d: 3" data-tag="citlali · mobile">
          <img src="/showcase/graphics/citlali-mobile.webp" alt="Citlali mobile" loading="lazy" />
          <span class="cn-node__tag">citlali &middot; mobile</span>
        </figure>

        <!-- Row 2 · Upper-middle (5 nodes) — motion hero band -->
        <figure class="cn-node cn-node--s" style="--ar: 0.80; --x: 8%; --y: 32%; --d: 4" data-tag="fmig · post">
          <img src="/showcase/graphics/fmig-post.webp" alt="FMIG post" loading="lazy" />
          <span class="cn-node__tag">fmig &middot; post</span>
        </figure>
        <figure class="cn-node cn-node--xl cn-node--video" style="--ar: 2.37; --x: 30%; --y: 28%; --d: 5" data-tag="header mograph · motion">
          <video muted loop playsinline autoplay preload="metadata" poster="/showcase/motion/header-mograph-poster.jpg">
            <source src="/showcase/motion/header-mograph.webm" type="video/webm" />
            <source src="/showcase/motion/header-mograph.mp4" type="video/mp4" />
          </video>
          <span class="cn-node__tag">header mograph &middot; motion</span>
        </figure>
        <figure class="cn-node cn-node--l" style="--ar: 2.37; --x: 60%; --y: 30%; --d: 6" data-tag="citlali · header">
          <img src="/showcase/graphics/citlali-header.webp" alt="Citlali header" loading="lazy" />
          <span class="cn-node__tag">citlali &middot; header</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 0.80; --x: 84%; --y: 32%; --d: 7" data-tag="portrait · 02">
          <img src="/showcase/graphics/portrait-02.webp" alt="Portrait 02" loading="lazy" />
          <span class="cn-node__tag">portrait &middot; 02</span>
        </figure>
        <figure class="cn-node cn-node--xs" style="--ar: 0.65; --x: 96%; --y: 30%; --d: 8" data-tag="pdf · astra yao">
          <img src="/showcase/graphics/pdf-astra-yao.webp" alt="Astra Yao PDF preview" loading="lazy" />
          <span class="cn-node__tag">pdf &middot; astra yao</span>
        </figure>

        <!-- Row 3 · Middle (5 nodes) — chii widescreen at heart -->
        <figure class="cn-node cn-node--xs" style="--ar: 0.65; --x: 8%; --y: 50%; --d: 9" data-tag="cipher · print">
          <img src="/showcase/graphics/cipher-print.webp" alt="Cipher print" loading="lazy" />
          <span class="cn-node__tag">cipher &middot; print</span>
        </figure>
        <figure class="cn-node cn-node--xs cn-node--video" style="--ar: 0.5625; --x: 24%; --y: 50%; --d: 10" data-tag="comp 1_1 · reel">
          <video muted loop playsinline autoplay preload="metadata" poster="/showcase/motion/comp-1-1-poster.jpg">
            <source src="/showcase/motion/comp-1-1.webm" type="video/webm" />
            <source src="/showcase/motion/comp-1-1.mp4" type="video/mp4" />
          </video>
          <span class="cn-node__tag">comp 1_1 &middot; reel</span>
        </figure>
        <figure class="cn-node cn-node--l" style="--ar: 2.22; --x: 52%; --y: 50%; --d: 11" data-tag="chii · widescreen">
          <img src="/showcase/graphics/chii3.webp" alt="Chii widescreen illustration" loading="lazy" />
          <span class="cn-node__tag">chii &middot; widescreen</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 1.25; --x: 78%; --y: 50%; --d: 12" data-tag="topbox">
          <img src="/showcase/graphics/topbox.webp" alt="Topbox" loading="lazy" />
          <span class="cn-node__tag">topbox</span>
        </figure>
        <figure class="cn-node cn-node--xs" style="--ar: 0.65; --x: 94%; --y: 50%; --d: 13" data-tag="pdf · kafka">
          <img src="/showcase/graphics/pdf-kafka.webp" alt="Kafka PDF preview" loading="lazy" />
          <span class="cn-node__tag">pdf &middot; kafka</span>
        </figure>

        <!-- Row 4 · Middle-lower (5 nodes) — square + prints -->
        <figure class="cn-node cn-node--s" style="--ar: 1; --x: 10%; --y: 70%; --d: 14" data-tag="concept · square">
          <img src="/showcase/graphics/concept-square.webp" alt="Concept square" loading="lazy" />
          <span class="cn-node__tag">concept &middot; square</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 1; --x: 28%; --y: 70%; --d: 15" data-tag="product · square">
          <img src="/showcase/graphics/product-square.webp" alt="Product square" loading="lazy" />
          <span class="cn-node__tag">product &middot; square</span>
        </figure>
        <figure class="cn-node cn-node--s" style="--ar: 0.80; --x: 48%; --y: 70%; --d: 16" data-tag="portrait · 03">
          <img src="/showcase/graphics/portrait-03.webp" alt="Portrait 03" loading="lazy" />
          <span class="cn-node__tag">portrait &middot; 03</span>
        </figure>
        <figure class="cn-node cn-node--xs" style="--ar: 0.55; --x: 68%; --y: 70%; --d: 17" data-tag="nso · psg anm">
          <img src="/showcase/graphics/nsopsg-anm.webp" alt="NSO/PSG animation" loading="lazy" />
          <span class="cn-node__tag">nso &middot; psg anm</span>
        </figure>
        <figure class="cn-node cn-node--xs" style="--ar: 0.65; --x: 88%; --y: 70%; --d: 18" data-tag="fuwamoco · illust">
          <img src="/showcase/graphics/fuwamoco-illust.webp" alt="Fuwamoco commercial illustration" loading="lazy" />
          <span class="cn-node__tag">fuwamoco &middot; illust</span>
        </figure>

        <!-- Row 5 · Bottom (4 nodes: 2 tall stills + 2 wide banners) -->
        <figure class="cn-node cn-node--xs" style="--ar: 0.56; --x: 18%; --y: 88%; --d: 20" data-tag="yx · story">
          <img src="/showcase/graphics/yx-story.webp" alt="Yx story" loading="lazy" />
          <span class="cn-node__tag">yx &middot; story</span>
        </figure>
        <figure class="cn-node cn-node--xs" style="--ar: 0.65; --x: 38%; --y: 88%; --d: 21" data-tag="print · 01">
          <img src="/showcase/graphics/print-01.webp" alt="Print 01" loading="lazy" />
          <span class="cn-node__tag">print &middot; 01</span>
        </figure>
        <figure class="cn-node cn-node--m" style="--ar: 2.37; --x: 60%; --y: 88%; --d: 22" data-tag="ayaka · header">
          <img src="/showcase/graphics/dodgers-ayaka-header.webp" alt="Dodgers Ayaka header" loading="lazy" />
          <span class="cn-node__tag">ayaka &middot; header</span>
        </figure>
        <figure class="cn-node cn-node--m" style="--ar: 2.22; --x: 88%; --y: 88%; --d: 23" data-tag="banner · 02">
          <img src="/showcase/graphics/banner-02.webp" alt="Banner 02" loading="lazy" />
          <span class="cn-node__tag">banner &middot; 02</span>
        </figure>

        <!-- Theme storefront full-page screenshots (native tall aspect) -->
        <figure class="cn-node cn-node--m" style="--ar: 0.40; --d: 24" data-tag="theme · psg">
          <img src="/showcase/graphics/theme-psg.webp" alt="PSG themed storefront full page" loading="lazy" />
          <span class="cn-node__tag">theme &middot; psg</span>
        </figure>
        <figure class="cn-node cn-node--m" style="--ar: 0.50; --d: 25" data-tag="theme · nso">
          <img src="/showcase/graphics/theme-nso.webp" alt="NSO themed storefront full page" loading="lazy" />
          <span class="cn-node__tag">theme &middot; nso</span>
        </figure>
      </div>

    </div>
  </section>

  <!-- ================================================================
       03 · PRODUCT PHOTOGRAPHY — full-width 3D coverflow, caption below
       ================================================================ -->
  <section id="photo" class="sec">
    <div class="sec__head" data-reveal>
      <p class="sec__num">03 / 04</p>
      <p class="sec__eyebrow">product photography</p>
      <h2 class="sec__title">finished pieces.</h2>
    </div>

    <!-- Full-width 3D coverflow — spans the whole section -->
    <div class="lead-3d" aria-label="Product photography carousel">
          <div class="lead-3d__stage">
            <button class="lead-3d__card" data-i="0" aria-label="Frame 01">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-01.webp" alt="Product photography frame 01" loading="lazy" />
                <span class="lead-3d__card-tag">01</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="1" aria-label="Frame 02">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-02.webp" alt="Product photography frame 02" loading="lazy" />
                <span class="lead-3d__card-tag">02</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="2" aria-label="Frame 03">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-03.webp" alt="Product photography frame 03" loading="lazy" />
                <span class="lead-3d__card-tag">03</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="3" aria-label="Frame 04">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-04.webp" alt="Product photography frame 04" loading="lazy" />
                <span class="lead-3d__card-tag">04</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="4" aria-label="Frame 05">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-05.webp" alt="Product photography frame 05" loading="lazy" />
                <span class="lead-3d__card-tag">05</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="5" aria-label="Frame 06">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-06.webp" alt="Product photography frame 06" loading="lazy" />
                <span class="lead-3d__card-tag">06</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="6" aria-label="Frame 07">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-07.webp" alt="Product photography frame 07" loading="lazy" />
                <span class="lead-3d__card-tag">07</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="7" aria-label="Frame 08">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-08.webp" alt="Product photography frame 08" loading="lazy" />
                <span class="lead-3d__card-tag">08</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="8" aria-label="Frame 09">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-09.webp" alt="Product photography frame 09" loading="lazy" />
                <span class="lead-3d__card-tag">09</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="9" aria-label="Frame 10">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-10.webp" alt="Product photography frame 10" loading="lazy" />
                <span class="lead-3d__card-tag">10</span>
              </div>
            </button>
            <button class="lead-3d__card" data-i="10" aria-label="Frame 11">
              <div class="lead-3d__card-inner">
                <img src="/showcase/photography/photo-11.webp" alt="Product photography frame 11" loading="lazy" />
                <span class="lead-3d__card-tag">11</span>
              </div>
            </button>
          </div>

          <div class="lead-3d__ctrl">
            <button class="lead-3d__arrow" data-nav="prev" aria-label="Previous">&larr;</button>
            <div class="lead-3d__dots">
              <button class="is-active" data-goto="0" aria-label="Frame 01"></button>
              <button                   data-goto="1" aria-label="Frame 02"></button>
              <button                   data-goto="2" aria-label="Frame 03"></button>
              <button                   data-goto="3" aria-label="Frame 04"></button>
              <button                   data-goto="4" aria-label="Frame 05"></button>
              <button                   data-goto="5" aria-label="Frame 06"></button>
              <button                   data-goto="6" aria-label="Frame 07"></button>
              <button                   data-goto="7" aria-label="Frame 08"></button>
              <button                   data-goto="8" aria-label="Frame 09"></button>
              <button                   data-goto="9" aria-label="Frame 10"></button>
              <button                   data-goto="10" aria-label="Frame 11"></button>
