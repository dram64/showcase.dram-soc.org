---
export const prerender = true;
import Base from "../../layouts/Base.astro";
---

<Base title="work — tokyo zero catalog">
  <section class="work">
    <p class="work__kicker">tokyo zero · chromadipity core</p>
    <h1 class="work__title">the catalog.</h1>
    <p class="work__lede">
      A 47-product anime merch line. Character illustration, print production specs, three
      themed storefronts. This is a curated slice — head to
      <a href="https://www.instagram.com/tokyozeroofficial/" target="_blank" rel="noopener">
        @tokyozeroofficial</a> for the live drops.
    </p>

    <div class="work__themes">
      <a class="theme" href="/work/psg/">
        <p class="theme__num">01</p>
        <h2 class="theme__name">psg</h2>
        <p class="theme__desc">Panty &amp; Stocking pastiche — candy halftones, 7-item showcase, hot-pink frills.</p>
      </a>
      <a class="theme" href="/work/nso/">
        <p class="theme__num">02</p>
        <h2 class="theme__name">nso</h2>
        <p class="theme__desc">Needy Streamer Overload homage — CRT scanlines, RGB-glitching popups, chrome background.</p>
      </a>
      <a class="theme" href="/work/misc/">
        <p class="theme__num">03</p>
        <h2 class="theme__name">misc</h2>
        <p class="theme__desc">Neutral hub — magazine catalog, numbered cards, slate-violet accent, 47 products.</p>
      </a>
    </div>

    <div class="work__meta">
      <p>
        This section is a work-in-progress — page previews and hi-res mockups drop in as I
        migrate them from the live Shopify build. See <a href="/process/">/process</a> for
        the underlying design system.
      </p>
    </div>
  </section>

  <style>
    .work {
      max-width: 1080px;
      margin: 0 auto;
      padding: clamp(48px, 8vw, 96px) clamp(24px, 6vw, 48px);
    }
    .work__kicker {
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 16px;
    }
    .work__title {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(3rem, 8vw, 5.5rem);
      line-height: 1;
      margin: 0 0 20px;
    }
    .work__lede {
      font-size: 1.05rem;
      line-height: 1.55;
      color: var(--ink-soft);
      margin: 0 0 6vh;
      max-width: 620px;
    }
    .work__lede a { color: var(--accent); text-decoration: underline; }
    .work__themes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 6vh;
    }
    .theme {
      display: block;
      padding: 28px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      text-decoration: none;
      color: inherit;
      transition: transform 140ms ease, border-color 140ms ease;
    }
    .theme:hover {
      transform: translateY(-3px);
      border-color: var(--accent);
    }
    .theme__num {
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.16em;
      color: var(--ink-soft);
      margin: 0 0 12px;
    }
    .theme__name {
      font-family: var(--serif);
      font-weight: 400;
      font-size: 2rem;
      margin: 0 0 12px;
      line-height: 1;
    }
    .theme__desc {
      font-size: 0.92rem;
      color: var(--ink-soft);
      margin: 0;
      line-height: 1.5;
    }
    .work__meta {
      padding: 20px 24px;
      background: var(--accent-soft);
      border-radius: 8px;
      font-size: 0.95rem;
      color: var(--ink-soft);
    }
    .work__meta a { color: var(--accent); text-decoration: underline; }
    @media (max-width: 700px) {
      .work__themes { grid-template-columns: 1fr; }
    }
  </style>
</Base>
