---
export const prerender = true;
import Base from "../../../layouts/Base.astro";
import ProductCard from "../../../components/ProductCard.astro";
import { products } from "../../../data/products.ts";

const featured = [
  "deskmat-yuzuha-alice",
  "tapestry-astra-yao",
  "print-yuzuha",
  "sticker-blanc-bunny",
  "deskmat-toki-bunny",
  "tapestry-citlali",
  "print-castorice",
  "sticker-alice",
].map(slug => products.find(p => p.slug === slug)).filter(Boolean);

const roster = [
  { key: "kafka",     img: "/portfolio/kafka.webp",     name: "Kafka",             faction: "Stellaron Hunters", universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "topaz",     img: "/portfolio/topaz.webp",     name: "Topaz",             faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR" },
  { key: "psg",       img: "/portfolio/psg.webp",       name: "Panty & Stocking",  faction: "Daten City Church",  universe: "Panty & Stocking",  tag: "PSG" },
  { key: "ayaka",     img: "/portfolio/ayaka.webp",     name: "Kamisato Ayaka",    faction: "Kamisato Clan",       universe: "Genshin Impact",     tag: "GI" },
  { key: "jane",      img: "/portfolio/jane.webp",      name: "Jane Doe",          faction: "Tokyo Zero Original", universe: "Chromadipity Core",  tag: "OC" },
  { key: "ironmouse", img: "/portfolio/ironmouse.webp", name: "Ironmouse",         faction: "VShojo",              universe: "Vtuber",             tag: "VT" },
];
---
<Base title="lab — endfield ref" pageClass="page-index" showHeader={false} showFooter={true}>

  <!-- Small labeled banner marking this as the reference version -->
  <div style="background: #ffee00; color: #14131a; padding: 8px 24px; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; text-align: center;">
    // LAB · reference build · endfield-inspired · <a href="/" style="color: #14131a; text-decoration: underline;">back to /</a>
  </div>


  <!-- ============================================================
       SECTION 01 · HERO — dark cinematic banner
       ============================================================ -->
  <section class="hero" aria-label="hero">
    <!-- Left rail — vertical brand + section indicator -->
    <div class="hero__rail hero__rail--l" aria-hidden="true">
      <span class="hero__mark"></span>
      <span class="ef-vrail">// TOKYO ZERO · CHROMADIPITY CORE</span>
    </div>

    <!-- Right rail — social icons -->
    <div class="hero__rail hero__rail--r">
      <a href="https://www.instagram.com/tokyozeroofficial/" target="_blank" rel="noopener" aria-label="Instagram">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="4" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="17" cy="7" r="1" fill="currentColor"/></svg>
      </a>
      <a href="https://github.com/dram64" target="_blank" rel="noopener" aria-label="GitHub">
        <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 00-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.15-1.1-1.46-1.1-1.46-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.9.83.1-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 015 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.86v2.75c0 .27.18.58.69.48A10 10 0 0012 2z" fill="currentColor"/></svg>
      </a>
      <a href="mailto:desiramirez62200@gmail.com" aria-label="Email">
        <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="1" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M4 6l8 7 8-7" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
      </a>
    </div>

    <!-- Painterly atmosphere -->
    <div class="hero__glow hero__glow--l" aria-hidden="true"></div>
    <div class="hero__glow hero__glow--r" aria-hidden="true"></div>
    <div class="hero__grain" aria-hidden="true"></div>

    <!-- Sprites -->
    <img class="hero__char hero__char--l" src="/assets/psg-panty.webp"    alt="Panty" />
    <img class="hero__char hero__char--r" src="/assets/psg-stocking.webp" alt="Stocking" />
    <div class="hero__floor" aria-hidden="true"></div>

    <!-- Center frame -->
    <div class="hero__frame">
      <p class="hero__meta">
        <span class="ef-brk"><span class="rec-dot" style="width:8px;height:8px;border-radius:50%;background:#ff5566;box-shadow:0 0 8px #ff5566;display:inline-block;"></span> REC</span>
        <span class="hero__meta-sep">/</span>
        <span>01/04 · portfolio</span>
      </p>
      <div class="hero__title-wrap">
        <h1 class="hero__title">TOKYO<br/>ZERO</h1>
        <p class="hero__title-sub">chromadipity core</p>
      </div>
      <p class="hero__lede">
        Three themed anime merch storefronts &mdash; hand-illustrated character work,
        magazine-style catalog, shipped on a serverless AWS stack provisioned via Terraform.
      </p>
      <div class="hero__cta">
        <a class="ef-btn" href="/catalog/">
          <span class="ef-btn__bar"></span>
          <span class="ef-btn__body">▶ Enter Catalog</span>
        </a>
        <a class="hero__cta-alt" href="/architecture/">// the aws stack &rarr;</a>
      </div>
    </div>

    <!-- Bottom ticker -->
    <div class="hero__ticker" aria-hidden="true">
      <div class="hero__ticker-inner">
        <span><em>// DESIGN</em> Astro · Space Grotesk · Chakra Petch · Beam Visionary</span>
        <span><em>// CLOUD</em> S3 · CloudFront · Lambda · Athena · Terraform</span>
        <span><em>// OPS</em> <a href="/status/">/status</a> · <a href="/insights/">/insights</a></span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 02 · GRAPHIC DESIGN WORK — Themed-Gallery layout
       ============================================================ -->
  <section class="sec02" aria-label="graphic design work">
    <!-- Tab bar -->
    <div class="sec02__tabs-wrap">
      <div class="sec02__brand">
        <span class="sec02__brand-mark"></span>
        <span class="sec02__brand-txt">TOKYO ZERO</span>
      </div>
      <div class="ef-tabs" role="tablist">
        <a class="is-active">Chromadipity</a>
        <a>PSG</a>
        <a>NSO</a>
        <a>Genshin · HSR</a>
        <a>Vtuber</a>
      </div>
    </div>

    <div class="sec02__body">
      <!-- Left rail — theme info -->
      <aside class="sec02__rail">
        <span class="sec02__chip"></span>
        <p class="ef-counter"><strong>02</strong><span class="sep">/</span>04</p>
        <p class="ef-meta">// THEME <em>&mdash; the roster</em></p>
        <p class="ef-meta">// CREATOR <em>&mdash; dram</em></p>
        <div class="sec02__rail-num" aria-hidden="true">
          <span class="sec02__rail-num-lg">02</span>
          <span class="sec02__rail-num-sub">CHROMADIPITY</span>
        </div>
      </aside>

      <!-- Center — filler slot with big graphic to drop in -->
      <div class="sec02__stage ef-corners">
        <span class="ef-corner--tr"></span>
        <span class="ef-corner--bl"></span>
        <div class="ef-slot">
          <span class="ef-slot__label">// slot 01 · illustration</span>
          <span class="ef-slot__icon">◇</span>
          <span class="ef-slot__dim">2400 &times; 1600 · webp · portrait or landscape both fit</span>
          <span class="ef-slot__dim">DROP HERO GRAPHIC HERE</span>
        </div>
        <p class="sec02__stage-caption">// FEATURED PIECE &mdash; SWAP FREELY</p>
      </div>

      <!-- Right rail — rotated section text -->
      <aside class="sec02__rail sec02__rail--r">
        <span class="ef-vrail">OVER THE FRONTIER · CHROMADIPITY CORE</span>
      </aside>
    </div>

    <div class="sec02__foot">
      <div class="sec02__nav" aria-hidden="true">
        <button class="sec02__arrow">&larr;</button>
        <div class="sec02__progress">
          <span class="sec02__progress-bar">01 / 12</span>
        </div>
        <button class="sec02__arrow">&rarr;</button>
      </div>
      <p class="ef-meta">** MISSION-DEPENDENT PAYLOAD &mdash; INTERFACE / 002</p>
    </div>
  </section>

  <!-- ============================================================
       SECTION 03 · CHARACTER SHOWCASE — Operators layout
       ============================================================ -->
  <section class="sec03" aria-label="character roster">
    <!-- Left rail — portrait carousel -->
    <aside class="sec03__rail">
      <button class="sec03__scroll" aria-label="scroll up">&uarr;</button>
      {roster.map((r, i) => (
        <button class:list={["ef-portrait", i === 0 && "is-active"]} data-key={r.key} aria-label={r.name}>
          <img src={r.img} alt={r.name} />
        </button>
      ))}
      <button class="sec03__scroll" aria-label="scroll down">&darr;</button>
      <button class="sec03__all">
        <span class="ef-mono">All Characters</span>
      </button>
    </aside>

    <!-- Center — big character illustration + big bleed letters + yellow block -->
    <div class="sec03__stage">
      <div class="ef-yellow-block sec03__yellow"></div>
      <div class="ef-bleed-letters" data-target="letters">KAFKA</div>

      <div class="sec03__hero">
        <p class="ef-brk ef-brk--rec">
          <span class="rec-dot"></span> REC
        </p>
        <p class="sec03__index">
          <span class="sec03__name" data-target="name">Kafka</span>
          <span class="sec03__count"><em id="c-num">01</em> / 06</span>
        </p>

        <div class="sec03__ranking">
          <span class="sec03__diamond"></span>
          <span class="sec03__diamond"></span>
          <span class="sec03__diamond"></span>
          <span class="sec03__diamond"></span>
          <span class="sec03__diamond"></span>
        </div>

        <div class="sec03__img-wrap ef-corners">
          <span class="ef-corner--tr"></span>
          <span class="ef-corner--bl"></span>
          <img class="sec03__img" src="/portfolio/kafka.webp" alt="Kafka" data-target="img" />
        </div>
      </div>

      <!-- Info card -->
      <div class="sec03__info">
        <div class="sec03__info-icons">
          <span aria-hidden="true">◤◢</span>
        </div>
        <p class="ef-brk" style="font-size: 1.1rem; letter-spacing: 0.06em;">
          <span data-target="brk-name">Kafka</span>
        </p>
        <div class="sec03__accent-bar"></div>
        <div class="sec03__tags">
          <span class="sec03__tag sec03__tag--k">Faction</span>
          <span class="sec03__tag-val" data-target="faction">Stellaron Hunters</span>
          <span class="sec03__tag sec03__tag--k">Universe</span>
          <span class="sec03__tag-val" data-target="universe">Honkai: Star Rail</span>
        </div>
        <div class="sec03__voice">
          <span class="sec03__voice-tag">✽</span>
          <span data-target="tag">HSR</span>
        </div>
        <p class="sec03__desc">
          Hand-illustrated character work &mdash; portraits, key art, chibi variants,
          and full-body poses. Each character in the roster serves a specific product
          category: deskmats, tapestries, prints, or acrylic stands.
        </p>
      </div>
    </div>

    <!-- Right rail — vertical text + "Go to Catalog" -->
    <aside class="sec03__rail sec03__rail--r">
      <span class="ef-vrail">// FULL ROSTER &mdash; 40+ PIECES</span>
      <a class="sec03__cta" href="/catalog/">
        <span class="sec03__cta-mark">▲</span>
        <span class="sec03__cta-txt">Go to<br/>Catalog</span>
      </a>
    </aside>
  </section>

  <!-- ============================================================
       SECTION 04 · PRODUCT TILES — Tokyo Zero misc__card grid
       ============================================================ -->
  <section class="sec04" aria-label="from the catalog">
    <div class="sec04__head">
      <p class="ef-meta">// ARKNIGHTS:ENDFIELD ↘</p>
      <h2 class="ef-h ef-h--xl ef-h--block" style="text-transform: uppercase;">CATALOG</h2>
    </div>

    <div class="sec04__meta-row">
      <p class="ef-meta">// Notices &nbsp; 2026-06-24 &nbsp; [ Tokyo Zero ] Featured Drops</p>
    </div>

    <div class="misc__grid">
      {featured.map((p, i) => (
        <ProductCard product={p} index={String(i + 1).padStart(2, "0")} category={p.category} />
      ))}
    </div>

    <div class="sec04__foot">
      <div class="sec02__nav">
        <button class="sec02__arrow" aria-label="prev">&larr;</button>
        <button class="sec02__arrow" aria-label="next">&rarr;</button>
      </div>
      <a class="ef-btn" href="/catalog/">
        <span class="ef-btn__bar"></span>
        <span class="ef-btn__body">More Intel &rarr;</span>
      </a>
    </div>
  </section>

  <!-- ============================================================
       SECTION 05 · WHAT WE HAD BEFORE — kept for continuity
       (Product photography + paths)
       ============================================================ -->
  <section class="sec05" aria-label="product photography">
    <div class="sec05__head">
      <p class="ef-meta">// PRODUCT PHOTOGRAPHY</p>
      <h2 class="ef-h ef-h--lg">finished pieces.</h2>
      <p class="sec05__lede">
        Illustration &rarr; production &rarr; photography. Four physical drops from the roster.
      </p>
    </div>

    <div class="prod-grid">
      <figure class="prod ef-corners">
        <span class="ef-corner--tr"></span>
        <span class="ef-corner--bl"></span>
        <div class="prod__img"><img src="/portfolio/prod-kafka-acrylic.webp" alt="Kafka Acrylic Stand" loading="lazy" /></div>
        <figcaption>
          <span class="prod__label">// acrylic stand</span>
          <span class="prod__name">Kafka</span>
          <span class="prod__spec">5.6 &times; 7.4 in &middot; clear acrylic</span>
        </figcaption>
      </figure>
      <figure class="prod ef-corners">
        <span class="ef-corner--tr"></span>
        <span class="ef-corner--bl"></span>
        <div class="prod__img"><img src="/portfolio/prod-topaz-acrylic.webp" alt="Topaz Acrylic Stand" loading="lazy" /></div>
        <figcaption>
          <span class="prod__label">// acrylic stand</span>
          <span class="prod__name">Topaz</span>
          <span class="prod__spec">5.6 &times; 7.4 in &middot; clear acrylic</span>
        </figcaption>
      </figure>
      <figure class="prod ef-corners">
        <span class="ef-corner--tr"></span>
        <span class="ef-corner--bl"></span>
        <div class="prod__img"><img src="/portfolio/prod-faruzan.webp" alt="Faruzan Deskmat" loading="lazy" /></div>
        <figcaption>
          <span class="prod__label">// deskmat</span>
          <span class="prod__name">Faruzan</span>
          <span class="prod__spec">900 &times; 400 mm &middot; sublimated</span>
        </figcaption>
      </figure>
      <figure class="prod ef-corners">
        <span class="ef-corner--tr"></span>
        <span class="ef-corner--bl"></span>
        <div class="prod__img"><img src="/portfolio/prod-miku.webp" alt="Cinna Miku" loading="lazy" /></div>
        <figcaption>
          <span class="prod__label">// print</span>
          <span class="prod__name">Cinna Miku</span>
          <span class="prod__spec">12 &times; 18 in &middot; satin card stock</span>
        </figcaption>
      </figure>
    </div>

    <div class="sec05__paths">
      <a class="path" href="/work/">
        <p class="ef-meta">// 01</p>
        <h3 class="path__title">the three themes</h3>
        <p class="path__desc">PSG · NSO · MISC &mdash; each with a distinct visual system.</p>
      </a>
      <a class="path" href="/process/">
        <p class="ef-meta">// 02</p>
        <h3 class="path__title">design case study</h3>
        <p class="path__desc">Voice, typography, color, three-theme system.</p>
      </a>
      <a class="path" href="/architecture/">
        <p class="ef-meta">// 03</p>
        <h3 class="path__title">the aws stack</h3>
        <p class="path__desc">Serverless breakdown &mdash; request path, services, and IaC.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    // Portrait carousel — swap the character showcase on click.
    const roster = {
      kafka:     { name: "Kafka",             letters: "KAFKA",      faction: "Stellaron Hunters",       universe: "Honkai: Star Rail", tag: "HSR",  img: "/portfolio/kafka.webp",     num: "01" },
      topaz:     { name: "Topaz",             letters: "TOPAZ",      faction: "IPC · Strategic Investment", universe: "Honkai: Star Rail", tag: "HSR", img: "/portfolio/topaz.webp",     num: "02" },
      psg:       { name: "Panty & Stocking",  letters: "PSG",        faction: "Daten City Church",       universe: "Panty & Stocking",  tag: "PSG",  img: "/portfolio/psg.webp",       num: "03" },
      ayaka:     { name: "Kamisato Ayaka",    letters: "AYAKA",      faction: "Kamisato Clan",           universe: "Genshin Impact",     tag: "GI",   img: "/portfolio/ayaka.webp",     num: "04" },
      jane:      { name: "Jane Doe",          letters: "JANE",       faction: "Tokyo Zero Original",     universe: "Chromadipity Core",  tag: "OC",   img: "/portfolio/jane.webp",      num: "05" },
      ironmouse: { name: "Ironmouse",         letters: "MOUSE",      faction: "VShojo",                  universe: "Vtuber",             tag: "VT",   img: "/portfolio/ironmouse.webp", num: "06" },
    };
    document.querySelectorAll(".ef-portrait[data-key]").forEach(btn => {
      btn.addEventListener("click", () => {
        const k = btn.dataset.key;
        const r = roster[k];
        if (!r) return;
        document.querySelectorAll(".ef-portrait").forEach(b => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        const map = { name: r.name, letters: r.letters, "brk-name": r.name, faction: r.faction, universe: r.universe, tag: r.tag };
        Object.keys(map).forEach(target => {
          const el = document.querySelector(`[data-target="${target}"]`);
          if (el) el.textContent = map[target];
        });
        const img = document.querySelector('[data-target="img"]');
        if (img) img.src = r.img;
        const num = document.getElementById("c-num");
        if (num) num.textContent = r.num;
      });
    });
  </script>

  <style>
    /* ============================================================
       SECTION 01 · HERO — dark cinematic
       ============================================================ */
    .hero {
      position: relative;
      min-height: min(92vh, 900px);
      overflow: hidden;
      background:
        radial-gradient(ellipse at 25% 30%, rgba(80, 97, 185, 0.22) 0%, transparent 55%),
        radial-gradient(ellipse at 75% 70%, rgba(255, 129, 176, 0.14) 0%, transparent 60%),
        linear-gradient(180deg, #14131a 0%, #1c1a26 45%, #1a1622 100%);
      color: #f5f4f0;
      display: grid;
      grid-template-rows: 1fr auto;
      isolation: isolate;
    }
    .hero__glow {
      position: absolute;
      width: 60vw; height: 60vw;
      max-width: 900px; max-height: 900px;
      border-radius: 50%;
      filter: blur(90px);
      opacity: 0.55;
      pointer-events: none;
      z-index: 0;
    }
    .hero__glow--l { background: rgba(80, 97, 185, 0.35); top: -22%; left: -25%; }
    .hero__glow--r { background: rgba(255, 129, 176, 0.35); bottom: -30%; right: -25%; }
    .hero__grain {
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 20% 30%, transparent 2px, rgba(255,255,255,0.02) 3px),
        radial-gradient(circle at 80% 70%, transparent 2px, rgba(255,255,255,0.02) 3px);
      background-size: 4px 4px, 6px 6px;
      opacity: 0.6;
      pointer-events: none;
      z-index: 1;
    }
    .hero__char {
      position: absolute;
      bottom: 0;
      height: 92%;
      width: auto;
      max-width: 42%;
      object-fit: contain;
      object-position: bottom center;
      z-index: 3;
      filter: drop-shadow(0 30px 40px rgba(0, 0, 0, 0.5));
      pointer-events: none;
    }
    .hero__char--l { left: -3%; }
    .hero__char--r { right: -3%; }
    .hero__floor {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      height: 30%;
      background: linear-gradient(180deg, transparent 0%, rgba(20, 19, 26, 0.5) 60%, rgba(20, 19, 26, 0.9) 100%);
      z-index: 4;
      pointer-events: none;
    }

    /* Left/Right rails */
    .hero__rail {
      position: absolute;
      top: 0; bottom: 0;
      width: 60px;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 20px 0;
      background: rgba(20, 19, 26, 0.55);
      backdrop-filter: blur(8px);
    }
    .hero__rail--l { left: 0; border-right: 1px solid rgba(255,255,255,0.08); gap: 32px; }
    .hero__rail--r { right: 0; border-left:  1px solid rgba(255,255,255,0.08); gap: 20px; justify-content: center; }
    .hero__mark {
      display: block;
      width: 22px; height: 22px;
      background: #fff;
      clip-path: polygon(0 0, 100% 0, 100% 60%, 60% 100%, 0 100%);
    }
    .hero__rail--r a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.65);
      transition: color 140ms ease;
    }
    .hero__rail--r a:hover { color: #ffee00; }
    .hero__rail--r svg { width: 20px; height: 20px; }
    .hero__rail .ef-vrail { color: rgba(245, 244, 240, 0.55); }

    .hero__frame {
      position: relative;
      z-index: 5;
      align-self: center;
      justify-self: center;
      text-align: center;
      max-width: 720px;
      padding: 8vh clamp(80px, 8vw, 120px) 4vh;
    }
    .hero__meta {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(245, 244, 240, 0.75);
      margin: 0 0 32px;
    }
    .hero__meta-sep { opacity: 0.35; }
    .hero__meta .ef-brk { color: #ff8898; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; letter-spacing: 0.18em; }
    .hero__meta .ef-brk::before, .hero__meta .ef-brk::after { color: #ff5566; }

    .hero__title-wrap { margin-bottom: 20px; }
    .hero__title {
      font-family: 'Apex Mk3', 'Chakra Petch', sans-serif;
      font-weight: 300;
      font-size: clamp(4rem, 12vw, 8rem);
      line-height: 0.85;
      letter-spacing: 0.04em;
      color: #ffffff;
      text-shadow: 0 4px 30px rgba(80, 97, 185, 0.5);
